---
import Layout from "../layouts/Layout.astro";
import {getEntry} from "astro:content";
import {defaults} from "../config/site";

const site = await getEntry("siteInfo", "main");

// Fallbacks if content isn’t filled yet
const shopName = site?.data.name ?? defaults.siteName;
const addressObj = site?.data.address ?? defaults.address;

const phone = site?.data.phone ?? defaults.sitePhone;
const email = site?.data.email ?? defaults.siteEmail;
const hours = site?.data.hours ?? [];

const addressString = `${addressObj.streetAddress }, ${addressObj.addressLocality}, ${addressObj.addressRegion} ${addressObj.postalCode}`;
const mapQuery = encodeURIComponent(addressString);
const phoneDigits = phone.replace(/[^\d+]/g, ""); // keep + and digits
const phoneHref = `tel:${phoneDigits}`;
const emailHref = `mailto:${email}`;

// If you prefer the old embed with place_id, keep yours;
// otherwise a simple query-based embed (no key) works too:
// const mapSrc = `https://www.google.com/maps?q=${mapQuery}&output=embed`;

const mapSrc = `https://www.google.com/maps?q=${mapQuery}&output=embed`;

const contactJsonLd = {
    "@context": "https://schema.org",
    "@type": "TattooParlor",
    name: shopName,
    address: {
        "@type": "PostalAddress",
        streetAddress: addressObj.streetAddress,
        addressLocality: addressObj.addressLocality,
        addressRegion: addressObj.addressRegion,
        postalCode: addressObj.postalCode,
        addressCountry: addressObj.addressCountry
    },
    telephone: phone,
    email: email,
    url: "https://your-domain-here.com/contact"
};

const title = "Contact Us";
---

<Layout title={title}>

    <article class="page-article">
        <h1 class="page-title">{title}</h1>
        <div class="grid md:grid-cols-2 md:items-stretch">
            {/* Left: Contact + Hours */}
            <section class="border border-black/10 p-5 md:p-6" aria-labelledby="contact-info-heading">
                <h2 id="contact-info-heading" class="mb-4 text-xl font-semibold">
                    Visit or reach out
                </h2>

                <address class="not-italic">
                    <ul>
                        <li class="flex items-start gap-3">
                            <svg viewBox="0 0 24 24" class="mt-0.5 h-5 w-5 shrink-0" aria-hidden="true">
                                <path d="M12 2C8.1 2 5 5.1 5 9c0 5.2 7 13 7 13s7-7.8 7-13c0-3.9-3.1-7-7-7zm0 9.5c-1.4 0-2.5-1.1-2.5-2.5S10.6 6.5 12 6.5s2.5 1.1 2.5 2.5S13.4 11.5 12 11.5z"/>
                            </svg>
                            <div>
                                <div class="font-medium">{shopName}</div>
                                <a
                                        class="underline hover:no-underline"
                                        href={`https://www.google.com/maps/search/?api=1&query=${mapQuery}`}
                                        target="_blank"
                                        rel="noopener"
                                >
                                    {addressString}
                                </a>
                            </div>
                        </li>

                        <li class="flex items-start gap-3">
                            <svg viewBox="0 0 24 24" class="mt-0.5 h-5 w-5 shrink-0" aria-hidden="true">
                                <path d="M6.6 10.8c1.3 2.5 3.1 4.6 5.6 6l1.9-1.9c.3-.3.8-.4 1.1-.2 1.2.4 2.5.7 3.8.7.6 0 1 .4 1 .9V20c0 .5-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.5-1 1-1h3.7c.5 0 .9.4.9 1 0 1.3.2 2.6.7 3.8.1.4.1.8-.2 1.1l-1.5 1.9z"/>
                            </svg>
                            <a class="underline hover:no-underline" href={phoneHref} aria-label={`Call ${shopName}`}>
                                {phone}
                            </a>
                        </li>

                        <li class="flex items-start gap-3">
                            <svg viewBox="0 0 24 24" class="mt-0.5 h-5 w-5 shrink-0" aria-hidden="true">
                                <path d="M12 13L2 6.76V18a2 2 0 002 2h16a2 2 0 002-2V6.76L12 13zM21.64 5.23A2 2 0 0020 5H4a2 2 0 00-1.64.23L12 11l9.64-5.77z"/>
                            </svg>
                            <a class="underline hover:no-underline" href={emailHref} aria-label={`Email ${shopName}`}>
                                {email}
                            </a>
                        </li>
                    </ul>
                </address>


                {hours.length > 0 && (
                        <div class="mt-6">
                            <h3 class="mb-2 text-lg font-semibold">Hours | Drop-In*</h3>
                            <dl class="divide-y divide-black/10 border border-black/10">
                                {hours.map(({label, value}) => (
                                        <div class="grid grid-cols-2 gap-2 p-2">
                                            <dt>{label}</dt>
                                            <dd class="text-right">{value}</dd>
                                        </div>
                                ))}
                            </dl>
                        </div>
                )}

                <p class="mt-5 text-sm hidden">
                    Prefer forms? You can also reach us via{" "}
                    <a href="#contact-form" class="underline hover:no-underline">the contact form below</a>.
                </p>

                <p class="mt-5 text-sm">
                    *Appointment hours can vary based upon artist availability, which can fall outside the posted hours.
                </p>
            </section>

            {/* Right: Map embed */}
            <section
                    class="border border-black/10 p-2 md:p-3 flex flex-col"
                    aria-labelledby="map-heading"
            >
                <h2 id="map-heading" class="sr-only">Map</h2>

                {/* Map grows to fill remaining height */}
                <div class="relative overflow-hidden
                    aspect-video
                    md:aspect-auto md:flex-1
                    md:min-h-[400px]">
                    <iframe
                            title={`${shopName} location on Google Maps`}
                            src={mapSrc}
                            loading="lazy"
                            class="absolute left-0 top-0 h-full w-full border-0"
                    ></iframe>
                </div>

                <div class="mt-2 text-right">
                    <a
                            href={`https://www.google.com/maps/search/?api=1&query=${mapQuery}`}
                            target="_blank"
                            rel="noopener"
                            class="text-sm underline hover:no-underline"
                    >
                        Open in Google Maps →
                    </a>
                </div>
            </section>
        </div>
    </article>

    {/* SEO structured data */}
    <script
            type="application/ld+json"
            set:html={JSON.stringify(contactJsonLd)}
    />
</Layout>
