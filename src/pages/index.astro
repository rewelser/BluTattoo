---
import Layout from "../layouts/Layout.astro";
import { getEntry } from "astro:content";
import ScrollPeelStack from "../components/decor/ScrollPeelStack_original_modified.astro";
import DualFlourish from "../components/decor/DualFlourish.astro";
// import ParallaxWindow from "../components/decor/ParallaxWindow.astro";
// import ParallaxWindow from "../components/decor/ParallaxWindow 2.astro";
// import ParallaxWindow from "../components/decor/ParallaxWindow1-2.astro";
import ParallaxWindow from "../components/decor/ParallaxWindow2-2.astro";

// const home = await getEntry("home", "main"); // reads src/content/home/main.json
// const h = home?.data?.promoMain;
const title = "Home";
---

<script>
  import { bootFadeUp } from "../scripts/fade-up";
  bootFadeUp({ observeMutations: true });
</script>

<Layout isHome title={title}>
  <section class="relative w-full py-32 px-6 overflow-hidden">
    <!-- subtle background glow / depth -->
    <!-- <div class="pointer-events-none absolute inset-0">
      <div
        class="absolute inset-0 bg-gradient-to-b from-black via-black to-black"
      >
      </div>
      <div
        class="absolute -top-40 left-1/2 -translate-x-1/2 w-[800px] h-[800px] bg-orange-500/10 blur-[120px] rounded-full"
      >
      </div>
    </div> -->

    <!-- content -->
    <div
      class="relative max-w-4xl mx-auto text-center flex flex-col items-center gap-8"
    >
      <!-- headline -->
      <h1
        class="text-5xl sm:text-7xl md:text-9xl leading-[1.1] font-[Fleur_de_Leah] js-fade-up"
      >
        More than a tattoo.
      </h1>

      <!-- subheadline -->
      <p
        class="text-lg sm:text-xl md:text-2xl text-black/80 leading-relaxed max-w-2xl js-fade-up"
      >
        A collaboration between artist and canvas — shaped by story, refined by
        technique.
      </p>

      <!-- supporting line -->
      <p
        class="text-base sm:text-lg text-black/60 max-w-xl leading-relaxed js-fade-up"
      >
        At BluTattoo Studio, every piece is designed with intention and built to
        last.
      </p>

      <!-- CTA -->
      <div class="pt-6">
        <a
          href="/booking"
          class="inline-block px-8 py-3 border border-orange-100/30 rounded-full text-sm tracking-wide uppercase
               hover:bg-orange-100 hover:text-black transition duration-300 js-fade-up"
        >
          BOOKING
        </a>
      </div>
    </div>
  </section>

  <!-- /////////////////////////////////////////// -->

  <DualFlourish durationMs={1000} easing="linear" />

  <!-- /////////////////////////////////////////// -->
  <!-- <ParallaxWindow src="/uploads/misc_images/bigroom.webp" windowHeight="35vh" strength={0.35}> -->
  <ParallaxWindow
    src="/uploads/misc_images/bigroom.webp"
    kind="image"
    windowHeight="35vh"
    strength={0.55}
  >
    <!-- optional overlay -->
    <h2 style="color:white; text-shadow: 0 2px 16px rgba(0,0,0,.6);">
      A window into the scene
    </h2>
  </ParallaxWindow>

  <!-- <ParallaxWindow
  src="/uploads/misc_videos/hero-720.mp4"
  kind="video"
  strength={0.95}
  muted={true}
  autoplay={true}
  loop={true}
  playsinline={true}
/> -->

  <ScrollPeelStack
    id="beforeafter-test"
    heightVh={500}
    images={[
      "/uploads/people/zirk1.jpeg",
      "/uploads/misc_images/hero-poster.jpg",
      "/uploads/misc_images/hero-poster-red.jpg",
    ]}
    sideImages={{
      left: [
        { src: "/uploads/misc_images/hero-poster.jpg", alt: "Side A" },
        { src: "/uploads/misc_images/hero-poster-red.jpg", alt: "Side B" },
      ],
      right: [
        { src: "/uploads/misc_images/hero-poster.jpg", alt: "Side C" },
        { src: "/uploads/misc_images/hero-poster-red.jpg", alt: "Side D" },
      ],
    }}
  />
  <div class=" relative top-200px bg-transparent h-[500px] w-full"> test</div>
</Layout>
