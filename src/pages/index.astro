---
import Layout from "../layouts/Layout.astro";
import {getEntry} from "astro:content";
import ScrollPeelStack from "../components/decor/ScrollPeelStack.astro";
import DualFlourish from "../components/decor/DualFlourish.astro";
import HrDivider from "../components/decor/HrDivider.astro";
// import ParallaxWindow from "../components/decor/ParallaxWindow.astro";
// import ParallaxWindow from "../components/decor/ParallaxWindow 2.astro";
// import ParallaxWindow from "../components/decor/ParallaxWindow1-2.astro";
// import ParallaxWindow from "../components/decor/ParallaxWindow2-2.astro";
import ParallaxWindow from "../components/decor/ParallaxWindow2-3-3.astro";
import {defaults} from "../config/site.ts";
import ArtistRunway from "../components/ArtistRunway.astro";
import ParallaxObject from "../components/decor/ParallaxObject.astro";
import InkDroplet from "../components/decor/InkDroplet.astro";
import ObjectScatterField from "../components/decor/ObjectScatterField.astro";
import ScatterRegion from "../components/decor/ScatterRegion.astro";
import FramedImage from "../components/decor/FramedImage2.astro";

// const home = await getEntry("home", "main"); // reads src/content/home/main.json
// const h = home?.data?.promoMain;
const branding = await getEntry("branding", "main");
const site = await getEntry("siteInfo", "main");
const shopName = site?.data.siteName ?? defaults.siteName;
const addressObj = site?.data.address ?? defaults.address;

const phone = site?.data.phone ?? defaults.sitePhone;
const email = site?.data.email ?? defaults.siteEmail;
const hours = site?.data.hours ?? [];

const addressString = `${addressObj.streetAddress}, ${addressObj.addressLocality}, ${addressObj.addressRegion} ${addressObj.postalCode}`;
const mapQuery = encodeURIComponent(addressString);
const phoneDigits = phone.replace(/[^\d+]/g, ""); // keep + and digits
const phoneHref = `tel:${phoneDigits}`;
const emailHref = `mailto:${email}`;
const mapSrc = `https://www.google.com/maps?q=${mapQuery}&output=embed`;
const hoursShortline = site?.data.hoursShortline;

const ourStory = branding?.data.ourStory;

const title = "Home";
const description = "BluTattoo is a tattoo and piercing studio offering custom tattoos, guest artist events, piercing services, booking, aftercare, and artist information.";
---

<script>
    import {bootFadeUp} from "../scripts/fade-up";

    bootFadeUp({observeMutations: true});
</script>

<Layout isHome title={title} description={description}>
    <section class="relative w-full py-32 px-6 overflow-hidden" aria-labelledby="homepage-heading">
        <!-- content -->
        <div
                class="relative max-w-4xl mx-auto text-center flex flex-col items-center gap-8"
        >
            <!-- headline -->
            <h1 id="homepage-heading"
                class="text-5xl px-4 sm:text-7xl md:text-9xl font-[Fleur_de_Leah] overflow-visible js-fade-up">
                Stories, told by ink
            </h1>

            <!-- subheadline -->
            <p class="text-lg sm:text-xl md:text-2xl text-black/80 leading-relaxed max-w-2xl js-fade-up">
                A collaboration between artist and canvas.
            </p>

            <!-- supporting line -->
            <p class="text-base sm:text-lg text-black/60 max-w-xl leading-relaxed js-fade-up">
                At BluTattoo Studio, every piece is designed with intention and built to
                last.
            </p>

            <!-- CTA -->
            <div class="pt-6">
                <a
                        href="/booking"
                        class="inline-block px-8 py-3 border border-black shadow-[3px_3px_0_black] text-sm tracking-wide uppercase
               hover:bg-blue-100 hover:shadow-[2px_2px_0_black] hover:text-black transition duration-300 js-fade-up"
                >
                    BOOK NOW
                </a>
            </div>
        </div>
    </section>

    <!-- /////////////////////////////////////////// -->

    <DualFlourish durationMs={1000} easing="linear"/>

    <!-- /////////////////////////////////////////// -->
    <!-- <ParallaxWindow src="/uploads/misc_images/bigroom.webp" windowHeight="35vh" strength={0.35}> -->
    <section class="px-6 py-16 md:py-24" aria-labelledby="our-location-heading">
        <div class="m-2 rounded-xl overflow-hidden">
            <ParallaxWindow
                    src="/uploads/misc_images/blutattoo_exterior.jpg"
                    kind="image"
                    windowHeight="65vh"
                    strength={.95}
                    useMinMediaHeight={false}
            >
                <!-- optional overlay color:white; text-shadow: 0 2px 16px rgba(0,0,0,.6);  text-shadow-[4px_4px_0_rgba(0,0,0,.9),0_0_20px_rgb(0,0,0)] -->
                <h2 id="our-location-heading"
                    class="backdrop-blur-sm bg-white/20 rounded-md sm:rounded-lg md:rounded-xl p-2 sm:p-3 md:p-4 text-white text-shadow-[1px_1px_0_rgba(0,0,0),0_0_20px_rgb(0,0,0)] sm:text-shadow-[3px_3px_0_rgba(0,0,0),0_0_10px_rgb(0,0,0)] md:text-shadow-[4px_4px_0_rgba(0,0,0),0_0_10px_rgb(0,0,0)] text-5xl sm:text-7xl md:text-9xl font-[Fleur_de_Leah] js-fade-up">
                    Our Location
                </h2>
            </ParallaxWindow>
        </div>
        <div class="relative max-w-4xl mx-auto text-center flex flex-col items-center gap-8 pt-32 js-fade-up">
            <p class="text-lg sm:text-xl md:text-2xl text-black/80 leading-relaxed max-w-2xl">
                Nestled in the heart of Uptown Martinsville, Virginia:
            </p>
            <!--<div class="grid grid-cols-1 md:grid-cols-3">-->
            <div class="flex flex-col md:flex-row justify-around gap-8 w-full">
                <div class="pt-6">
                    <h3 class="text-3xl sm:text-4xl pb-4">ADDRESS</h3>
                    <a
                            class="underline hover:no-underline"
                            href={`https://www.google.com/maps/search/?api=1&query=${mapQuery}`}
                            target="_blank"
                            rel="noopener"
                    >
                        <p>{addressObj.streetAddress}</p>
                        <p>{addressObj.addressLocality} {addressObj.addressRegion}</p>
                    </a>
                </div>
                <div class="pt-6 flex flex-col">
                    <h3 class="text-3xl sm:text-4xl pb-4">CONTACT</h3>
                    <a class="underline hover:no-underline" href={phoneHref} aria-label={`Call ${shopName}`}>
                        {phone}
                    </a>

                    <a class="underline hover:no-underline" href={emailHref} aria-label={`Email ${shopName}`}>
                        {email}
                    </a>

                    <a class="underline hover:no-underline" href="/booking">
                        Schedule an appointment
                    </a>
                </div>
                <div class="pt-6">
                    <h3 class="text-3xl sm:text-4xl pb-4">HOURS</h3>
                    <p class="whitespace-pre-line">{hoursShortline}</p>
                </div>
            </div>
            <p class="text-base sm:text-lg text-black/60 max-w-xl leading-relaxed">
                <a class="underline hover:no-underline" href="/booking">Book now</a>, or come on in. Walk-ins welcome!
            </p>
        </div>
    </section>
    <div class="h-[50vh] w-full bg-repeat-x bg-size-[auto_100%]"
         style="background-image: url('/uploads/misc_images/scalloped_bg_to_gray.svg');">
    </div>
    <section class="bg-neutral-700 py-16 md:py-24" aria-labelledby="artists-heading" data-section-theme="neutraldark">
        <div class="mx-8 rounded-xl overflow-hidden">
            <ParallaxWindow
                    src="/uploads/misc_videos/fartists3-web.mp4"
                    srcMobile="/uploads/misc_videos/fartists3-mobile-portrait.mp4"
                    kind="video"
                    windowHeight="65vh"
                    mediaHeightMult={1}
                    mediaHeightMultMobile={.5}
                    strength={.95}
                    strengthMobile={1}
                    layerClass="grayscale brightness-75"
            >
                <!-- optional overlay color:white; text-shadow: 0 2px 16px rgba(0,0,0,.6);  text-shadow-[4px_4px_0_rgba(0,0,0,.9),0_0_20px_rgb(0,0,0)] -->
                <h2 id="artists-heading"
                    class="backdrop-blur-sm bg-white/20 rounded-md sm:rounded-lg md:rounded-xl p-2 sm:p-3 md:p-4 text-white text-shadow-[1px_1px_0_rgba(0,0,0),0_0_20px_rgb(0,0,0)] sm:text-shadow-[3px_3px_0_rgba(0,0,0),0_0_10px_rgb(0,0,0)] md:text-shadow-[4px_4px_0_rgba(0,0,0),0_0_10px_rgb(0,0,0)] text-5xl sm:text-7xl md:text-9xl font-[Fleur_de_Leah] js-fade-up">
                    Our Artists
                </h2>
            </ParallaxWindow>
        </div>
        <div class=" pt-16 md:pt-24 px-6">
            <ArtistRunway/>
        </div>
    </section>

    <!-- /////////////////////////////////////////// -->

    <ScatterRegion/>

    <!-- /////////////////////////////////////////// -->

    <section class="bg-[#231f20] py-64 md:py-80" aria-labelledby="our-process-heading" data-section-theme="neutraldark">
        <div class="mx-8 rounded-xl overflow-hidden">
            <ParallaxWindow
                    src="/uploads/misc_videos/ourprocess-web.mp4"
                    srcMobile="/uploads/misc_videos/ourprocess-mobile-portrait11.mp4"
                    kind="video"
                    windowHeight="65vh"
                    mediaHeightMult={1}
                    mediaHeightMultMobile={.5}
                    strength={.95}
                    strengthMobile={1}
                    layerClass="grayscale brightness-75"
            >
                <!-- optional overlay color:white; text-shadow: 0 2px 16px rgba(0,0,0,.6);  text-shadow-[4px_4px_0_rgba(0,0,0,.9),0_0_20px_rgb(0,0,0)] -->
                <h2 id="our-process-heading"
                    class="backdrop-blur-sm bg-white/20 rounded-md sm:rounded-lg md:rounded-xl p-2 sm:p-3 md:p-4 text-white text-shadow-[1px_1px_0_rgba(0,0,0),0_0_20px_rgb(0,0,0)] sm:text-shadow-[3px_3px_0_rgba(0,0,0),0_0_10px_rgb(0,0,0)] md:text-shadow-[4px_4px_0_rgba(0,0,0),0_0_10px_rgb(0,0,0)] text-5xl sm:text-7xl md:text-9xl font-[Fleur_de_Leah] js-fade-up">
                    Our Process
                </h2>
            </ParallaxWindow>
        </div>
        <div class="px-6 mx-auto mt-20 max-w-3xl text-center leading-relaxed apply-themed-prose">
            <!--<h1 class="text-8xl font-light">-->
            <!--    Sure! Here are some eye-catching blurbs to put on your tattoo shop website that stress both ease of process and adherence to compliance standards:-->
            <!--</h1>-->

            <p>
                Getting tattooed should feel exciting from the first idea to the final heal. Explore our artists' work
                and pick a vibe, or come talk to us and we'll brainstorm.
            </p>
            <p>
                Once you’re ready, book directly with your artist, or just walk on in! We’ll take care of
                the rest: a clean, licensed studio environment and guidance for keeping your
                tattoo looking great long after you leave the chair.
            </p>
            <p>
                Ready to start your next piece? Browse our artists, choose your fit, and let’s make something permanent.
            </p>

            <HrDivider color="seashell"/>
        </div>
        <div class=" pt-16 md:pt-24">
            <ScrollPeelStack
                    heightVh={800}
                    images={[
                        "/uploads/people/zirk1.jpeg",
                        "/uploads/misc_images/hero-poster.jpg",
                        "/uploads/misc_images/hero-poster-red.jpg",
                    ]}
                    sideImages={{
                        left: [
                            {src: "/uploads/misc_images/hero-poster.jpg", alt: "Side A"},
                            {src: "/uploads/misc_images/hero-poster-red.jpg", alt: "Side B"},
                        ],
                        right: [
                            {src: "/uploads/misc_images/hero-poster.jpg", alt: "Side C"},
                            {src: "/uploads/misc_images/hero-poster-red.jpg", alt: "Side D"},
                        ],
                    }}
                    openStartVh={2}
            />
        </div>
    </section>


    <!-- <ParallaxWindow
    src="/uploads/misc_videos/hero-720.mp4"
    kind="video"
    strength={0.95}
    muted={true}
    autoplay={true}
    loop={true}
    playsinline={true}
  /> -->


    <!-- <section id="our-story" class="px-6 py-16 md:py-24 bg-neutral-50"> -->
    {
        ourStory && (
                    <section id="our-story" class="px-6 py-16 md:py-24" data-section-theme="neutraldark">
                        <div class="mx-auto max-w-3xl flex justify-center fade-bottom-40">
                            <FramedImage
                                    kind="video"
                                    class="w-[80vw] lg:w-[40vw]"
                                    frame={ourStory?.frameImage}
                                    framedImage={ourStory?.image}
                                    videoSrc="/uploads/misc_videos/fartists3-web.mp4"
                                    videoSrcMobile="/uploads/misc_videos/fartists3-mobile-portrait.mp4"
                                    frameMask={ourStory?.frameWindowSvg}
                                    frameMaskImgMetadata={ourStory?.frameWindowSvg}
                                    photoAlt={`${ourStory?.imgAltText || "image for our story section"}`}
                            />
                            <style>
                                .fade-bottom-40 {
                                    -webkit-mask-image: linear-gradient(to bottom, black 80%, transparent 95%);
                                    mask-image: linear-gradient(to bottom, black 80%, transparent 95%);
                                }
                            </style>
                        </div>

                        <!-- <div class="mx-auto max-w-3xl prose prose-lg text-center leading-relaxed text-neutral-700"> -->
                        <div class="mx-auto max-w-3xl text-center leading-relaxed apply-themed-prose">
                            <h2 class="text-5xl sm:text-7xl md:text-9xl font-normal font-[Fleur_de_Leah]">
                                Our Story
                            </h2>
                            <p class="whitespace-pre-line">
                                {ourStory?.storyText}
                            </p>
                            <HrDivider color="seashell"/>
                        </div>
                    </section>
        )
    }
</Layout>
