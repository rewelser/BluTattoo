---
// src/pages/events.astro
import Layout from "../layouts/Layout.astro";
import PromoHero from "../components/PromoHero.astro";
import { EventsCalendar } from "../components/EventsCalendar copy";
import { buildEventsByYearMonthDay } from "../scripts/events";
import type { EventItem, EventsByYearMonthDay } from "../scripts/events";

import {
    loadEventsPublishedCached,
    splitUpcomingPast,
    pickFeaturedHero,
    fmtDateRange
} from "../scripts/events";

const now = new Date();

const events: EventItem[] = await loadEventsPublishedCached();
const eventsByYearMonthDay: EventsByYearMonthDay = await buildEventsByYearMonthDay(events);
// const events = await loadEventsPublished();
const { upcoming, past } = splitUpcomingPast(events, now);
const featured = pickFeaturedHero(upcoming);
---

<Layout title="BluTattoo Studio — Events">
    <article class="page-article page-article--stack space-y-6">
        <h1 class="page-title">Events</h1>

        {
            featured?.image && (
                <PromoHero
                    image={featured.image}
                    alt={featured.alt ?? featured.title}
                    className="p-8"
                />
            )
        }

        {
            upcoming.length > 0 ? (
                <section class="space-y-3">
                    <h2 class="text-xl font-semibold tracking-tight">
                        Upcoming
                    </h2>

                    <div class="divide-y divide-black/10 border border-black/10">
                        {upcoming.map((ev) => (
                            <a
                                class="block p-4 hover:bg-black/5"
                                href={`/events/${ev.id}`}
                            >
                                <div class="font-medium">{ev.title}</div>
                                <div class="text-sm opacity-80">
                                    {fmtDateRange(ev)}
                                    {ev.location ? ` • ${ev.location}` : ""}
                                </div>
                            </a>
                        ))}
                    </div>
                </section>
            ) : (
                <section class="border border-black/10 p-5 md:p-6">
                    <h2 class="text-xl font-semibold tracking-tight">
                        Stay tuned
                    </h2>
                    <p class="mt-2 leading-relaxed">
                        We’re planning events and guest spots. As soon as dates
                        are locked in, they’ll appear here.
                    </p>
                </section>
            )
        }

<EventsCalendar client:load eventsByYearMonthDay={eventsByYearMonthDay} currentDate={now} />

        {
            past.length > 0 && (
                <section class="space-y-3">
                    <h2 class="text-xl font-semibold tracking-tight">Past</h2>

                    <div class="divide-y divide-black/10 border border-black/10">
                        {past.slice(0, 6).map((ev) => (
                            <a
                                class="block p-4 hover:bg-black/5"
                                href={`/events/${ev.id}`}
                            >
                                <div class="font-medium">{ev.title}</div>
                                <div class="text-sm opacity-80">
                                    {fmtDateRange(ev)}
                                    {ev.location ? ` • ${ev.location}` : ""}
                                </div>
                            </a>
                        ))}
                    </div>
                </section>
            )
        }
    </article>
</Layout>