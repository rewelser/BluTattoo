---
// src/pages/faq.astro
import Layout from "../layouts/Layout.astro";
import { getCollection, type CollectionEntry } from "astro:content";

const entries = (await getCollection("faqs")) as CollectionEntry<"faqs">[];

const faqs = entries
  .sort((a, b) => (a.data.sort ?? 9999) - (b.data.sort ?? 9999))
  .map((e) => e.data);

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(({ q, a }) => ({
    "@type": "Question",
    "name": q,
    "acceptedAnswer": { "@type": "Answer", "text": a }
  }))
};
---

<Layout title="BluTattoo Studio — FAQ">


  <div class="shimmer-container m-40">
    <div class="shimmer-shadow"/>
    <div class="shimmer-border-box">
      <p>Shimmering Border Effect</p>
    </div>
    <div class="absolute top-[3px] left-[3px] h-full w-full rounded-[10px] -z-1 bg-[#b6d9ff] animate-ping-faint-normal" />
  </div>
  <style>
    .shimmer-container {
      position: relative;
      width: fit-content;
    }
    .shimmer-border-box {
      position: relative;
      width: 300px;
      height: 150px;
      padding: 20px;
      z-index: 1;
      background-color: #1a1a1a;
      color: white;
      border-radius: 10px;
      border: 3px solid transparent;
      background: 
      linear-gradient(white 0 0) padding-box,
      conic-gradient(from var(--glow-deg), white, #4DA3FF, #4DA3FF, #416AF1, #416AF1, #4DA3FF, #4DA3FF, white ) border-box;
      animation: glow 10s linear infinite;
  }

  .shimmer-shadow {
      content: "";
      position: absolute;
      top: 6px;
      left: 6px;
      width: 100%;
      height: 100%;
      background: conic-gradient(from var(--glow-deg), white, #4DA3FF, #4DA3FF, #416AF1, #416AF1, #4DA3FF, #4DA3FF, white);
      border-radius: 10px;
      animation: glow 10s linear infinite;
  }

  @property --glow-deg {
    syntax: "<angle>";
    inherits: true;
    initial-value: 0deg;
  }

  @keyframes glow {
    100% {
      --glow-deg: 360deg;
    }
  }
  </style>

  <article class="page-article page-article--stack space-y-6">
    <h1 class="page-title">FAQ</h1>

    <div class="divide-y divide-black/10 border border-black/10">
      {faqs.map(({ q, a }) => (
        <details class="group open:bg-black/5">
          <summary class="flex cursor-pointer items-center justify-between gap-4 p-4 font-medium hover:bg-black/5">
            <span>{q}</span>
            <svg viewBox="0 0 24 24" class="h-5 w-5 shrink-0 transition-transform group-open:rotate-180" aria-hidden="true">
              <path d="M7 10l5 5 5-5H7z" />
            </svg>
          </summary>

          <div class="px-4 pb-4">
            <p class="leading-relaxed">{a}</p>
          </div>
        </details>
      ))}
    </div>

    <p class="mt-6 text-sm">
      Still have questions? <a href="/contact" class="underline hover:no-underline">Contact us</a> or see
      our <a href="/aftercare" class="underline hover:no-underline">Aftercare</a> guide.
    </p>
  </article>


  {/* SEO: FAQPage structured data */}
  <script type="application/ld+json">
    {JSON.stringify(faqJsonLd)}
  </script>


</Layout>
