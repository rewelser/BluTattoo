---
import { getCollection, getEntry } from "astro:content";
import { Image } from "astro:assets";
import ParallaxWindow from "../components/decor/ParallaxWindow2-2.astro";
import "../styles/global.css";
import { socialIcons } from "../components/graphics/socialmedia/registry";
import { socialTypes } from "../scripts/socials-defs";
import type { SocialType } from "../scripts/socials-defs";

import {
    loadArtistsActiveNonguest,
} from "../scripts/people";

/**
 * ARTISTS
 */
const default_profile_image = "/uploads/defaults/default-booking-profile.jpg";

// Load & order artists todo: see if we can't refactor this into types.ts somehow
let people_unnormalized = await loadArtistsActiveNonguest();
let people = await loadArtistsActiveNonguest();
// console.log("people", people);
// const bookingOptions = artists2.map;
// const boof = artists2.map((entry) => {
//     label: entry.data.contact_socials_booking?.booking_note;
// });
// const moduleInfo = square?.link_or_module_info.find(
//   (item) => item.type === "module_info",
// );

const sickleSvg = `
