  <path fill="black" stroke="black" d="M286.59,485.79c-5.81-47.19-14.94-90.92-32.47-134.05-13.96-34.35-34.35-62.9-62.86-86.51l-54.76-45.33c-29.05-24.05-53.78-53.35-68.59-88.08-4.25-9.96-7.14-17.13-17.17-22.83-24.28-13.81-41.52-8.65-49.72-13.7-8.78-5.4,41.87-40.56,51.07-42.03,1.07-6.22,1.6-14.36,3.95-19.28,4.92-10.31,18.61-13.09,28.61-11.57l5.7,10.76c78.57-43.44,191.24-46.57,266.96,4.68,18.31,12.39,36.55,26.5,44.62,49.03-92.31-58.53-208.47-34.52-293.69,20.3,12.79,29.12,33.18,51.83,57.39,71.49,49.87,40.49,94.87,77.53,125.72,135.35,19.71,36.94,33.43,75.49,42.78,116.27,8.77,38.25-24.35,49.59-34.42,88.43-7.95-8.37-11.56-20.15-13.13-32.95ZM332.67,45.01c14.6,4.98,24.74,13.34,40.23,15.25-21.44-20.79-47.32-32.71-75.19-41.08C227.93-1.77,156.52,10.45,89.66,40.03c1.23,9.62,2.57,17.59,5.16,26.03,73.49-40.4,158.93-47.98,237.85-21.05ZM83.83,66.01l-4.04-35.2c-5.41.86-13.04,2.97-17.06,5.69-1.9,1.28-3.44,8.64-1.54,9.91l6.45,4.31c6.03,4.03,10.9,9.71,16.19,15.29ZM163.56,228.46c2.69,9.83,16.3,14.41,24.5,21.17,13.36-16.54-22.32-57.67-31.76-65.88-25.79-22.41-46.75-46.73-59.48-78.91-5.06-12.78-21.03-46.44-35.45-51.28-.25,7.55,0,15.75.99,21.29,18.72,4.5,29.03,38.71,34.46,55.53,13.57,41.99,55.25,55.99,59.94,73.18l6.8,24.89ZM57.32,102.77l-5.56-40.35c-14.87,8.23-26.9,16.32-38.62,27.16,17.58,1.94,30.05,5.53,44.18,13.19ZM130.92,183.47c-20.58-13.61-33.28-31.57-40.37-54.1-3.1-9.84-14.95-47.42-27.38-47.46,7.41,57.8,47.67,109.55,92.36,140.35.44-19.05-14.08-27.16-24.61-38.79ZM187.67,210.41c6.29,16.53,14.06,28.71,4.3,43.07,18.23,14.96,34.04,31.27,48.88,51.77,26.13-21.79-32.08-83.59-53.18-94.84ZM323.28,422.66l-5.35-19.36c-4.66,8.45-10.2,14.11-18.05,13.25-5.92-.65-12.69-8.08-13.75-15.2-3.87-25.95-9.57-49.93-18.69-74.56-4.25-11.49-3.84-22.04.82-33.37l-18.46-23.05c1.06,16.43,9.3,26.74-5.94,39.73,26.59,46.16,40.71,97.04,48.75,151.24,6.86-15.06,7.79-34.71,30.65-38.68ZM304.58,409.42c10.58-6,9.28-19.08,5.99-28-10.51-28.44-21.27-55.47-38.82-81.86-3.89,10.1-.98,20.1,2.57,29.47,8.74,23.1,13.78,45.66,17.3,69.94.8