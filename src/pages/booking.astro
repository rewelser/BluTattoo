    <script is:inline>
        (() => {
            const root = document.querySelector("[data-accordion-root]");
            if (!root) return;

            const isExpanded = (btn) =>
                btn.getAttribute("aria-expanded") === "true";

            const getPanel = (btn) => {
                const id = btn.getAttribute("aria-controls");
                return id ? document.getElementById(id) : null;
            };

            const setPanelInteractive = (panel, interactive) => {
                if (!panel) return;
                panel.inert = !interactive;
            };

            const isFocusInside = (el) =>
                !!el &&
                !!document.activeElement &&
                el.contains(document.activeElement);

            const ensureFocusNotIn = (panel, fallbackEl) => {
                if (isFocusInside(panel)) fallbackEl?.focus?.();
            };

            const getTransitionMs = (el) => {
                const styles = getComputedStyle(el);

                const parseList = (value) =>
                    value
                        .split(",")
                        .map((part) => part.trim())
                        .map((part) =>
                            part.endsWith("ms")
                                ? parseFloat(part)
                                : parseFloat(part) * 1000,
                        )
                        .filter((n) => !Number.isNaN(n));

                const durations = parseList(styles.transitionDuration);
                const delays = parseList(styles.transitionDelay);

                const maxDuration = Math.max(0, ...durations, 0);
                const maxDelay = Math.max(0, ...delays, 0);

                return maxDuration + maxDelay + 50;
            };

            const ensurePixelHeight = (panel) => {
                const computed = getComputedStyle(panel).height;
                if (computed === "auto" || panel.style.height === "auto") {
                    panel.style.height = panel.scrollHeight + "px";
                    void panel.offsetHeight;
                }
            };

            const animatePanel = (btn, panel, expand) =>
                new Promise((resolve) => {
                    if (!btn || !panel) {
                        resolve();
                        return;
                    }

                    if (panel.dataset.animating === "1") {
                        resolve();
                        return;
                    }

                    if (!expand) ensureFocusNotIn(panel, btn);

                    if (expand) {
                        setPanelInteractive(panel, true);
                    }

                    btn.disabled = true;
                    panel.dataset.animating = "1";
                    panel.style.pointerEvents = "none";

                    btn.setAttribute(
                        "aria-expanded",
                        expand ? "true" : "false",
                    );
                    panel.setAttribute(
                        "data-state",
                        expand ? "open" : "closed",
                    );

                    ensurePixelHeight(panel);

                    const finish = () => {
                        delete panel.dataset.animating;
                        panel.style.pointerEvents = "";
                        btn.disabled = false;

                        if (expand) {
                            panel.style.height = "auto";
                        } else {
                            setPanelInteractive(panel, false);
                        }

                        resolve();
                    };

                    let done = false;
                    const complete = () => {
                        if (done) return;
                        done = true;
                        panel.removeEventListener("transitionend", onEnd);
                        clearTimeout(fallback);
                        finish();
                    };

                    const onEnd = (e) => {
                        if (e.target !== panel || e.propertyName !== "height")
                            return;
                        complete();
                    };

                    const fallback = setTimeout(
                        complete,
                        getTransitionMs(panel),
                    );

                    panel.addEventListener("transitionend", onEnd);

                    requestAnimationFrame(() => {
                        panel.style.height = expand
                            ? panel.scrollHeight + "px"
                            : "0px";
                    });
                });

            const getOpenDescendantButtonsDeepestFirst = (panel) => {
                const openButtons = Array.from(
                    panel.querySelectorAll(
                        '[data-accordion-toggle][aria-expanded="true"]',
                    ),
                );

                return openButtons.sort((a, b) => {
                    const depthA =
                        a.closest("[data-accordion-panel]")?.parentsLength ?? 0;
                    const depthB =
                        b.closest("[data-accordion-panel]")?.parentsLength ?? 0;
                    return depthB - depthA;
                });
            };

            // Slightly more reliable depth calculation than the placeholder above.
            const getDepth = (el) => {
                let depth = 0;
                let current = el.closest("[data-accordion-panel]");
                while (current) {
                    depth += 1;
                    current =
                        current.parentElement?.closest?.(
                            "[data-accordion-panel]",
                        ) ?? null;
                }
                return depth;
            };

            const closeDescendantsFirst = async (panel) => {
                const openButtons = Array.from(
                    panel.querySelectorAll(
                        '[data-accordion-toggle][aria-expanded="true"]',
                    ),
                ).sort((a, b) => getDepth(b) - getDepth(a));

                for (const openBtn of openButtons) {
                    const openPanel = getPanel(openBtn);
                    if (!openPanel) continue;
                    await animatePanel(openBtn, openPanel, false);
                }
            };

            const closeBranch = async (btn) => {
                const panel = getPanel(btn);
                if (!panel || !isExpanded(btn)) return;

                await closeDescendantsFirst(panel);
                await animatePanel(btn, panel, false);
            };

            const getRootButtons = () =>
                Array.from(
                    root.querySelectorAll(
                        '[data-accordion-toggle][data-accordion-level="root"]',
                    ),
                );

            root.addEventListener("click", async (event) => {
                const btn = event.target.closest?.("[data-accordion-toggle]");
                if (!btn || !root.contains(btn)) return;

                const panel = getPanel(btn);
                if (!panel) return;

                if (panel.dataset.animating === "1") return;

                const level = btn.getAttribute("data-accordion-level");
                const nextExpanded = !isExpanded(btn);

                if (level === "root") {
                    if (nextExpanded) {
                        for (const openRootBtn of getRootButtons()) {
                            if (openRootBtn === btn) continue;
                            if (!isExpanded(openRootBtn)) continue;
                            await closeBranch(openRootBtn);
                        }
                        await animatePanel(btn, panel, true);
                    } else {
                        await closeBranch(btn);
                    }

                    return;
                }

                // Nested toggles:
                // they can open/close independently,
                // but when their parent person closes, they will be closed first.
                await animatePanel(btn, panel, nextExpanded);
            });

            document.addEventListener("keydown", async (event) => {
                if (event.key !== "Escape") return;

                const openRootBtn = getRootButtons().find((btn) =>
                    isExpanded(btn),
                );
                if (!openRootBtn) return;

                await closeBranch(openRootBtn);
                openRootBtn.focus();
            });
        })();
    </script>
