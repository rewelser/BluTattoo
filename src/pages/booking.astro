---
import { getCollection, getEntry } from "astro:content";
import { Image } from "astro:assets";
import ParallaxWindow from "../components/decor/ParallaxWindow2-2.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
// import "../styles/global.css";
import { iconRegistry } from "../components/graphics/icons/registry";
import type { IconType } from "../scripts/contact-socials-platforms-defs";
import DesktopTopLogo from "../components/header/DesktopTopLogo.astro";
import branding from "../content/branding.json";
const site = await getEntry("siteInfo", "main");
import { defaults } from "../config/site";

import { loadArtistsActiveNonguest } from "../scripts/people";


let people = await loadArtistsActiveNonguest();

const sickleSvg = `
<svg id="Layer_1" data-name="Layer 1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1061.88 1009.9">
  <path fill="black" stroke="black" d="M286.59,485.79c-5.81-47.19-14.94-90.92-32.47-134.05-13.96-34.35-34.35-62.9-62.86-86.51l-54.76-45.33c-29.05-24.05-53.78-53.35-68.59-88.08-4.25-9.96-7.14-17.13-17.17-22.83-24.28-13.81-41.52-8.65-49.72-13.7-8.78-5.4,41.87-40.56,51.07-42.03,1.07-6.22,1.6-14.36,3.95-19.28,4.92-10.31,18.61-13.09,28.61-11.57l5.7,10.76c78.57-43.44,191.24-46.57,266.96,4.68,18.31,12.39,36.55,26.5,44.62,49.03-92.31-58.53-208.47-34.52-293.69,20.3,12.79,29.12,33.18,51.83,57.39,71.49,49.87,40.49,94.87,77.53,125.72,135.35,19.71,36.94,33.43,75.49,42.78,116.27,8.77,38.25-24.35,49.59-34.42,88.43-7.95-8.37-11.56-20.15-13.13-32.95ZM332.67,45.01c14.6,4.98,24.74,13.34,40.23,15.25-21.44-20.79-47.32-32.71-75.19-41.08C227.93-1.77,156.52,10.45,89.66,40.03c1.23,9.62,2.57,17.59,5.16,26.03,73.49-40.4,158.93-47.98,237.85-21.05ZM83.83,66.01l-4.04-35.2c-5.41.86-13.04,2.97-17.06,5.69-1.9,1.28-3.44,8.64-1.54,9.91l6.45,4.31c6.03,4.03,10.9,9.71,16.19,15.29ZM163.56,228.46c2.69,9.83,16.3,14.41,24.5,21.17,13.36-16.54-22.32-57.67-31.76-65.88-25.79-22.41-46.75-46.73-59.48-78.91-5.06-12.78-21.03-46.44-35.45-51.28-.25,7.55,0,15.75.99,21.29,18.72,4.5,29.03,38.71,34.46,55.53,13.57,41.99,55.25,55.99,59.94,73.18l6.8,24.89ZM57.32,102.77l-5.56-40.35c-14.87,8.23-26.9,16.32-38.62,27.16,17.58,1.94,30.05,5.53,44.18,13.19ZM130.92,183.47c-20.58-13.61-33.28-31.57-40.37-54.1-3.1-9.84-14.95-47.42-27.38-47.46,7.41,57.8,47.67,109.55,92.36,140.35.44-19.05-14.08-27.16-24.61-38.79ZM187.67,210.41c6.29,16.53,14.06,28.71,4.3,43.07,18.23,14.96,34.04,31.27,48.88,51.77,26.13-21.79-32.08-83.59-53.18-94.84ZM323.28,422.66l-5.35-19.36c-4.66,8.45-10.2,14.11-18.05,13.25-5.92-.65-12.69-8.08-13.75-15.2-3.87-25.95-9.57-49.93-18.69-74.56-4.25-11.49-3.84-22.04.82-33.37l-18.46-23.05c1.06,16.43,9.3,26.74-5.94,39.73,26.59,46.16,40.71,97.04,48.75,151.24,6.86-15.06,7.79-34.71,30.65-38.68ZM304.58,409.42c10.58-6,9.28-19.08,5.99-28-10.51-28.44-21.27-55.47-38.82-81.86-3.89,10.1-.98,20.1,2.57,29.47,8.74,23.1,13.78,45.66,17.3,69.94.82,5.68,6.55,14.08,12.97,10.45ZM322.37,460.86c5.95-8.85,6.56-19.71,1.83-28.29-20.61-8.47-30.06,48.17-25.33,63.27l23.5-34.97Z"/>
</svg>
`;

const sickleDataUrl = `data:image/svg+xml;charset=utf-8,${encodeURIComponent(sickleSvg)}`;
const siteName = site?.data?.siteName ?? defaults.siteName;
const logoDark = branding?.logoDark ?? defaults.siteLogo;
const defaultPersonProfilePicture = defaults.personProfilePicture;
const title = "Booking";
---

<!-- <html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Star Drift Test</title>
    </head> -->
<BaseLayout title={title} bodyClass="bg-black">
    <main class="page">
        <!-- <div id="wallpaper-gradient" class="wallpaper h-screen bg-gradient-to-b from-stone-500 to-stone-700" aria-hidden="true" /> -->
        <!-- <div class="wallpaper wallpaper-gradient h-screen bg-gradient-to-b from-neutral-300 to-stone-600 hidden md:block" aria-hidden="true"> -->
        <div
            class="wallpaper wallpaper-gradient h-screen hidden md:block"
            aria-hidden="true"
        >
        </div>
        <div
            class="wallpaper wallpaper-flash-animated hidden md:block"
            aria-hidden="true"
            style={`background-image: url(${sickleDataUrl})`}
        >
        </div>
        <!-- <div id="booking-content" class="relative bg-amber-400 bg-gradient-to-b from-stone-500 to-stone-700 md:rounded-4xl overflow-hidden md:mx-auto md:my-10 md:max-w-3xl"> -->
        <!-- <div id="booking-content" class="relative bg-gradient-to-b from-pink-200 to-violet-200 md:rounded-4xl overflow-hidden md:mx-auto md:my-10 md:max-w-3xl"> -->
        <!-- <div id="booking-content" class="relative bg-gradient-to-b from-sky-500 to-indigo-900 md:rounded-4xl overflow-hidden md:mx-auto md:my-10 md:max-w-3xl"> -->
        <!-- <div id="booking-content" class="relative bg-gradient-to-b from-rose-500 to-stone-700 md:rounded-4xl overflow-hidden md:mx-auto md:my-10 md:max-w-3xl"> -->
        <!-- <div id="booking-content" class="relative bg-gradient-to-b from-indigo-700 to-cyan-900 md:rounded-4xl overflow-hidden md:mx-auto md:my-10 md:max-w-3xl"> -->
        <!-- <div id="booking-content" class="relative bg-gradient-to-r from-teal-200 to-indigo-200 md:rounded-4xl overflow-hidden md:mx-auto md:my-10 md:max-w-3xl"> -->
        <!-- <div id="booking-content" class="relative bg-gradient-to-b from-amber-200 to-amber-500 md:rounded-4xl overflow-hidden md:mx-auto md:my-10 md:max-w-3xl"> -->
        <!-- <div id="booking-content" class="relative bg-gradient-to-b from-teal-200 to-teal-600 md:rounded-4xl overflow-hidden md:mx-auto md:my-10 md:max-w-3xl"> -->
        <div
            id="booking-content"
            class="relative bg-gradient-to-b from-[#04005c] to-[#193cb8] md:rounded-4xl overflow-hidden md:mx-auto md:my-10 md:max-w-3xl"
        >
            <div
                class="wallpaper wallpaper-flash-animated block md:hidden"
                aria-hidden="true"
                style={`background-image: url(${sickleDataUrl})`}
            >
            </div>
            <header
                id="booking-header"
                class="relative flex flex-col justify-center"
            >
                <div
                    id="header-img-container"
                    class="relative md:rounded-4xl overflow-hidden opacity-0"
                >
                    <img
                        class="backdrop-opacity-10"
                        src="/uploads/misc_images/teamstock.jpg"
                    />
                </div>

                <style>
                    #header-img-container {
                        /* mask: linear-gradient(to bottom, black, transparent); */
                        mask: linear-gradient(
                            to bottom,
                            black 0%,
                            black 85%,
                            transparent 100%
                        );
                        clip-path: shape(
                            from 0 0,
                            hline to 100%,
                            vline to 85%,
                            curve to 0 85% with 50% 100%,
                            close
                        );
                    }
                </style>
                <div class="relative w-full">
                    <!-- <DesktopTopLogo logo_dark={logo_dark} siteName={siteName} /> -->
                    <div
                        class="mx-auto px-4 py-6 md:py-8 flex items-center justify-center"
                    >
                        <!-- <a href="/" class="aspect-square rounded-full h-50 w-50 md:h-80 md:w-80 bg-[var(--brand-profile-bg-color)] overflow-hidden flex items-center justify-center p-5 -translate-y-1/2 border-2 border-(--brand-profile-border-color) shadow-[6px_4px_0px_var(--brand-profile-shadow-color)]"> -->
                        <a
                            id="brand-profile-pic"
                            href="/"
                            class="aspect-square rounded-full h-50 w-50 md:h-80 md:w-80 bg-[var(--brand-profile-bg-color)] overflow-hidden flex items-center justify-center p-5 -translate-y-1/2 border-2 border-(--brand-profile-border-color) shadow-[3px_3px_0px_1px_var(--brand-profile-shadow-color)]"
                        >
                            <img src={logoDark} alt={`${siteName} Homepage`} />
                        </a>
                    </div>
                </div>
            </header>
            <section
                class="px-4 pt-8 pb-16"
                aria-labelledby="people-tree-title"
            >
                <h1 id="people-tree-title" class="sr-only">People</h1>
                <ul class="m-0 list-none p-0" data-accordion-root>
                    {
                        people.map((person, personIndex) => {
                            const personBtnId = `person-${personIndex}-toggle`;
                            const personPanelId = `person-${personIndex}-panel`;
                            const csb = person.data.contactSocialsBooking;
                            const profilePicture =
                                csb?.bookingProfilePicture ??
                                defaultPersonProfilePicture;
                            const contacts = csb?.contact?.filter(
                                (item) => item.enabled,
                            );
                            const socials = csb?.socials?.filter(
                                (item) => item.enabled && item.bookable,
                            );
                            const platforms = csb?.platforms?.filter(
                                (item) => item.enabled,
                            );

                            const bookables = [
                                ...(contacts ?? []).map((item) => ({
                                    ...item,
                                    category: "contact" as const,
                                })),
                                ...(socials ?? []).map((item) => ({
                                    ...item,
                                    category: "social" as const,
                                })),
                                ...(platforms ?? []).flatMap((platform) =>
                                    (platform.linkOrModuleInfo ?? []).map(
                                        (entry) => ({
                                            ...entry,
                                            category: "platform" as const,
                                            preferred: platform.preferred,
                                            type: platform.type,
                                            platformEnabled: platform.enabled,
                                        }),
                                    ),
                                ),
                            ].sort(
                                (a, b) =>
                                    Number(b.preferred ?? false) -
                                    Number(a.preferred ?? false),
                            );

                            const hasBookables = (bookables?.length ?? 0) > 0;

                            return (
                                csb &&
                                hasBookables && (
                                    <li class="relative rounded-[50px] border-2 border-black bg-[floralwhite] shadow-[3px_4px_0px_black] overflow-hidden not-first:mt-3">
                                        <button
                                            id={personBtnId}
                                            class="flex min-h-12 w-full cursor-pointer items-center justify-between gap-4 border-0 bg-transparent p-2 text-left text-inherit"
                                            type="button"
                                            aria-expanded="false"
                                            aria-controls={personPanelId}
                                            data-accordion-toggle
                                            data-accordion-level="root"
                                        >
                                            {/* <div class="h-16 w-16 overflow-hidden rounded-[50px] border-2 border-(--profile-frame-border-color) shadow-[6px_4px_0px_var(--profile-frame-shadow-color)]"> */}
                                            <div class="h-16 w-16 overflow-hidden rounded-[50px] border-2 border-(--profile-frame-border-color) shadow-[3px_3px_0px_1px_var(--profile-frame-shadow-color)]">
                                                <img
                                                    src={profilePicture}
                                                    alt={`Booking profile image for ${person.data.name}`}
                                                    decoding="async"
                                                    loading="lazy"
                                                    class="h-full w-full object-cover"
                                                />
                                            </div>

                                            <span class="grid gap-[0.2rem] text-center">
                                                <span class="text-[1.05rem] font-bold leading-[1.2]">
                                                    {person.data.name}
                                                </span>
                                                <span class="text-[0.9rem] leading-[1.2] opacity-75">
                                                    {person.data.primaryRole}
                                                </span>
                                            </span>

                                            <svg
                                                viewBox="0 0 24 24"
                                                aria-hidden="true"
                                                class="h-4 w-4 shrink-0 transition-transform duration-200 ease-[ease]"
                                            >
                                                <path
                                                    fill="currentColor"
                                                    d="M7 10l5 5 5-5H7z"
                                                />
                                            </svg>
                                        </button>

                                        <div
                                            id={personPanelId}
                                            class="h-0 overflow-hidden transition-[height] duration-[260ms] ease-[ease] will-change-[height]"
                                            aria-labelledby={personBtnId}
                                            data-accordion-panel
                                            inert
                                        >
                                            <div class="p-4">
                                                {csb.bookingNote && (
                                                    <p class="mb-4 mt-0 leading-[1.55] opacity-[0.88]">
                                                        {csb.bookingNote}
                                                    </p>
                                                )}

                                                <ul class="m-0 grid list-none gap-2 p-0">
                                                    {bookables.map(
                                                        (item, index) => {
                                                            const typeKey =
                                                                item.type as IconType;
                                                            const entry =
                                                                iconRegistry[
                                                                    typeKey
                                                                ];
                                                            const { Icon } =
                                                                entry;

                                                            const hasNotes = (
                                                                item: any,
                                                            ): item is {
                                                                notes: string;
                                                            } => {
                                                                return (
                                                                    "notes" in
                                                                        item &&
                                                                    typeof item.notes ===
                                                                        "string"
                                                                );
                                                            };
                                                            const hasHref = (
                                                                item: any,
                                                            ): item is {
                                                                href: string;
                                                            } => {
                                                                return (
                                                                    "href" in
                                                                        item &&
                                                                    typeof item.href ===
                                                                        "string"
                                                                );
                                                            };

                                                            const resolvedHref =
                                                                hasHref(item)
                                                                    ? item.type ===
                                                                      "phone"
                                                                        ? `tel:${item.href}`
                                                                        : item.type ===
                                                                            "email"
                                                                          ? `mailto:${item.href}`
                                                                          : item.href
                                                                    : null;

                                                            const merchantId =
                                                                "merchantId" in
                                                                    item &&
                                                                item.merchantId;
                                                            const locationId =
                                                                "locationId" in
                                                                    item &&
                                                                item.locationId;

                                                            const isPreferred =
                                                                item.preferred;

                                                            const formatItem = (
                                                                item: any,
                                                            ) => {
                                                                if (
                                                                    item.category ===
                                                                    "contact"
                                                                )
                                                                    return item.href;

                                                                if (
                                                                    item.category ===
                                                                    "social"
                                                                ) {
                                                                    return item.handle
                                                                        ? `${item.handle} | ${item.type}`
                                                                        : item.type;
                                                                }

                                                                return item.type;
                                                            };

                                                            const subBtnId = `person-${personIndex}-sub-${index}-toggle`;
                                                            const subPanelId = `person-${personIndex}-sub-${index}-panel`;

                                                            return (
                                                                <div
                                                                    class={`${isPreferred ? "preferred" : "bookable"} relative`}
                                                                >
                                                                    <li
                                                                        class={`relative z-10 rounded-[50px] border-3 ${isPreferred ? "border-transparent" : "border-[#4DA3FF] shadow-[3px_4px_0px_#4DA3FF]"} bg-(--subitem-bookable-bg-color) not-first:mt-2`}
                                                                    >
                                                                        {hasHref(
                                                                            item,
                                                                        ) &&
                                                                        resolvedHref ? (
                                                                            <a
                                                                                class="font-semibold break-all"
                                                                                href={
                                                                                    resolvedHref
                                                                                }
                                                                                target={
                                                                                    item.href.startsWith(
                                                                                        "http",
                                                                                    )
                                                                                        ? "_blank"
                                                                                        : undefined
                                                                                }
                                                                                rel={
                                                                                    item.href.startsWith(
                                                                                        "http",
                                                                                    )
                                                                                        ? "noreferrer noopener"
                                                                                        : undefined
                                                                                }
                                                                            >
                                                                                <div class="grid grid-cols-[auto_1fr] gap-x-3 gap-y-1 px-4 py-[0.875rem]">
                                                                                    <div class="h-full content-center">
                                                                                        <div
                                                                                            aria-hidden="true"
                                                                                            class="flex h-10 w-10"
                                                                                        >
                                                                                            <Icon class="h-full w-full" />
                                                                                        </div>
                                                                                    </div>

                                                                                    <div class="grid gap-[0.35rem] text-center content-center pr-10">
                                                                                        {formatItem(
                                                                                            item,
                                                                                        )}
                                                                                        {hasNotes(
                                                                                            item,
                                                                                        ) && (
                                                                                            <div class="text-[0.95rem] leading-[1.5] opacity-80">
                                                                                                {
                                                                                                    item.notes
                                                                                                }
                                                                                            </div>
                                                                                        )}
                                                                                    </div>
                                                                                </div>
                                                                            </a>
                                                                        ) : (
                                                                            <>
                                                                                <button
                                                                                    id={
                                                                                        subBtnId
                                                                                    }
                                                                                    class="grid min-h-12 w-full grid-cols-[auto_1fr_auto] items-center gap-3 border-0 bg-transparent px-4 py-[0.875rem] text-left text-inherit"
                                                                                    type="button"
                                                                                    aria-expanded="false"
                                                                                    aria-controls={
                                                                                        subPanelId
                                                                                    }
                                                                                    data-accordion-toggle
                                                                                    data-accordion-level="nested"
                                                                                >
                                                                                    <div class="h-full content-center">
                                                                                        <div
                                                                                            aria-hidden="true"
                                                                                            class="flex h-10 w-10"
                                                                                        >
                                                                                            <Icon class="h-full w-full" />
                                                                                        </div>
                                                                                    </div>

                                                                                    <div class="grid gap-[0.35rem] text-center content-center font-semibold break-all">
                                                                                        {
                                                                                            item.type
                                                                                        }
                                                                                    </div>

                                                                                    <svg
                                                                                        viewBox="0 0 24 24"
                                                                                        aria-hidden="true"
                                                                                        class="h-4 w-4 shrink-0 transition-transform duration-200 ease-[ease]"
                                                                                    >
                                                                                        <path
                                                                                            fill="currentColor"
                                                                                            d="M7 10l5 5 5-5H7z"
                                                                                        />
                                                                                    </svg>
                                                                                </button>

                                                                                <div
                                                                                    id={
                                                                                        subPanelId
                                                                                    }
                                                                                    class="h-0 overflow-hidden transition-[height] duration-[260ms] ease-[ease] will-change-[height]"
                                                                                    aria-labelledby={
                                                                                        subBtnId
                                                                                    }
                                                                                    data-accordion-panel
                                                                                    inert
                                                                                >
                                                                                    <div class="border-t border-white/10 px-4 pt-[0.875rem] pb-4">
                                                                                        <div class="grid min-h-32 place-items-center border border-dashed border-white/20 p-4 text-center opacity-75">
                                                                                            Square
                                                                                            module
                                                                                            placeholder
                                                                                            <br />
                                                                                            merchantId:{" "}
                                                                                            {
                                                                                                merchantId
                                                                                            }
                                                                                            <br />
                                                                                            locationId:{" "}
                                                                                            {
                                                                                                locationId
                                                                                            }
                                                                                        </div>
                                                                                    </div>
                                                                                </div>
                                                                            </>
                                                                        )}
                                                                    </li>
                                                                    {isPreferred && (
                                                                        <>
                                                                            <div class="preferred-ping absolute top-[1.5px] left-[2px] h-full w-full bg-[#ffd230] rounded-[9999px] animate-ping-faint" />
                                                                            <div class="preferred-shadow absolute top-[3px] left-[4px] w-full h-full rounded-[100px]" />
                                                                        </>
                                                                    )}
                                                                </div>
                                                            );
                                                        },
                                                    )}
                                                </ul>
                                            </div>
                                        </div>
                                    </li>
                                )
                            );
                        })
                    }
                </ul>
            </section>
        </div>
    </main>
    <!-- </html> -->
    <script is:inline>
        window.addEventListener("scroll", function () {
            const scrollPosition = window.scrollY;
            // const scrollHeight = document.body.offsetHeight - document.documentElement.clientHeight;
            const bookingContent = document.getElementById("booking-content");
            const scrollHeightHeaderImg = bookingContent.clientHeight;
            const wallaperFlashAnimated = document.querySelector(
                ".wallpaper-flash-animated",
            );
            const headerImgContainer = document.querySelector(
                "#header-img-container",
            );
            const headerImg = document.querySelector(
                "#header-img-container img",
            );

            const bookingContentRectTop =
                bookingContent.getBoundingClientRect().top;
            const scrollPositionHeaderImg = Math.abs(
                Math.min(0, bookingContentRectTop),
            );
            const headerImgProgress =
                scrollPositionHeaderImg / scrollHeightHeaderImg;

            wallaperFlashAnimated.style.transform = `translateY(${scrollPosition * 0.5}px)`;

            headerImgContainer.style.transform = `translateY(${scrollPositionHeaderImg * 0.5}px)`;
            // headerImg.style.transform = `scale(${1 + headerImgProgress * 0.1})`;
            headerImg.style.transform = `scale(${1 + headerImgProgress * 0.9})`; // why did I originally go with .1?? .9 is so much better, desktop & mobile
            headerImg.style.opacity = `${1 - headerImgProgress * 3}`;
            // headerImg.style.opacity = `${1 - headerImgProgress * }`;
        });
    </script>
    <style>
        [data-accordion-toggle][aria-expanded="true"] > svg {
            transform: rotate(180deg);
        }

        @media (prefers-reduced-motion: reduce) {
            [data-accordion-panel],
            [data-accordion-toggle] > svg {
                transition: none;
            }
        }

        /*** ----------------------- ***/
        /*** pill shimmers & pulses  ***/
        /*** ----------------------- ***/

        @property --glow-deg {
            syntax: "<angle>";
            inherits: true;
            initial-value: 0deg;
        }

        @keyframes glow {
            100% {
                --glow-deg: 360deg;
            }
        }

        :root {
            /* --preferred-gradient: #ffea9f, #ffd230, #ffd230, #ffc800, #ffc800, #ffd230, #ffd230, #ffea9f; */
            background-color: antiquewhite;
            background-color: bisque;
            background-color: blanchedalmond;
            background-color: tan;
            background-color: seashell;
            background-color: snow;
            background-color: whitesmoke;
            background-color: ivory;
            background-color: ghostwhite;
            background-color: oldlace;
            --test-brand-profile-bg-color: #ffd230;
            --test-brand-profile-border-color: #dfac04;
            --test-brand-profile-shadow-color: #c8a01b;
            --brand-profile-bg-color: floralwhite;
            --brand-profile-border-color: lightgray;
            --brand-profile-shadow-color: gainsboro;
            --preferred-gradient:
                #fff4ce, #ffd230, #ffd230, #ffc800, #ffc800, #ffd230, #ffd230,
                #fff4ce;
            --preferred-gradient:
