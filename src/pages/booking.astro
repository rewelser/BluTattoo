const sickleDataUrl = `data:image/svg+xml;charset=utf-8,${encodeURIComponent(flashSvg)}`;
const siteName = site?.data?.siteName ?? defaults.siteName;
const logoDark = branding?.logoDark ?? defaults.siteLogo;
const bookingHeroPhoto = branding?.hero.bookingHeroPhoto ?? defaults.bookingHeroPhoto;
const defaultPersonProfilePicture = defaults.personProfilePicture;
const siteSocials = site && siteInfoSocialsToItems(site.data.socials);
const title = "Booking";
---

<!-- <html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Star Drift Test</title>
    </head> -->
<BaseLayout title={title} bodyClass="bg-black">
    <Fragment slot="head">
        <meta name="description" content="Short description here" />

        <meta property="og:title" content="Your Title" />
        <meta property="og:description" content="Short description here" />
        <meta property="og:url" content="https://example.com/page" />
        <meta property="og:type" content="website" />
        <meta property="og:image" content={`${Astro.url.origin}${logoDark}`} />

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content="Your Title" />
        <meta name="twitter:description" content="Short description here" />
        <meta name="twitter:image" content={logoDark} />
    </Fragment>
    <main class="page">
        <!-- <div id="wallpaper-gradient" class="wallpaper h-screen bg-gradient-to-b from-stone-500 to-stone-700" aria-hidden="true" /> -->
        <!-- <div class="wallpaper wallpaper-gradient h-screen bg-gradient-to-b from-neutral-300 to-stone-600 hidden md:block" aria-hidden="true"> -->
        <div
                class="wallpaper wallpaper-gradient h-screen hidden md:block"
                aria-hidden="true"
        >
        </div>
        <div
                class="wallpaper wallpaper-flash-animated hidden md:block"
                aria-hidden="true"
                style={`background-image: url(${sickleDataUrl})`}
        >
        </div>
        <!--<div id="booking-content" class="relative bg-amber-400 bg-gradient-to-b from-stone-500 to-stone-700 md:rounded-4xl overflow-hidden md:mx-auto md:my-10 md:max-w-3xl">-->
        <!-- <div id="booking-content" class="relative bg-gradient-to-b from-pink-200 to-violet-200 md:rounded-4xl overflow-hidden md:mx-auto md:my-10 md:max-w-3xl">-->
        <!-- <div id="booking-content" class="relative bg-gradient-to-b from-sky-500 to-indigo-900 md:rounded-4xl overflow-hidden md:mx-auto md:my-10 md:max-w-3xl">-->
        <!-- <div id="booking-content" class="relative bg-gradient-to-b from-rose-500 to-stone-700 md:rounded-4xl overflow-hidden md:mx-auto md:my-10 md:max-w-3xl">-->
        <!-- <div id="booking-content" class="relative bg-gradient-to-b from-indigo-700 to-cyan-900 md:rounded-4xl overflow-hidden md:mx-auto md:my-10 md:max-w-3xl">-->
        <!-- <div id="booking-content" class="relative bg-gradient-to-r from-teal-200 to-indigo-200 md:rounded-4xl overflow-hidden md:mx-auto md:my-10 md:max-w-3xl">-->
        <!-- <div id="booking-content" class="relative bg-gradient-to-b from-amber-200 to-amber-500 md:rounded-4xl overflow-hidden md:mx-auto md:my-10 md:max-w-3xl">-->
        <!-- <div id="booking-content" class="relative bg-gradient-to-b from-teal-200 to-teal-600 md:rounded-4xl overflow-hidden md:mx-auto md:my-10 md:max-w-3xl">-->
        <!--<div id="booking-content" class="relative bg-gradient-to-b from-[#04005c] to-[#193cb8] md:rounded-4xl overflow-hidden md:mx-auto md:my-10 md:max-w-3xl">-->
        <div id="booking-content"
             class="relative bg-gradient-to-b from-[#04005c] via-[#193cb8] to-[#3F1782] md:rounded-4xl overflow-hidden md:mx-auto md:my-10 md:max-w-3xl">
            <div
                    class="wallpaper wallpaper-flash-animated block md:hidden"
                    aria-hidden="true"
                    style={`background-image: url(${sickleDataUrl})`}
            >
            </div>
            <header
                    id="booking-header"
                    class="relative flex flex-col justify-center"
            >
                <div id="header-img-container">
                    <div
                            id="header-img-translator"
                            class="relative md:rounded-4xl overflow-hidden"
                    >
                        <img
                                class="backdrop-opacity-10 object-cover"
                                src={bookingHeroPhoto}
                                loading="eager"
                                decoding="async"
                                fetchpriority="high"
                                alt=""
                        />
                    </div>
                </div>

                <style>
                    #header-img-container {
                        aspect-ratio: 16 / 11;
                        width: 100%;
                    }

                    #header-img-translator {
                        /* mask: linear-gradient(to bottom, black, transparent); */
                        mask: linear-gradient(
                                to bottom,
                                black 0%,
                                black 85%,
                                transparent 100%
                        );
                        clip-path: shape(
                                from 0 0,
                                hline to 100%,
                                vline to 85%,
                                curve to 0 85% with 50% 100%,
                                close
                        );
                    }

                    #header-img-container img {
                        aspect-ratio: 16 / 11;
                        object-fit: cover;
                        object-position: center top;
                    }
                </style>
                <div id="booking-header-activity">
                    <!-- <DesktopTopLogo logo_dark={logo_dark} siteName={siteName} /> -->
                    <div
                            class="mx-auto px-4 py-6 md:py-8 flex flex-col items-center justify-center"
                    >
                        <!-- <a href="/" class="aspect-square rounded-full h-50 w-50 md:h-80 md:w-80 bg-[var(--brand-profile-bg-color)] overflow-hidden flex items-center justify-center p-5 -translate-y-1/2 border-2 border-(--brand-profile-border-color) shadow-[6px_4px_0px_var(--brand-profile-shadow-color)]"> -->
                        <a
                                id="brand-profile-pic"
                                href="/"
                                class="aspect-square rounded-full h-50 w-50 md:h-80 md:w-80 bg-[var(--brand-profile-bg-color)] overflow-hidden flex items-center justify-center p-5 border-2 border-(--brand-profile-border-color) shadow-[3px_3px_0px_1px_var(--brand-profile-shadow-color)]"
                        >
                            <img src={logoDark} alt={`${siteName} Homepage`}/>
                        </a>
                        <ShareModal siteName={siteName} logo={logoDark}/>
                        <SocialRow links={siteSocials} variant="thin" class="text-white" iconClass="h-8 w-8"/>
                        <div class="overflow-hidden overflow-x-auto">
                            <div class="flex flex-nowrap">
                                <a></a>
                            </div>
                        </div>

                    </div>
                </div>
                <style>
                    #booking-header-activity {
                        position: relative;
                        width: 100%;
                        transform: translateY(calc(var(--spacing) * -30));
                        margin-bottom: calc(var(--spacing) * -30);
                    }

                    @media (min-width: 768px) {
                        #booking-header-activity {
                            transform: translateY(calc(var(--spacing) * -40));
                            margin-bottom: calc(var(--spacing) * -40);
                        }
                    }
                </style>
            </header>
            <section
                    class="px-4 pt-8 pb-16"
                    aria-labelledby="people-tree-title"
            >
                <h1 id="people-tree-title" class="sr-only">{title}</h1>
                <ul class="m-0 list-none p-0" data-accordion-root>
                    {
                        people.map((person, personIndex) => {
                            const personBtnId = `person-${person.id}-toggle`;
                            const personPanelId = `person-${person.id}-panel`;
                            const personHeadingId = `person-${person.id}-heading`;
                            const csb = person.data.contactSocialsBooking;
                            const profilePicture =
                                csb?.bookingProfilePicture ??
                                defaultPersonProfilePicture;
                            const contacts = csb?.contact?.filter(
                                (item) => item.enabled,
                            );
                            const socials = csb?.socials?.filter(
                                (item) => item.enabled && item.bookable,
                            );
                            const platforms = csb?.platforms?.filter(
                                (item) => item.enabled,
                            );

                            const nonbookableSocials = csb?.socials?.filter(
                                (item) => item.enabled && !item.bookable
                            );

                            const hasNonbookableSocials = nonbookableSocials && nonbookableSocials.length > 0;

                            const bookables = [
                                ...(contacts ?? []).map((item) => ({
                                    ...item,
                                    category: "contact" as const,
                                })),
                                ...(socials ?? []).map((item) => ({
                                    ...item,
                                    category: "social" as const,
                                })),
                                ...(platforms ?? []).flatMap((platform) =>
                                    (platform.linkOrModuleInfo ?? []).map(
                                        (entry) => ({
                                            ...entry,
                                            category: "platform" as const,
                                            preferred: platform.preferred,
                                            type: platform.type,
                                            platformEnabled: platform.enabled,
                                        }),
                                    ),
                                ),
                            ].sort(
                                (a, b) =>
                                    Number(b.preferred ?? false) -
                                    Number(a.preferred ?? false),
                            );

                            const hasBookables = (bookables?.length ?? 0) > 0;

                            const isGuest = person.variant === "guest" && person.event && person.hrefId;

                            return (
                                csb &&
                                hasBookables && (
                                        <li class={`person-bookable-card-li ${isGuest ? "guest" : ""}`}>
                                            {isGuest && (
                                                    <div class="absolute rounded-4xl bg-white border-2 border-gray-300 -translate-y-[50%] translate-x-16 py-1 px-2 break-words font-[Spectral]">
                                                        Guest {person.data.primaryRole.replaceAll("Tattoo ", "")}
                                                        &#10209 {fmtDateRange(person.event)}</div>
                                                    <SparkleCorners fillColor="gold"/>
                                            )}
                                            <section aria-labelledby={personHeadingId}>
                                                <h2 id={personHeadingId} class="sr-only">
                                                    {person.data.name}
                                                </h2>
                                                <button
                                                        id={personBtnId}
                                                        class="flex min-h-12 w-full cursor-pointer items-center justify-between gap-4 border-0 bg-transparent p-2 text-left text-inherit"
                                                        type="button"
                                                        aria-expanded="false"
                                                        aria-controls={personPanelId}
                                                        data-accordion-toggle
                                                        data-accordion-level="root"
                                                >
                                                    {/* <div class="h-16 w-16 overflow-hidden rounded-[50px] border-2 border-(--profile-frame-border-color) shadow-[6px_4px_0px_var(--profile-frame-shadow-color)]"> */}
                                                    <div class="profile-picture">
                                                        <img
                                                                src={csb.bookingProfilePicture?.src ?? defaultPersonProfilePicture}
                                                                alt={`Booking profile image for ${person.data.name}`}
                                                                decoding="async"
                                                                loading="lazy"
                                                                class="h-full w-full object-cover"
                                                        />
                                                    </div>

                                                    <span class="grid gap-[0.2rem] text-center pr-12">
                                                        <span class="text-[1.05rem] font-bold leading-[1.2]">
                                                            {person.data.name}
                                                        </span>
                                                        <span class="text-[0.9rem] leading-[1.2] opacity-75">
                                                            {person.data.primaryRole}
                                                        </span>
                                                    </span>

                                                    <svg
                                                            viewBox="0 0 24 24"
                                                            aria-hidden="true"
                                                            class="h-4 w-4 shrink-0 transition-transform duration-200 ease-[ease]"
                                                    >
                                                        <path
                                                                fill="currentColor"
                                                                d="M7 10l5 5 5-5H7z"
                                                        />
                                                    </svg>
                                                </button>

                                                <div
                                                        id={personPanelId}
