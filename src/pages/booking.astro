---
import {getCollection, getEntry} from "astro:content";
import {Image} from "astro:assets";
import ParallaxWindow from "../components/decor/ParallaxWindow2-2.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
// import "../styles/global.css";
import {iconRegistry, getIconEntry} from "../components/graphics/icons/registry";
import DesktopTopLogo from "../components/header/DesktopTopLogo.astro";
import branding from "../content/branding.json";
const site = await getEntry("siteInfo", "main");
import {defaults} from "../config/site";

import {loadActiveArtists} from "../domain/people/server.ts";
import type {IconType} from "../domain/contact/types.ts";
import SquareAppointments from "../components/SquareAppointments.astro";
import SquareAppointmentsIsland from "../components/SquareAppointmentsIsland.tsx";
import SlottableModal from "../components/SlottableModal.astro";
import SocialRow from "../components/SocialRow.astro";
import {loadUpcomingGuestSpotCandidates} from "../domain/events/selectors.ts";
import {fmtDateRange} from "../domain/events/format.ts";
import SparkleCorners from "../components/decor/SparkleCorners.astro";
import {siteInfoSocialsToItems} from "../domain/contact/adapters.ts";
import ShareRow from "../components/ShareRow.astro";
import ShareModal from "../components/ShareModal.astro";
import ScrollXContainer from "../components/scaffolding/ScrollXContainer.astro";

let residentPeople = await loadActiveArtists();
const guestSpotEvents = await loadUpcomingGuestSpotCandidates(new Date());
const seen = new Set<string>();

const people = [
    ...guestSpotEvents
        .filter((ev) => {
            if (seen.has(ev.guestSpot.guestName)) {
                return false;
            }
            seen.add(ev.guestSpot.guestName);
            return true;
        }).map((guest) => {
            return {
                event: guest,
                id: `guest-${guest.id.replaceAll("/", "-")}`,
                hrefId: guest.id,
                data: {
                    name: guest.guestSpot.guestName,
                    ...guest.guestSpot,
                    startDate: guest.startDate,
                    endDate: guest.endDate,
                },
                variant: "guest",
            }
        }),
    ...residentPeople.map((person) => {
        return {
            event: undefined,
            id: person.id,
            data: person.data,
            variant: "resident"
        }
    })
];


