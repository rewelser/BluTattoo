---
import {getEntry} from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import {getIconEntry} from "../components/graphics/icons/registry";
import {defaults} from "../config/site";
import {loadActiveArtists, loadActivePiercers} from "../domain/people/server.ts";
import type {IconType} from "../domain/contact/types.ts";
import SquareAppointmentsIsland from "../components/SquareAppointmentsIsland.tsx";
import SlottableModal from "../components/SlottableModal.astro";
import SocialRow from "../components/SocialRow.astro";
import {loadUpcomingGuestSpotCandidates} from "../domain/events/selectors.ts";
import {fmtDateRange} from "../domain/events/format.ts";
import SparkleCorners from "../components/decor/SparkleCorners.astro";
import {siteInfoSocialsToItems} from "../domain/contact/adapters.ts";
import ShareModal from "../components/ShareModal.astro";
import {getImageSrc} from "../domain/decor/selectors.ts";
import {getBookables} from "../domain/contact/utlis.ts";
import {Image} from "astro:assets";

const branding = await getEntry("branding", "main");
const site = await getEntry("siteInfo", "main");

const residentPeople = (
    await Promise.all([
        loadActiveArtists(),
        loadActivePiercers()
    ])
).flat();

const guestSpotEvents = await loadUpcomingGuestSpotCandidates(new Date());
const seen = new Set<string>();

const people = [
    ...guestSpotEvents
        .filter((ev) => {
            if (seen.has(ev.guestSpot.guestName)) {
                return false;
            }
            seen.add(ev.guestSpot.guestName);
            return true;
        }).map((guest) => {
            return {
                event: guest,
                id: `guest-${guest.id.replaceAll("/", "-")}`,
                hrefId: guest.id,
                data: {
                    name: guest.guestSpot.guestName,
                    ...guest.guestSpot,
                    startDate: guest.startDate,
                    endDate: guest.endDate,
                    ogPhotoTextless: guest.ogPhotoTextless,
                    ogPhotoTexted: guest.ogPhotoTexted,
                    eventImage: guest.image,
                },
                variant: "guest",
            }
        }),
    ...residentPeople.map((person) => {
        return {
            event: undefined,
            id: person.id,
            data: {
                ...person.data,
                eventImage: undefined,
            },
            variant: "resident",
        }
    })
];

const siteName = site?.data?.siteName ?? defaults.siteName;
const logoDark = branding?.data.logoDark ?? defaults.siteLogo;
const logoDarkBold = branding?.data.logoDarkBold ?? defaults.siteLogo;
const artistPageShopLogo = branding?.data.logoDarkBold ?? logoDark;
const bookingHeroPhoto = branding?.data.hero?.bookingHeroPhoto ?? defaults.bookingHeroPhoto;
const bookingShareOGPhoto = getImageSrc(branding?.data.bookingShareOGPhoto ?? defaults.ogPhoto);
const bookingFlashLight = branding?.data.bookingFlashLight;
const bookingFlashDark = branding?.data.bookingFlashDark;
const defaultPersonProfilePicture = defaults.personProfilePicture;
const siteSocials = site && siteInfoSocialsToItems(site.data.socials);
const title = "Booking";
const description = "Book a tattoo or piercing appointment at BluTattoo, view available artists & piercers, and find the right next step for your tattoo idea.";
---
<BaseLayout title={title} description={description} ogImage={bookingShareOGPhoto} preloadImage={bookingHeroPhoto.src}
            bodyClass="bg-black">
    <main class="page">
        <div
                class="wallpaper wallpaper-gradient h-screen hidden md:block"
                aria-hidden="true"
        >
        </div>
        {
            bookingFlashDark && (
                        <div
                                class="wallpaper wallpaper-flash-animated hidden md:block"
                                aria-hidden="true"
                                style={`background-image: url(${bookingFlashDark.src})`}
                        >
                        </div>
            )
        }

        <div id="booking-content"
             class="relative bg-gradient-to-b from-[#04005c] via-[#193cb8] to-[#3F1782] md:rounded-4xl overflow-hidden md:mx-auto md:my-10 md:max-w-3xl">
            {
                bookingFlashLight && (
                            <div
                                    class="wallpaper wallpaper-flash-animated block md:hidden"
                                    aria-hidden="true"
                                    style={`background-image: url(${bookingFlashLight.src})`}
                            >
                            </div>
                )
            }
            <header
                    id="booking-header"
                    class="relative flex flex-col justify-center"
            >
                <div id="header-img-container">
                    <div
                            id="header-img-translator"
                            class="relative md:rounded-4xl overflow-hidden"
                    >
                        <Image
                                class="backdrop-opacity-10 object-cover"
                                src={bookingHeroPhoto}
                                loading="eager"
                                decoding="sync"
                                fetchpriority="high"
                                alt=""
                        />
                    </div>
                </div>

                <div id="booking-header-activity">
                    <div
                            class="mx-auto px-4 py-6 md:py-8 flex flex-col items-center justify-center"
                    >
                        <a
                                id="brand-profile-pic"
                                href="/"
                                class="aspect-square rounded-full h-50 w-50 md:h-80 md:w-80 bg-[var(--brand-profile-bg-color)] overflow-hidden flex items-center justify-center p-5 border-2 border-(--brand-profile-border-color) shadow-[3px_3px_0px_1px_var(--brand-profile-shadow-color)]"
                        >
                            <Image
                                    src={logoDark}
                                    alt={`${siteName} Homepage`}
                                    widths={[300, 500]}
                                    sizes="250px"
                                    loading="eager"
                                    decoding="sync"
                                    fetchpriority="high"
                            />
                        </a>
                        <ShareModal shareTitle={siteName} shareHero={logoDark}/>
                        <SocialRow links={siteSocials} variant="thin" class="text-white" iconClass="h-8 w-8"/>
                    </div>
                </div>
            </header>
            <section
                    class="px-4 pt-8 pb-16"
                    aria-labelledby="people-tree-title"
            >
                <h1 id="people-tree-title" class="sr-only">{title}</h1>
                <ul class="m-0 list-none p-0" data-accordion-root>
                    {
                        people.map((person, personIndex) => {
                            const personBtnId = `person-${person.id}-toggle`;
                            const personPanelId = `person-${person.id}-panel`;
                            const personHeadingId = `person-${person.id}-heading`;
                            const csb = person.data.contactSocialsBooking;
                            const contacts = csb?.contact?.filter(
                                (item) => item.enabled,
                            );
                            const socials = csb?.socials?.filter(
                                (item) => item.enabled && item.bookable,
                            );
                            const platforms = csb?.platforms?.filter(
                                (item) => item.enabled,
                            );

                            const nonbookableSocials = csb?.socials?.filter(
                                (item) => item.enabled && !item.bookable
                            );

                            const hasNonbookableSocials = nonbookableSocials && nonbookableSocials.length > 0;

                            const bookables = getBookables(csb);

                            const hasBookables = (bookables?.length ?? 0) > 0;

                            const isGuest = person.variant === "guest" && person.event && person.hrefId;

                            const ogImage = person.data.ogPhotoTextless ?? person.data.ogPhotoTexted ?? person.data.eventImage ?? branding?.data.sitewideOGPhoto ?? defaults.ogPhoto;
                            const ogImageSrc = getImageSrc(ogImage);

                            return (
                                csb &&
                                hasBookables && (
                                        <li class={`person-bookable-card-li ${isGuest ? "guest" : ""}`}>
                                            {isGuest && (
                                                    <div class="absolute rounded-4xl bg-white border-2 border-gray-300 -translate-y-[50%] translate-x-16 py-1 px-2 break-words font-[Spectral]">
                                                        Guest {person.data.primaryRole.replaceAll("Tattoo ", "")}
                                                        &#10209 {fmtDateRange(person.event)}</div>
                                                    <SparkleCorners fillColor="gold"/>
                                            )}
                                            <section aria-labelledby={personHeadingId}>
                                                <h2 id={personHeadingId} class="sr-only">
                                                    {person.data.name}
                                                </h2>
                                                <button
                                                        id={personBtnId}
                                                        class="flex min-h-12 w-full cursor-pointer items-center justify-between gap-4 border-0 bg-transparent p-2 text-left text-inherit"
                                                        type="button"
                                                        aria-expanded="false"
                                                        aria-controls={personPanelId}
                                                        data-accordion-toggle
                                                        data-accordion-level="root"
                                                >
                                                    <span class="profile-picture">
                                                        <Image
                                                                src={csb.bookingProfilePicture ?? defaultPersonProfilePicture}
                                                                alt={`Booking profile image for ${person.data.name}`}
                                                                width="120"
                                                                loading="lazy"
                                                                decoding="async"
                                                                class="h-full w-full object-cover"
                                                        />
                                                    </span>

                                                    <span class="grid gap-[0.2rem] text-center pr-12">
                                                        <span class="text-[1.05rem] font-bold leading-[1.2]">
                                                            {person.data.name}
                                                        </span>
                                                        <span class="text-[0.9rem] leading-[1.2] opacity-75">
                                                            {person.data.primaryRole}
                                                        </span>
                                                    </span>

                                                    <svg
                                                            viewBox="0 0 24 24"
                                                            aria-hidden="true"
                                                            class="h-4 w-4 shrink-0 transition-transform duration-200 ease-[ease]"
                                                    >
                                                        <path
                                                                fill="currentColor"
                                                                d="M7 10l5 5 5-5H7z"
                                                        />
                                                    </svg>
                                                </button>

                                                <div
                                                        id={personPanelId}
                                                        class="h-0 overflow-hidden transition-[height] duration-[260ms] ease-[ease] will-change-[height]"
                                                        aria-labelledby={personBtnId}
                                                        data-accordion-panel
                                                        inert
                                                >
                                                    <div>
                                                        <section class="p-4 mb-7 booking-section list-section"
                                                                 aria-labelledby={`${personHeadingId}-booking-section`}>
                                                            <div class="list-section-text">
                                                                <h3 id={`${personHeadingId}-booking-section`}
                                                                    class="text-base tracking-wide text-neutral-700">
                                                                    Book Below{!csb.bookingNote && ":"}
                                                                </h3>
                                                                {csb.bookingNote && (
                                                                        <p class="text-sm leading-relaxed text-neutral-700/80">
                                                                            {csb.bookingNote}
                                                                        </p>
                                                                )}
                                                            </div>
                                                            <ul class="m-0 grid list-none gap-2">
                                                                {bookables.map(
                                                                    (item, index) => {
                                                                        const typeKey = item.type as IconType;

                                                                        const entry = getIconEntry(typeKey, ["roundColor", "round", "thick"]);
                                                                        const Icon = entry?.Icon;

                                                                        const hasNotes = (item: any): item is {
                                                                            notes: string;
                                                                        } => {
                                                                            return ("notes" in item && typeof item.notes === "string");
                                                                        };
                                                                        const hasHref = (item: any): item is {
                                                                            href: string;
                                                                            type: string;
                                                                        } => {
                                                                            return ("href" in item && typeof item.href === "string");
                                                                        };

                                                                        const isTextPreferred = item.type === "phone" && item.callOrTextPreferred === "text";

                                                                        const resolvedHref =
                                                                            hasHref(item)
                                                                                ? item.type ===
                                                                                "phone"
                                                                                    ? `tel:${item.href}`
                                                                                    : item.type ===
                                                                                    "email"
                                                                                        ? `mailto:${item.href}`
                                                                                        : item.href
                                                                                : null;

                                                                        const getResolveHref = (item: any) => {
                                                                            if (item.type === "phone") {
                                                                                if (isTextPreferred) {
                                                                                    const message = item.textMessageDefaultInquiry?.trim();

                                                                                    return message
                                                                                        ? `sms:${item.href}?&body=${encodeURIComponent(message)}`
                                                                                        : `sms:${item.href}`;
                                                                                }

                                                                                return `tel:${item.href}`;
                                                                            }

                                                                            if (item.type === "email") {
                                                                                /**
                                                                                * In a future update, either abstract up textMessageDefaultInquiry, or config a dedicated email subject/body field:
                                                                                * const href = `mailto:${email}?subject=${encodeURIComponent(item.emailSubject)}&body=${encodeURIComponent(item.emailBody)}`;
                                                                                */
                                                                                return `mailto:${item.href}?subject=${encodeURIComponent("Booking inquiry")}`;
                                                                            }

                                                                            return item.href;
                                                                        }

                                                                        const merchantId = "merchantId" in item && item.merchantId;
                                                                        const locationId = "locationId" in item && item.locationId;

                                                                        const isPreferred = item.preferred;

                                                                        const formatItem = (item: any) => {
                                                                            if (item.category === "contact") {
                                                                                if (item.type === "phone") {
                                                                                    if (isTextPreferred) {
                                                                                        return `text: ${item.href}`;
                                                                                    } else {
                                                                                        return `call: ${item.href}`;
                                                                                    }
                                                                                }
                                                                                return item.href;

                                                                            }
                                                                            if (item.category === "social") {
                                                                                return item.handle
                                                                                    ? `${item.handle} | ${item.type}`
                                                                                    : item.type;
                                                                            }

                                                                            return item.type;
                                                                        };

                                                                        const subBtnId = `person-${person.id}-sub-${index}-toggle`;
                                                                        const subPanelId = `person-${person.id}-sub-${index}-panel`;

                                                                        return (
                                                                                <li class="link-card-li">
                                                                                    {hasHref(item) ? (
                                                                                            <>
                                                                                                <div class={`link-card ${isPreferred ? "preferred" : "bookable"} not-first:mt-2`}>
                                                                                                    <a
                                                                                                            class="font-semibold break-words"
                                                                                                            href={getResolveHref(item)}
                                                                                                            target={item.href.startsWith("http") ? "_blank" : undefined}
                                                                                                            rel={item.href.startsWith("http") ? "noreferrer noopener" : undefined}
                                                                                                    >
                                                                                                        <div class="grid grid-cols-[auto_1fr] gap-x-3 gap-y-1 px-4 py-[0.875rem]">
                                                                                                            <div class="h-full content-center">
                                                                                                                <div
                                                                                                                        aria-hidden="true"
                                                                                                                        class="flex h-10 w-10"
                                                                                                                >
                                                                                                                    {Icon &&
                                                                                                                            <Icon class="h-full w-full"/>}
                                                                                                                </div>
                                                                                                            </div>

                                                                                                            <div class="grid gap-[0.35rem] text-center content-center pr-10">
                                                                                                                {formatItem(item)}
                                                                                                                {hasNotes(item) && (
                                                                                                                        <div class="text-[0.95rem] leading-[1.5] opacity-80">
                                                                                                                            {item.notes}
                                                                                                                        </div>
                                                                                                                )}
                                                                                                            </div>
                                                                                                        </div>
                                                                                                    </a>
                                                                                                </div>
                                                                                                {isPreferred && (
                                                                                                        <>
                                                                                                            <div class="preferred-ping absolute top-[1.5px] left-[2px] h-full w-full bg-(--preferred-accent-color) rounded-[9999px] animate-ping-faint"/>
                                                                                                            <div class="preferred-shadow absolute top-[3px] left-[4px] w-full h-full rounded-[100px]"/>
                                                                                                        </>
                                                                                                )}
                                                                                            </>
                                                                                    ) : (
                                                                                            <>
                                                                                                {
                                                                                                    merchantId && locationId && (
                                                                                                                <>
                                                                                                                    <SlottableModal
                                                                                                                            cardButtonClass={`link-card ${isPreferred ? "preferred" : "bookable"} w-full not-first:mt-2`}
                                                                                                                            cardRadius="50px"
                                                                                                                            expandedRadius="24px"
                                                                                                                            cardShadow={`${isPreferred ? "3px 4px 0 0 var(--preferred-accent-color)" : "3px 4px 0 0 var(--bookable-accent-color)"}`}
                                                                                                                            expandedShadow="none"
                                                                                                                            cardBorder={`${isPreferred ? "3px solid var(--preferred-accent-color)" : "3px solid var(--bookable-accent-color)"}`}
                                                                                                                            expandedBorder={`${isPreferred ? "0px solid var(--preferred-accent-color)" : "0px solid var(--bookable-accent-color)"}`}
                                                                                                                            heroHeight="initial"
                                                                                                                            duration="420ms"
                                                                                                                    >
                                                                                                                        <Fragment
                                                                                                                                slot="card">
                                                                                                                            <>
                                                                                                                                <div
                                                                                                                                        class="grid min-h-12 w-full grid-cols-[auto_1fr_auto] items-center gap-3 border-0 bg-transparent px-4 py-[0.875rem] text-left text-inherit"
                                                                                                                                >
                                                                                                                                    <div class="h-full content-center">
                                                                                                                                        <div aria-hidden="true"
                                                                                                                                             class="flex h-10 w-10">
                                                                                                                                            {Icon &&
                                                                                                                                                    <Icon class="h-full w-full"/>}
                                                                                                                                        </div>
                                                                                                                                    </div>

                                                                                                                                    <div class="grid gap-[0.35rem] text-center content-center font-semibold break-words pr-10">
                                                                                                                                        {item.type}
                                                                                                                                    </div>
                                                                                                                                </div>
                                                                                                                            </>
                                                                                                                        </Fragment>
                                                                                                                        <Fragment
                                                                                                                                slot="modal-content-hero">
                                                                                                                            <img
                                                                                                                                    class="object-cover object-top"
                                                                                                                                    src={ogImageSrc}
                                                                                                                                    alt=""
                                                                                                                            />
                                                                                                                        </Fragment>
                                                                                                                        <Fragment
                                                                                                                                slot="modal-content-main">
                                                                                                                            <SquareAppointmentsIsland
                                                                                                                                    client:load
                                                                                                                                    merchantSlug={merchantId}
                                                                                                                                    locationSlug={locationId}/>
                                                                                                                        </Fragment>
                                                                                                                    </SlottableModal>
                                                                                                                    {isPreferred && (
                                                                                                                            <>
                                                                                                                                <div class="preferred-ping absolute top-[1.5px] left-[2px] h-full w-full bg-(--preferred-accent-color) rounded-[9999px] animate-ping-faint"/>
                                                                                                                                <div class="preferred-shadow absolute top-[3px] left-[4px] w-full h-full rounded-[100px]"/>
                                                                                                                            </>
                                                                                                                    )}
                                                                                                                </>
                                                                                                    )
                                                                                                }
                                                                                            </>
                                                                                    )}
                                                                                </li>
                                                                        );
                                                                    },
                                                                )}
                                                            </ul>
                                                        </section>
                                                        <section class="p-4 other-links-section list-section"
                                                                 aria-labelledby={`${personHeadingId}-other-links-section`}>
                                                            <div class="list-section-text">
                                                                <h3 id={`${personHeadingId}-other-links-section`}
                                                                    class="text-base tracking-wide text-neutral-700">
                                                                    Other Links:
                                                                </h3>
                                                            </div>
                                                            <ul class="m-0 grid list-none gap-2">
                                                                <li class="link-card-li">
                                                                    <div class={`link-card basic not-first:mt-2`}>
                                                                        {
                                                                            (() => {
                                                                                let href = `/`;
                                                                                if (isGuest) {
                                                                                    href = `/events/${person.hrefId}`;
                                                                                } else if (person.data.primaryRole === "Tattoo Artist") {
                                                                                    href = `/artists/${person.id}`;
                                                                                } else if (person.data.primaryRole === "Piercer") {
                                                                                    href = `/piercing`;
                                                                                }

                                                                                return (
                                                                                        <a
                                                                                                class="font-semibold break-words"
                                                                                                href={href}
                                                                                        >
                                                                                            <div class="grid grid-cols-[auto_1fr] gap-x-3 gap-y-1 px-[0.375rem] py-[0.375rem]">
                                                                                                <div class="h-full content-center">
                                                                                                    <div
                                                                                                            aria-hidden="true"
                                                                                                            class="flex h-[3.5rem] w-[3.5rem] bg-white rounded-full p-1 outline-2 outline-dotted outline-slate-300"
                                                                                                    >
                                                                                                        <Image src={logoDarkBold}
                                                                                                               alt={`${siteName} page for ${person.data.name}`}/>
                                                                                                    </div>
                                                                                                </div>
                                                                                                <div class="grid gap-[0.35rem] text-center content-center pr-[3.5rem]">
                                                                                                    <div class="text-[0.95rem] leading-[1.5] opacity-80">
                                                                                                        Go to
                                                                                                        <span class="lowercase"
                                                                                                        >{isGuest ? (
                                                                                                            "Event"
                                                                                                        ) : (
                                                                                                            `${person.data.primaryRole.replaceAll("Tattoo ", "")}`
                                                                                                        )}
                                                                                        </span>
                                                                                                        page →
                                                                                                    </div>
                                                                                                </div>
                                                                                            </div>
                                                                                        </a>
                                                                                )
                                                                            })()
                                                                        }
                                                                    </div>
                                                                </li>
                                                                {hasNonbookableSocials && (
                                                                        <li class="link-card-li">
                                                                            <div class={`link-card basic h-[4.25rem] w-full not-first:mt-2`}>
                                                                                <SocialRow
                                                                                        links={nonbookableSocials}
                                                                                        class="h-full"
                                                                                        anchorClass="px-3"
                                                                                />
                                                                            </div>
                                                                        </li>
                                                                )}
                                                            </ul>
                                                        </section>
                                                    </div>
                                                </div>
                                            </section>
                                        </li>
                                )
                            );
                        })
                    }
                </ul>
            </section>
        </div>
    </main>
    <script is:inline>
        window.addEventListener("scroll", function () {
            const scrollPosition = window.scrollY;
            const bookingContent = document.getElementById("booking-content");
            const scrollHeightHeaderImg = bookingContent.clientHeight;
            const wallaperFlashAnimated = document.querySelector(".wallpaper-flash-animated");
            const headerImgTranslator = document.querySelector("#header-img-translator");
            const headerImg = document.querySelector("#header-img-translator img");

            const bookingContentRectTop = bookingContent.getBoundingClientRect().top;
            const scrollPositionHeaderImg = Math.abs(Math.min(0, bookingContentRectTop),);
            const headerImgProgress = scrollPositionHeaderImg / scrollHeightHeaderImg;

            wallaperFlashAnimated.style.transform = `translateY(${scrollPosition * 0.5}px)`;

            headerImgTranslator.style.transform = `translateY(${scrollPositionHeaderImg * 0.2}px)`;
            headerImg.style.transform = `scale(${1 + headerImgProgress * 0.6})`; // why did I originally go with .1?? .9 is so much better, desktop & mobile
            headerImg.style.opacity = `${1 - headerImgProgress * 3}`;
        });
    </script>
    <style>
        :root {
            background-color: oldlace;
            --test-brand-profile-bg-color: #ffd230;
            --test-brand-profile-border-color: #dfac04;
            --test-brand-profile-shadow-color: #c8a01b;
            --brand-profile-bg-color: floralwhite;
            --brand-profile-border-color: lightgray;
            --brand-profile-shadow-color: gainsboro;
            --preferred-accent-color: #ffd230;
            --preferred-gradient: #ffffff, var(--preferred-accent-color), var(--preferred-accent-color), #ffc800, #ffc800, var(--preferred-accent-color), var(--preferred-accent-color),
            #ffffff;
            --bookable-accent-color: #4DA3FF;
            --bookable-gradient: #c6e2ff, var(--bookable-accent-color), var(--bookable-accent-color), #416af1, #416af1, var(--bookable-accent-color), var(--bookable-accent-color),
            #c6e2ff;
            --subitem-bg-color: #f5fff0;
            --bookable-bg-color: #f0f5ff;
            --preferred-bg-color: #fdfff0;
            --profile-frame-border-color: #c2abc2;
            --profile-frame-shadow-color: thistle;
        }

        #booking-header-activity {
            position: relative;
            width: 100%;
            transform: translateY(calc(var(--spacing) * -30));
            margin-bottom: calc(var(--spacing) * -30);
        }

        @media (min-width: 768px) {
            #booking-header-activity {
                transform: translateY(calc(var(--spacing) * -40));
                margin-bottom: calc(var(--spacing) * -40);
            }
        }

        #header-img-container {
            aspect-ratio: 16 / 11;
            width: 100%;
        }

        #header-img-translator {
            mask: linear-gradient(
                    to bottom,
                    black 0%,
                    black 85%,
                    transparent 100%
            );
            clip-path: shape(
                    from 0 0,
                    hline to 100%,
                    vline to 85%,
                    curve to 0 85% with 50% 100%,
                    close
            );
        }

        #header-img-container img {
            aspect-ratio: 16 / 11;
            object-fit: cover;
            object-position: center top;
        }

        [data-accordion-toggle][aria-expanded="true"] > svg {
            transform: rotate(180deg);
        }

        @media (prefers-reduced-motion: reduce) {
            [data-accordion-panel],
            [data-accordion-toggle] > svg {
                transition: none;
            }
        }

        /*** ----------------------- ***/
        /*** pill shimmers & pulses  ***/
        /*** ----------------------- ***/

        @property --glow-deg {
            syntax: "<angle>";
            inherits: true;
            initial-value: 0deg;
        }

        @keyframes glow {
            100% {
                --glow-deg: 360deg;
            }
        }

        .list-section:last-of-type {
            background: linear-gradient(#FAECD4, rgba(0, 0, 0, 0));
            padding-top: 40px;
            mask: linear-gradient(180deg, #0000 30px, #000 0),
            radial-gradient(30px, #000 calc(100% - 1px), #0000) top/55.5px 60px;
        }

        .list-section-text {
            padding: 1rem;
            margin-bottom: 1rem;
            padding-top: 0;
            text-align: center;
            max-width: 28rem;
            margin-inline: auto;
        }

        .person-bookable-card-li {
            position: relative;
            border-width: 2px;
            border-style: solid;
            border-radius: 50px;
            background-color: floralwhite;
        }

        .person-bookable-card-li:not(.guest) {
            border-color: black;
            box-shadow: 3px 4px 0 0 black;
        }

        .person-bookable-card-li.guest {
            border-color: #e0c7ff;
            box-shadow: 3px 4px 0 0 #e0c7ff;
        }

        .person-bookable-card-li:not(:first-child) {
            margin-top: 1.5rem;
        }

        .person-bookable-card-li:not(:first-child):not(.guest) {
            margin-top: 0.75rem;
        }

        .person-bookable-card-li:nth-last-child(1 of .guest) {
            margin-bottom: 4rem;
        }

        .profile-picture {
            height: 4rem;
            width: 4rem;
            overflow: hidden;
            border-width: 2px;
            border-radius: 50px;
        }

        .person-bookable-card-li:not(.guest) .profile-picture {
            border-color: var(--profile-frame-border-color);
            box-shadow: 3px 3px 0 1px var(--profile-frame-shadow-color);
        }

        .person-bookable-card-li.guest .profile-picture {
            border-color: lightgoldenrodyellow;
            box-shadow: 3px 3px 0 1px palegoldenrod;
        }

        .link-card-li {
            position: relative;
            min-width: 0;
            width: 100%;
        }

        .link-card {
            position: relative;
            z-index: 10;
            border-radius: 50px;
            border-width: 3px;
        }

        .link-card.basic {
            box-shadow: 3px 4px 0 0 black;
            background-color: honeydew;
        }

        .link-card.bookable:not(.preferred) {
            box-shadow: 3px 4px 0 0 var(--bookable-accent-color);
            background: var(--bookable-bg-color);
            border-color: var(--bookable-accent-color);
        }

        .preferred.link-card {
            border-color: transparent;
            background: linear-gradient(var(--preferred-bg-color) 0 0) padding-box,
            conic-gradient(from var(--glow-deg), var(--preferred-gradient)) border-box;
            animation: glow 10s linear infinite;
        }

        .preferred-shadow {
            background: conic-gradient(
                    from var(--glow-deg),
                    var(--preferred-gradient)
            );
            animation: glow 10s linear infinite;
        }

        /*** ----------------------- ***/
        /*** wallpaper animations    ***/
        /*** ----------------------- ***/

        .page {
            position: relative;
            min-height: 100vh;
            overflow: hidden;
        }

        .wallpaper {
            inset: 0;
            z-index: 0;
        }

        .wallpaper-flash-animated {
            position: absolute;
            background-color: transparent;
            background-repeat: repeat;
            background-size: 900px 900px;
            background-position: 0 0;
            animation: driftX 120s ease-in-out infinite,
            driftY 60s linear infinite;
            opacity: 0.9;
            transform: translateY(0);
        }

        #booking-content {
            box-shadow: 10px 10px 12px rgba(0, 0, 0, 0.5);
        }

        .wallpaper-gradient {
            position: fixed;
            background-color: oldlace;
        }

        @keyframes driftY {
            from {
                background-position-y: 0;
            }
            to {
                background-position-y: 900px;
            }
        }

        @keyframes driftX {
            0% {
                background-position-x: 0;
                animation-timing-function: ease-out;
            }
            25% {
                background-position-x: 900px;
                animation-timing-function: ease-in;
            }
            50% {
                background-position-x: 0px;
                animation-timing-function: ease-out;
            }
            75% {
                background-position: -900px;
                animation-timing-function: ease-in;
            }
            100% {
                background-position-x: 0px;
                animation-timing-function: ease-out;
            }
        }
    </style>

    <script is:inline>
        (() => {
            const root = document.querySelector("[data-accordion-root]");
            if (!root) return;

            const isExpanded = (btn) => btn.getAttribute("aria-expanded") === "true";

            const getPanel = (btn) => {
                const id = btn.getAttribute("aria-controls");
                return id ? document.getElementById(id) : null;
            };

            const setPanelInteractive = (panel, interactive) => {
                if (!panel) return;
                panel.inert = !interactive;
            };

            const isFocusInside = (el) =>
                !!el &&
                !!document.activeElement &&
                el.contains(document.activeElement);

            const ensureFocusNotIn = (panel, fallbackEl) => {
                if (isFocusInside(panel)) fallbackEl?.focus?.();
            };

            const getTransitionMs = (el) => {
                const styles = getComputedStyle(el);

                const parseList = (value) =>
                    value
                        .split(",")
                        .map((part) => part.trim())
                        .map((part) =>
                            part.endsWith("ms")
                                ? parseFloat(part)
                                : parseFloat(part) * 1000,
                        )
                        .filter((n) => !Number.isNaN(n));

                const durations = parseList(styles.transitionDuration);
                const delays = parseList(styles.transitionDelay);

                const maxDuration = Math.max(0, ...durations, 0);
                const maxDelay = Math.max(0, ...delays, 0);

                return maxDuration + maxDelay + 50;
            };

            const ensurePixelHeight = (panel) => {
                const computed = getComputedStyle(panel).height;
                if (computed === "auto" || panel.style.height === "auto") {
                    panel.style.height = panel.scrollHeight + "px";
                    void panel.offsetHeight;
                }
            };

            const animatePanel = (btn, panel, expand) =>
                new Promise((resolve) => {
                    if (!btn || !panel) {
                        resolve();
                        return;
                    }

                    if (panel.dataset.animating === "1") {
                        resolve();
                        return;
                    }

                    if (!expand) ensureFocusNotIn(panel, btn);

                    if (expand) {
                        setPanelInteractive(panel, true);
                    }

                    btn.disabled = true;
                    panel.dataset.animating = "1";
                    panel.style.pointerEvents = "none";

                    btn.setAttribute(
                        "aria-expanded",
                        expand ? "true" : "false",
                    );
                    panel.setAttribute(
                        "data-state",
                        expand ? "open" : "closed",
                    );

                    ensurePixelHeight(panel);

                    const finish = () => {
                        delete panel.dataset.animating;
                        panel.style.pointerEvents = "";
                        btn.disabled = false;

                        if (expand) {
                            panel.style.height = "auto";
                        } else {
                            setPanelInteractive(panel, false);
                        }

                        resolve();
                    };

                    let done = false;
                    const complete = () => {
                        if (done) return;
                        done = true;
                        panel.removeEventListener("transitionend", onEnd);
                        clearTimeout(fallback);
                        finish();
                    };

                    const onEnd = (e) => {
                        if (e.target !== panel || e.propertyName !== "height")
                            return;
                        complete();
                    };

                    const fallback = setTimeout(
                        complete,
                        getTransitionMs(panel),
                    );

                    panel.addEventListener("transitionend", onEnd);

                    requestAnimationFrame(() => {
                        panel.style.height = expand
                            ? panel.scrollHeight + "px"
                            : "0px";
                    });
                });

            const getOpenDescendantButtonsDeepestFirst = (panel) => {
                const openButtons = Array.from(
                    panel.querySelectorAll(
                        '[data-accordion-toggle][aria-expanded="true"]',
                    ),
                );

                return openButtons.sort((a, b) => {
                    const depthA =
                        a.closest("[data-accordion-panel]")?.parentsLength ?? 0;
                    const depthB =
                        b.closest("[data-accordion-panel]")?.parentsLength ?? 0;
                    return depthB - depthA;
                });
            };

            // Slightly more reliable depth calculation than the placeholder above.
            const getDepth = (el) => {
                let depth = 0;
                let current = el.closest("[data-accordion-panel]");
                while (current) {
                    depth += 1;
                    current =
                        current.parentElement?.closest?.(
                            "[data-accordion-panel]",
                        ) ?? null;
                }
                return depth;
            };

            const closeDescendantsFirst = async (panel) => {
                const openButtons = Array.from(
                    panel.querySelectorAll(
                        '[data-accordion-toggle][aria-expanded="true"]',
                    ),
                ).sort((a, b) => getDepth(b) - getDepth(a));

                for (const openBtn of openButtons) {
                    const openPanel = getPanel(openBtn);
                    if (!openPanel) continue;
                    await animatePanel(openBtn, openPanel, false);
                }
            };

            const closeBranch = async (btn) => {
                const panel = getPanel(btn);
                if (!panel || !isExpanded(btn)) return;

                await closeDescendantsFirst(panel);
                await animatePanel(btn, panel, false);
            };

            const getRootButtons = () =>
                Array.from(
                    root.querySelectorAll(
                        '[data-accordion-toggle][data-accordion-level="root"]',
                    ),
                );

            root.addEventListener("click", async (event) => {
                const btn = event.target.closest?.("[data-accordion-toggle]");
                if (!btn || !root.contains(btn)) return;

                const panel = getPanel(btn);
                if (!panel) return;

                if (panel.dataset.animating === "1") return;

                const level = btn.getAttribute("data-accordion-level");
                const nextExpanded = !isExpanded(btn);

                if (level === "root") {
                    if (nextExpanded) {
                        for (const openRootBtn of getRootButtons()) {
                            if (openRootBtn === btn) continue;
                            if (!isExpanded(openRootBtn)) continue;
                            await closeBranch(openRootBtn);
                        }
                        await animatePanel(btn, panel, true);
                    } else {
                        await closeBranch(btn);
                    }

                    return;
                }

                // Nested toggles:
                // they can open/close independently,
                // but when their parent person closes, they will be closed first.
                await animatePanel(btn, panel, nextExpanded);
            });

            const openFromHash = async () => {
                const rawHash = window.location.hash.slice(1);
                if (!rawHash) return;

                const target = document.getElementById(rawHash);
                if (!target) return;

                const btn = target.matches("[data-accordion-toggle]")
                    ? target
                    : document.querySelector(`[aria-controls="${CSS.escape(rawHash)}"]`);
                if (!btn) return;

                const panel = getPanel(btn);
                if (!panel) return;

                if (!isExpanded(btn)) {
                    if (btn.getAttribute("data-accordion-level") === "root") {
                        for (const openRootBtn of getRootButtons()) {
                            if (openRootBtn !== btn && isExpanded(openRootBtn)) {
                                await closeBranch(openRootBtn);
                            }
                        }
                    }

                    await animatePanel(btn, panel, true);
                }

                requestAnimationFrame(() => {
                    btn.scrollIntoView({
                        behavior: "smooth",
                        block: "start",
                    });
                });
            };

            window.addEventListener("hashchange", openFromHash);
            openFromHash();

            document.addEventListener("keydown", async (event) => {
                if (event.key !== "Escape") return;

                const openRootBtn = getRootButtons().find((btn) => isExpanded(btn));
                if (!openRootBtn) return;

                await closeBranch(openRootBtn);
                openRootBtn.focus();
            });
        })();
    </script>
</BaseLayout>
