---
import Layout from "../../layouts/Layout.astro";
import {loadActiveArtists, loadActivePeople} from "../../domain/people/server";
import {defaults} from "../../config/site.ts";
import {loadUpcomingGuestSpotCandidates} from "../../domain/events/selectors.ts";
// import SparkleCorners from "../../components/decor/SparkleCorners.astro";
import SparkleCorners from "../../components/decor/SparkleCornersPureCss.astro";


let artists = await loadActiveArtists();
const guestSpotEvents = await loadUpcomingGuestSpotCandidates(new Date());
const primaryRole = "Tattoo Artist";
const seen = new Set<string>();
const guestArtists = guestSpotEvents
    .filter(ev => ev.guestSpot[0].primaryRole === primaryRole)
    .filter((ev) => {
        if (seen.has(ev.guestSpot[0].guestName)) {
            return false;
        }
        seen.add(ev.guestSpot[0].guestName);
        return true;
    });



const defaultPersonProfilePicture = defaults.personProfilePicture;
const title = "Artists";
---

<Layout title={title}>
    <article class="page-article">
        <h1 class="page-title">{title}</h1>
        {
            guestArtists.length > 0 && (
                        <section class="mt-8">
                            <div class="flex flex-wrap justify-center gap-6">
                                {guestArtists.map((guest) => {
                                    const href = `/events/${guest.id}`;
                                    const runwayPhotoHref =
                                        guest.guestSpot[0].runwayPhoto
                                            ? `/src/content/events/${guest.guestSpot[0].runwayPhoto}`
                                            : undefined;
                                    return (
                                            <a
                                                    href={href}
                                                    class="group block w-full sm:w-[calc((100%-1.5rem)/2)] md:w-[calc((100%-3rem)/3)] lg:w-[calc((100%-4.5rem)/4)]"
                                            >
                                                <div class="relative overflow-visible">
                                                    <div class="aspect-[4/5] w-full overflow-hidden rounded-2xl bg-gray-200">
                                                        <img
                                                                src={runwayPhotoHref ?? defaultPersonProfilePicture}
                                                                alt={guest.guestSpot[0].guestName}
                                                                class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                                                        />
                                                    </div>
                                                    <SparkleCorners
                                                            color="transparent"
                                                            fillColor="#2E2EFF"
                                                            size={24}
                                                            gap={16}
                                                            offset={-20}
                                                    />
                                                    <!--<SparkleCorners-->
                                                    <!--        color="gold"-->
                                                    <!--        size={24}-->
                                                    <!--        gap={16}-->
                                                    <!--        offset={-40}-->
                                                    <!--        sparkleDurationMs={800}-->
                                                    <!--        stepMs={200}-->
                                                    <!--        betweenClustersPauseMs={1000}-->
                                                    <!--        cyclePauseMs={2000}-->
                                                    <!--/>-->
                                                </div>
                                                <p class="mt-3 text-center text-base font-medium tracking-wide">
                                                    {guest.guestSpot[0].guestName}
                                                </p>
                                                <!--<SparkleCorners-->
                                                <!--        color="goldenrod"-->
                                                <!--        sizes={[14, 22, 18]}-->
                                                <!--        gap={80}-->
                                                <!--        offset={12}-->
                                                <!--        sparkleDuration={5000}-->
                                                <!--        stagger={14000}-->
                                                <!--        pauseBetweenClusters={50000}-->
                                                <!--        pauseBeforeRepeat={700000}-->
                                                <!--&gt;</SparkleCorners>-->
                                            </a>
                                    );
                                })}
                            </div>
                        </section>
            )
        }
        <div class="mt-8 grid gap-6 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
            <!-- Artist Card -->
            {artists.map((artist) => {
                return (
                        <a href="#" class="group block spin-in">
                            <div class="aspect-[4/5] w-full overflow-hidden rounded-2xl bg-gray-200">
                                <img
                                        src={artist.data.runwayPhoto ?? defaultPersonProfilePicture}
                                        alt={artist.data.name}
                                        class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                                />
                            </div>
                            <p class="mt-3 text-center text-base font-medium tracking-wide">
                                {artist.data.name}
                            </p>
                        </a>
                );
            })}
        </div>
    </article>
</Layout>



