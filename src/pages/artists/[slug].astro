---
import Layout from "../../layouts/Layout.astro";
import {loadActiveArtists} from "../../domain/people/server.ts";
import {render, getCollection, type CollectionEntry, getEntry} from "astro:content";
import {ImageGallery} from "../../components/ImageGalleryNoThumbs.tsx";
import {getImage, Image} from "astro:assets";
import SocialRow from "../../components/SocialRow.astro";
import ShareModal from "../../components/ShareModal.astro";
import {defaults} from "../../config/site.ts";
import {getBookables} from "../../domain/contact/utlis.ts";

const branding = await getEntry("branding", "main");

const isAsset = (v: unknown) =>
    typeof v === "object" && v !== null && "src" in (v as any);

export async function getStaticPaths() {
    // const artists = await getCollection("artists");
    let artists = await loadActiveArtists();
    // artists = (await getCollection("artists")) as CollectionEntry<"artists">[];

    // todo: I did this differently (at a later time) for events. Take a look at that at some point to reconcile.
    return artists.map((entry) => ({
        params: {slug: entry.id},
        props: {entry},
    }));
}

const {entry} = Astro.props;

// Render the Markdown *body* (the part after the frontmatter)
const {Content} = await render(entry);

const thumb = (src: string, w: number) =>
    src.replace("/uploads/people/", `/uploads/_thumbs/people/${w}/`);

const square = entry.data.contactSocialsBooking?.platforms?.find(
    (p) => p.type === "square",
);

const socials = entry.data.contactSocialsBooking?.socials?.find(
    (item) => item.type === "instagram",
);

const moduleInfo = square?.linkOrModuleInfo.find(
    (item) => item.type === "moduleInfo",
);

const description = `Learn more about ${entry.data.name}, view tattoo style information, and find booking details at BluTattoo.`;
const ogImage = entry.data.ogPhotoTexted ?? entry.data.ogPhotoTextless ?? branding?.data.sitewideOGPhoto ?? defaults.ogPhoto;
const bookingToggleId = `person-${entry.id}-toggle`;
const artistBookingHref = `/booking#${bookingToggleId}`;
const hasBookables = (getBookables(entry.data.contactSocialsBooking)?.length ?? 0) > 0;

const lightboxImages = await Promise.all(
    (entry.data.images ?? []).map(async (img, idx) => {
        const lightbox = await getImage({
            src: img,
            // widths: [720, 960, 1280, 1600],
            widths: [720, 1080, 1440, 1920, 2400, 2880],
            sizes: "100vw",
            format: "webp",
            quality: 80,
        });

        // currently not using this, but keeping for posterity:
        const thumb = await getImage({
            src: img,
            width: 640,
            format: "webp",
            quality: 70,
        });

        return {
            src: lightbox.src,
            thumbSrc: thumb.src,
            srcSet: lightbox.srcSet.attribute,
            sizes: "100vw",
            width: Number(lightbox.attributes.width),
            height: Number(lightbox.attributes.height),
            alt: `${entry.data.name} gallery image ${idx + 1}`,
        };
    })
);
---

<script>
    import {bootFadeUp} from "../../scripts/fade-up";

    bootFadeUp({observeMutations: true, threshold: .01, rootMargin: "500px 00px",});
    //js-fade-up
</script>

<Layout
        title={entry.data.name}
        description={description}
        ogImage={ogImage}
        preloadImage={entry.data.pagePhoto?.src}
>
    <article class="space-y-6">
        <header class="text-orange-100">
            <div class="space-y-2 pt-10 bg-black outline-4 outline-black">
                <div class="mx-auto max-w-6xl grid grid-cols-1 sm:grid-cols-2 gap-4">
                    {
                        entry.data.pagePhoto && (
                                    <div class="portrait fade-in-left-and-glow-anim">
                                        <Image
                                                src={entry.data.pagePhoto}
                                                alt={`Portrait of ${entry.data.name}`}
                                                widths={[320, 480, 640, 768, 960, 1100, 1280]}
                                                sizes="(max-width: 639px) 100vw, (max-width: 1152px) calc((100vw - 1rem) / 2), 568px"
                                                decoding="sync"
                                                loading="eager"
                                                fetchpriority="high"
                                                class="mask-b-from-60% mask-b-to-100%"
                                        />
                                    </div>
                        )
                    }
                    <style>
                        @media (width < 40rem) {
                            .portrait {
                                filter: drop-shadow(-1px -10px 10px rgba(99, 102, 241, 0.35)) drop-shadow(-1px -10px 22px rgba(99, 102, 241, 0.18));
                            }
                        }

                        @media (width >= 40rem) {
                            .fade-in-left-and-glow-anim {
                                //--portrait-in: 6000ms;
                                --portrait-in: 2000ms;
                                opacity: 0;
                                //transform: translate3d(-200px, 0, 0);
                                transform: translate3d(-25px, 0, 0);
                                //filter: drop-shadow(-80px -10px 80px rgba(99, 102, 241, 0.35)) drop-shadow(-80px -10px 92px rgba(99, 102, 241, 0.18));
                                filter: drop-shadow(-40px -5px 40px rgba(99, 102, 241, 0.35)) drop-shadow(-40px -5px 45px rgba(99, 102, 241, 0.18));
                                animation: portraitIn var(--portrait-in) cubic-bezier(0.2, 0.9, 0.2, 1) forwards,
                                glowIn var(--portrait-in) cubic-bezier(0.2, 0.9, 0.2, 1) forwards;
                                will-change: transform, opacity;
                            }

                            @keyframes portraitIn {
                                to {
                                    opacity: 1;
                                    transform: translate3d(0, 0, 0);
                                }
                            }

                            @keyframes glowIn {
                                to {
                                    filter: drop-shadow(-1px -10px 10px rgba(99, 102, 241, 0.35)) drop-shadow(-1px -10px 22px rgba(99, 102, 241, 0.18));
                                }
                            }

                            @media (prefers-reduced-motion: reduce) {
                                .fade-in-left-and-glow-anim {
                                    opacity: 1;
                                    transform: none;
                                    animation: none;
                                }
                            }
                        }
                    </style>
                    <div id="artist-bio" class="flex items-center p-5 js-fade-up">
                        <div class="w-full">
                            <h1 id="artist-name" class="text-3xl font-bold inline-block">
                                {entry.data.name}
                            </h1>
                            <ShareModal shareTitle={entry.data.name} shareHero={ogImage} shellClass="inline-block"
                                        cardButtonClass="m-2"
                                        cardButtonColorClass="bg-white/10 border-1 border-solid border-orange-100/40"
                                        heroFullBleed={true}/>
                            {
                                entry.data.contactSocialsBooking?.socials && (
                                            <SocialRow
                                                    links={entry.data.contactSocialsBooking.socials}
                                                    class="my-3"
                                                    justificationClass="justify-start"
                                                    anchorClass="text-orange-100/60 hover:text-orange-100 transition duration-200"
                                                    scrollBtnClass="h-10 w-10 p-3 m-1 rounded-full bg-black/70 border-1 border-solid border-orange-100"
                                            />
                                )
                            }
                            {
                                hasBookables && (
                                            <div class="my-4">
                                                <a
                                                        href={artistBookingHref}
                                                        class="inline-flex items-center justify-center px-6 py-2 border border-orange-100 text-orange-100 shadow-[3px_3px_0_#ffedd5] text-sm tracking-wide uppercase hover:bg-orange-100 hover:text-black hover:shadow-[2px_2px_0_#ffedd5] transition duration-300"
                                                        aria-label={`Book an appointment with ${entry.data.name}`}
                                                >
                                                    Book with {entry.data.name}
                                                </a>
                                            </div>
                                )
                            }
                            <div class="js-fade-up">
                                <h2 class="sr-only">Bio</h2>
                                <div data-person-bio class="whitespace-pre-line">
                                    <Content/>
                                </div>
                            </div>
                        </div>
                        <style is:global>
                            [data-person-bio] a {
                                text-decoration: underline;
                            }

                            [data-person-bio] a:hover {
                                text-decoration: none;
                            }

                            [data-person-bio] blockquote {
                            }


                        </style>
                    </div>
                </div>
            </div>
            {/* Divider */}
            <div aria-hidden="true">
                <svg class="block h-full w-full" viewBox="1 1 590 213">
                    <path
                            d="M.5,67.66C138.58-15.68,457.87,282.01,595.78,198.61V.5H.5v67.16Z"
                            fill="black"></path>
                </svg>
            </div>
        </header>

        <!-- Artist Gallery -->
        {
            entry.data.images?.length && lightboxImages && (
                        <section class="js-fade-up" aria-labelledby="gallery-heading">
                            <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-10 pb-10 lg:pb-14">
                                <div class="flex items-end justify-between gap-4 mb-5 lg:mb-7">
                                    <div>
                                        <h2 id="gallery-heading"
                                            class="text-6xl sm:text-8xl md:text-9xl lg:text-9xl font-semibold text-gray-900">
                                            Gallery
                                        </h2>
                                        <p class="text-sm text-gray-600 js-fade-up">
                                            Tap/click to view full size.
                                        </p>
                                    </div>

                                    <p class="text-xs text-gray-500">
                                        {entry.data.images.length} photos
                                    </p>
                                </div>

                                <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 sm:gap-4">
                                    {entry.data.images.map((img, idx) => (
                                            <button
                                                    type="button"
                                                    class="group overflow-hidden rounded-md text-left cursor-pointer"
                                                    data-idx={idx}
                                                    onclick={`window.dispatchEvent(new CustomEvent("open-lightbox", { detail: { index: ${idx} } }))`}
                                            >
                                                <Image
                                                        src={img}
                                                        widths={[240, 360, 480, 512, 720]}
                                                        sizes="(max-width: 639px) calc(100vw - 32px), (max-width: 767px) calc((100vw - 64px) / 2), (max-width: 1023px) calc((100vw - 80px) / 3), (max-width: 1152px) calc((100vw - 128px) / 4), 256px"
                                                        alt={`${entry.data.name} gallery image ${idx + 1}`}
                                                        loading="lazy"
                                                        decoding="async"
                                                        class="block w-full aspect-square object-cover transition-transform duration-300 group-hover:scale-[1.03]"
                                                />
                                            </button>
                                    ))}
                                </div>
                                <!--<ImageGallery-->
                                <!--        client:load-->
                                <!--        images={entry.data.images.map((img, idx) => ({-->
                                <!--            src: img.src,-->
                                <!--            alt: `${entry.data.name} gallery image ${idx + 1}`,-->
                                <!--        }))}-->
                                <!--/>-->
                                <ImageGallery
                                        client:load
                                        images={lightboxImages}
                                />
                            </div>
                        </section>
            )
        }

        {hasBookables && (
                <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-10 pb-10 js-fade-up">
                    <div class="border border-black bg-[seashell] p-5 sm:p-6 shadow-[5px_5px_0_black] flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                        <div>
                            <h2 class="text-xl font-semibold tracking-tight">
                                Want to book with {entry.data.name}?
                            </h2>
                            <p class="mt-1 text-sm text-gray-700">
                                View booking details, contact channels, and appointment options.
                            </p>
                        </div>

                        <a
                                href={artistBookingHref}
                                class="inline-flex justify-center px-6 py-2 border border-black shadow-[3px_3px_0_black] text-sm tracking-wide uppercase hover:bg-blue-100 hover:shadow-[2px_2px_0_black] transition duration-300"
                        >
                            Book now
                        </a>
                    </div>
                </section>
                <aside
                        class="fixed-cta fixed inset-x-0 bottom-0 z-40 p-2 sm:hidden m-0"
                        aria-label={`Booking call to action for ${entry.data.name}`}
                >
                    <a
                            href={artistBookingHref}
                            class="block w-full text-center py-3 border border-orange-100 text-orange-100 shadow-[3px_3px_0_#ffedd5] text-sm tracking-wide uppercase hover:bg-orange-100 hover:text-black transition duration-300 bg-black/85 backdrop-blur"
                            aria-label={`Book an appointment with ${entry.data.name}`}
                    >
                        Book with {entry.data.name}
                    </a>
                    <script is:inline>
                        (() => {
                            const root = document.documentElement;
                            const parent = document.currentScript?.parentElement;
                            if (!root || !parent) return;

                            const measured = `${parent.offsetHeight}px`;
                            root.style.setProperty("--fixed-booking-button-h", measured);
                        })();
                    </script>
                </aside>
        )}
    </article>
</Layout>
