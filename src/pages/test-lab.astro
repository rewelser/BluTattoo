const sickleDataUrl = `data:image/svg+xml;charset=utf-8,${encodeURIComponent(sickleSvg)}`;
---

<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Star Drift Test</title>
    </head>
    <body>
        <main class="page">
            <div
                id="wallpaper"
                class="wallpaper"
                aria-hidden="true"
                style={`background-image: url("${sickleDataUrl}")`}
            >
            </div>

            <section class="content">
                <h1>Star Drift Test</h1>
                <p>Testing background-position animation.</p>
            </section>
        </main>
    </body>
</html>

<style>
    :global(html, body) {
        margin: 0;
        width: 100%;
        min-height: 100%;
    }

    :global(body) {
        /* background: #111; */
        background: whitesmoke;
        /* color: white; */
        font-family: sans-serif;
    }

    .page {
        position: relative;
        min-height: 100vh;
        overflow: hidden;
        /* isolation: isolate; */
    }

    .wallpaper {
        position: absolute;
        inset: 0;
        z-index: 0;
        background-repeat: repeat;
        background-size: 72px 72px;
        background-position: 0 0;
        animation:
            driftX 24s ease-in-out infinite,
            driftY 12s linear infinite;
        /* animation: driftWeave2 10s linear infinite; */
        opacity: 0.9;
        transform: translateY(0);
    }

    .content {
        position: relative;
        z-index: 1;
        min-height: 400vh;
        display: grid;
        place-items: center;
        text-align: center;
        padding: 2rem;
        background: linear-gradient(
            to bottom,
            rgb(0 0 0 / 0.15),
            rgb(0 0 0 / 0.35)
        );
        background: linear-gradient(
            to bottom,
            rgba(0, 30, 255, 0.15),
            rgba(136, 166, 255, 0.55)
        );
        background: linear-gradient(
            to bottom,
            rgba(136, 182, 255, 0.15),
            rgba(136, 199, 255, 0.75)
        );
    }

    @keyframes driftY {
        from {
            background-position-y: 0;
        }
        to {
            /* background-position: 0 72px; */
            /* background-position: 36px 72px; */
            background-position-y: 72px;
        }
    }

    @keyframes driftX {
        0% {
            background-position-x: 0;
            animation-timing-function: ease-out;
        }
        25% {
            background-position-x: 72px;
            animation-timing-function: ease-in;
        }
        50% {
            background-position-x: 0px;
            animation-timing-function: ease-out;
        }
        75% {
            background-position: -72px;
            animation-timing-function: ease-in;
        }
        100% {
            background-position-x: 0px;
            animation-timing-function: ease-out;
        }
    }
</style>

<script is:inline>
    window.addEventListener("scroll", function () {
        const scrollPosition = window.scrollY;
        const background = document.getElementById("wallpaper");

        // Adjust the multiplier (0.5 in this case) to control the speed.
        // A value between 0 and 1 makes it move slower than the foreground.
        background.style.transform = `translateY(${scrollPosition * 0.5}px)`;
    });
</script>
