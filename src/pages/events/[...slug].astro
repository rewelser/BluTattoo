---
import Layout from "../../layouts/Layout.astro";
import PromoHero from "../../components/PromoHero.astro";
import {getCollection, getEntry, render} from "astro:content";
// import {fmtDateRange, fmtTimeWindow} from "../../domain/events/format.ts";
import SocialRow from "../../components/SocialRow.astro";
import HrDivider from "../../components/decor/HrDivider.astro";
import {getTransformedEventBySlug, loadTransformedEvents} from "../../domain/events/server.ts";
import EventDateRange from "../../components/EventDateRange.astro";
import EventTimeWindow from "../../components/EventTimeWindow.astro";
import {defaults} from "../../config/site.ts";
import ShareModal from "../../components/ShareModal.astro";
import {getImage, Image} from "astro:assets";
import {ImageGallery} from "../../components/ImageGalleryNoThumbs.tsx";

const branding = await getEntry("branding", "main");

export async function getStaticPaths() {
    const entries = await loadTransformedEvents();
    return entries.map((e) => ({params: {slug: e.id}}));
}

const {slug} = Astro.params;
if (!slug) throw new Error("Missing event id param");

const entry = await getTransformedEventBySlug(slug);
if (!entry) throw new Error(`Event not found: ${slug}`);

const {Content} = await render(entry);
const ev = entry.data;

// console.log("ev.image", ev.image);
// console.log("ev.href");
const description = `Learn more about the following event: ${ev.title}`;
const ogImage = ev.ogPhotoTexted ?? ev.ogPhotoTextless ?? ev.image ?? branding?.data.sitewideOGPhoto ?? defaults.ogPhoto;


const lightboxImages = await Promise.all(
    (entry.data.images ?? []).map(async (img, idx) => {
        const lightbox = await getImage({
            src: img,
            // widths: [720, 960, 1280, 1600],
            widths: [720, 1080, 1440, 1920, 2400, 2880],
            sizes: "100vw",
            format: "webp",
            quality: 80,
        });

        // currently not using this, but keeping for posterity:
        const thumb = await getImage({
            src: img,
            width: 640,
            format: "webp",
            quality: 70,
        });

        return {
            src: lightbox.src,
            thumbSrc: thumb.src,
            srcSet: lightbox.srcSet.attribute,
            sizes: "100vw",
            width: Number(lightbox.attributes.width),
            height: Number(lightbox.attributes.height),
            alt: `${entry.data.title} gallery image ${idx + 1}`,
        };
    })
);
---

<Layout title={ev.title} description={description} ogImage={ogImage}>
    <article class="page-article page-article--stack space-y-6">
        <h1 class="page-heading">{ev.title}</h1>

        {
            ev.image && (
                        <PromoHero isEventPage image={ev.image} alt={ev.alt ?? ev.title} className="p-8"/>
            )
        }

        <div id="event-details" data-section="event-details" class="border border-black/10 p-5 md:p-6">
            <div class="text-sm opacity-80">
                <!--{fmtDateRange(ev)}-->
                <EventDateRange ev={ev}/>
                {" • "}
                <!--{fmtTimeWindow(ev)}-->
                <EventTimeWindow ev={ev}/>
                {ev.location ? ` • ${ev.location}` : ""}
                <ShareModal shareTitle={ev.title} shareHero={ogImage} variant={2} shellClass="inline-block"
                            cardButtonClass="mx-2" cardRadius="0.375rem" variant2ShareText="share event"
                            heroFullBleed={true}/>
            </div>

            <div id="event-info" data-section="event-info" class="prose mt-4 max-w-none">
                <Content/>
            </div>
            {
                (() => {
                    const guest = ev.guestSpot;
                    const socials = guest?.contactSocialsBooking?.socials;
                    if (!socials) return null;

                    const guestNamePossessive = guest.guestName.endsWith("s") ? guest.guestName + "'" : guest.guestName + "'s";

                    return (
                            <>
                                <HrDivider className="opacity-20"/>
                                <div class="mt-4 text-center">
                                    <p class="text-sm font-medium">Check out
                                        <span
                                                class="font-semibold">{guestNamePossessive}
                                        </span>
                                        work here:
                                    </p>
                                    <div class="flex justify-center">
                                        <SocialRow
                                                links={socials}
                                                class="my-3"
                                        />
                                    </div>
                                </div>
                            </>
                    )
                })
            }
        </div>

        <!--//////////////-->


        {
            entry.data.images?.length && lightboxImages && (
                        <section aria-labelledby="gallery-heading" class="my-5">
                            <h2 id="gallery-heading"
                                class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl text-center">
                                Event Gallery
                            </h2>
                            <div class="flex items-end justify-between gap-4 mb-3 sm:mb-4 md:mb-5 lg:mb-7">
                                <p class="text-sm text-gray-600">
                                    Tap/click to view full size.
                                </p>


                                <p class="text-xs text-gray-500">
                                    {entry.data.images.length} photos
                                </p>
                            </div>

                            <div class="gallery py-2">
                                {entry.data.images.map((img, idx) => (
                                        <button
                                                type="button"
                                                class="gallery-item cursor-pointer"
                                                data-idx={idx}
                                                onclick={`window.dispatchEvent(new CustomEvent("open-lightbox", { detail: { index: ${idx} } }))`}
                                        >
                                            <Image
                                                    src={img}
                                                    widths={[240, 360, 480, 512, 720]}
                                                    sizes="auto, 100vw"
                                                    alt={`${entry.data.title} gallery image ${idx + 1}`}
                                                    loading="lazy"
                                                    decoding="async"
                                                    class="block w-full h-auto rounded-2xl shadow-md"
                                            />
                                        </button>
                                ))}
                                <style>
                                    .gallery {
                                        columns: 4 250px;
                                        column-gap: 1rem;
                                        @media (max-width: 640px) {
                                            column-count: 2;
                                            column-width: auto;
                                            column-gap: 0.75rem;
                                        }
                                    }

                                    .gallery-item {
                                        display: block;
                                        width: 100%;
                                        break-inside: avoid;
                                        margin-bottom: 1rem;

                                        padding: 0;
                                        border: 0;
                                        background: transparent;
                                        @media (max-width: 640px) {
                                            margin-bottom: 0.75rem;
                                        }
                                    }

                                    .gallery-item img {
                                        display: block;
                                        width: 100%;
                                        max-width: none;
                                        height: auto;

                                        border-radius: 16px;
                                        box-shadow: 0 4px 12px rgba(0, 0, 0, .15);
                                    }
                                </style>
                            </div>

                            <ImageGallery
                                    client:load
                                    images={lightboxImages}
                            />
                        </section>
            )
        }

        <p class="text-sm">
            <a class="underline hover:no-underline" href="/events">← Back to Events</a
            >
        </p>
    </article>
</Layout>
