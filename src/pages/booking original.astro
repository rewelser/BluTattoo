<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Star Drift Test</title>
    </head>
    <body>
        <main class="page">
            <!-- <div class="fixed"> -->
            <div
                id="wallpaper-gradient"
                class="wallpaper h-screen"
                aria-hidden="true"
            >
            </div>
            <div
                id="wallpaper-flash"
                class="wallpaper"
                aria-hidden="true"
                style={`background-image: url("${sickleDataUrl}")`}
            >
            </div>
            <!-- </div> -->
            <ul class="relative">
                {
                    artists2.map((artist) => (
                        <li>
                            <h2>{artist.data.name}</h2>
                            <p>ID: {artist.id}</p>
                            <p>Role: {artist.data.primary_role}</p>
                            <p>Active: {artist.data.active ? "yes" : "no"}</p>
                            <p>Guest: {artist.data.guest ? "yes" : "no"}</p>
                            <p>Order: {artist.data.order}</p>
                        </li>
                    ))
                }
            </ul>

            <section class="artist-tree" aria-labelledby="artist-tree-title">
                <h1 id="artist-tree-title" class="sr-only">Artists</h1>

                <ul class="artist-tree__list" data-accordion-root>
                    {
                        artists.map((artist, artistIndex) => {
                            const artistBtnId = `artist-${artistIndex}-toggle`;
                            const artistPanelId = `artist-${artistIndex}-panel`;

                            return (
                                <li class="artist-tree__item">
                                    <button
                                        id={artistBtnId}
                                        class="artist-tree__toggle"
                                        type="button"
                                        aria-expanded="false"
                                        aria-controls={artistPanelId}
                                        data-accordion-toggle
                                        data-accordion-level="root"
                                    >
                                        <div class="profile-image">
                                            {/* <Image src={entry.data.src} alt={entry.data.alt} /> */}
                                            {/* <img
                                            source={entry.data.src}
                                            ></img> */}
                                            <img
                                                src={
                                                    "/uploads/misc_images/hero-poster-red.jpg"
                                                }
                                                alt={`Portrait of ${entry.data.title}`}
                                                decoding="async"
                                                loading="eager"
                                                fetchpriority="high"
                                                class="h-full w-full object-cover"
                                            />
                                        </div>
                                        <span class="artist-tree__headline">
                                            <span class="artist-tree__name">
                                                {artist.name}
                                            </span>
                                        </span>

                                        <svg
                                            viewBox="0 0 24 24"
                                            aria-hidden="true"
                                            class="artist-tree__chevron"
                                        >
                                            <path
                                                fill="currentColor"
                                                d="M7 10l5 5 5-5H7z"
                                            />
                                        </svg>
                                    </button>

                                    <div
                                        id={artistPanelId}
                                        class="artist-tree__panel"
                                        aria-labelledby={artistBtnId}
                                        data-accordion-panel
                                        inert
                                    >
                                        <div class="artist-tree__panel-inner">
                                            <p class="artist-tree__bio">
                                                {artist.bio}
                                            </p>

                                            <ul class="artist-tree__sublist">
                                                {artist.bookingOptions.map(
                                                    (option, optionIndex) => {
                                                        if (
                                                            option.type ===
                                                            "link"
                                                        ) {
                                                            return (
                                                                <li class="artist-tree__subitem">
                                                                    <div class="artist-tree__linkblock">
                                                                        <a
                                                                            class="artist-tree__link"
                                                                            href={
                                                                                option.href
                                                                            }
                                                                            target="_blank"
                                                                            rel="noreferrer noopener"
                                                                        >
                                                                            {
                                                                                option.label
                                                                            }
                                                                        </a>
                                                                        <div class="artist-tree__subdesc">
                                                                            {
                                                                                option.description
                                                                            }
                                                                        </div>
                                                                    </div>
                                                                </li>
                                                            );
                                                        }

                                                        const subBtnId = `artist-${artistIndex}-sub-${optionIndex}-toggle`;
                                                        const subPanelId = `artist-${artistIndex}-sub-${optionIndex}-panel`;

                                                        return (
                                                            <li class="artist-tree__subitem">
                                                                <button
                                                                    id={
                                                                        subBtnId
                                                                    }
                                                                    class="artist-tree__subtoggle"
                                                                    type="button"
                                                                    aria-expanded="false"
                                                                    aria-controls={
                                                                        subPanelId
                                                                    }
                                                                    data-accordion-toggle
                                                                    data-accordion-level="nested"
                                                                >
                                                                    <span>
                                                                        <strong>
                                                                            {
                                                                                option.label
                                                                            }
                                                                        </strong>
                                                                        <span class="sr-only">
                                                                            {" "}
                                                                            —{" "}
                                                                            {
                                                                                option.summary
                                                                            }
                                                                        </span>
                                                                    </span>

                                                                    <svg
                                                                        viewBox="0 0 24 24"
                                                                        aria-hidden="true"
                                                                        class="artist-tree__chevron"
                                                                    >
                                                                        <path
                                                                            fill="currentColor"
                                                                            d="M7 10l5 5 5-5H7z"
                                                                        />
                                                                    </svg>
                                                                </button>

                                                                <div
                                                                    id={
                                                                        subPanelId
                                                                    }
                                                                    class="artist-tree__subpanel"
                                                                    aria-labelledby={
                                                                        subBtnId
                                                                    }
                                                                    data-accordion-panel
                                                                    inert
                                                                >
                                                                    <div class="artist-tree__widget-shell">
                                                                        <div class="artist-tree__subcontent">
                                                                            {
                                                                                option.content
                                                                            }
                                                                        </div>

                                                                        <div class="artist-tree__widget-placeholder">
                                                                            Future
                                                                            embed
                                                                            /
                                                                            widget
                                                                            /
                                                                            module
                                                                            placeholder
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </li>
                                                        );
                                                    },
                                                )}
                                            </ul>
                                        </div>
                                    </div>
                                </li>
                            );
                        })
                    }
                </ul>
            </section>

