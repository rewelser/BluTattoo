---
import {defaults} from "../config/site";
import {getEntry} from "astro:content";
// import type {ImageMetadata} from "astro";
import type {OgImage} from "../domain/decor/types.ts";
import {getOgImageSrc} from "../domain/decor/selectors.ts";

const {
    title,
    description,
    canonical,
    ogImage,

} = Astro.props as {
    title: string,
    description: string,
    canonical: string,
    ogImage: OgImage,

};

const imageSrc = getOgImageSrc(ogImage);

const site = await getEntry("siteInfo", "main");
const siteName = site?.data?.siteName ?? defaults.siteName;

// const imageUrl = new URL(ogImage, Astro.site ?? Astro.url.origin).toString();
const imageUrl = new URL(imageSrc, Astro.site ?? Astro.url.origin).toString();

---
<>
    <meta property="og:title" content={title}/>
    <meta property="og:description" content={description}/>
    <meta property="og:url" content={canonical}/>
    <meta property="og:type" content="website"/>
    <meta property="og:image" content={imageUrl}/>
    <meta property="og:image:alt" content={title} />
    <meta property="og:site_name" content={siteName}/>
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image"/>
    <meta name="twitter:title" content={title}/>
    <meta name="twitter:description" content={description}/>
    <meta name="twitter:image" content={imageUrl}/>
    <meta name="twitter:image:alt" content={title} />
</>