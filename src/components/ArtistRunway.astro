---
import type {ImageMetadata} from "astro";
import {loadActiveArtists} from "../domain/people/server.ts";
import {loadUpcomingGuestSpotCandidates} from "../domain/events/selectors.ts";
import ArtistCard from "./ArtistCard.astro";
import {fmtDateRange} from "../domain/events/format.ts";


let artists = await loadActiveArtists();
const guestSpotEvents = await loadUpcomingGuestSpotCandidates(new Date());
const primaryRole = "Tattoo Artist";
const seen = new Set<string>();
const guestArtists = guestSpotEvents
    .filter(ev => ev.guestSpot.primaryRole === primaryRole)
    .filter((ev) => {
        if (seen.has(ev.guestSpot.guestName)) {
            return false;
        }
        seen.add(ev.guestSpot.guestName);
        return true;
    });


// Same visual width as:
// grid grid-cols-1 gap-6 sm:grid-cols-2 xl:grid-cols-3
const cardSlotClass =
    "w-full sm:w-[calc((100%-1.5rem)/2)] xl:w-[calc((100%-3rem)/3)]";
---
<>
    {guestArtists.length > 0 && (
            <section class="mt-8">
                <div class="flex flex-wrap justify-around gap-6">
                    {guestArtists.map((guest) => {
                        const spot = guest.guestSpot;
                        const dateRange = fmtDateRange(guest);
                        return (
                                <a
                                        href={`/events/${guest.id}`}
                                        class={`relative block ${cardSlotClass}`}
                                >
                                    <ArtistCard
                                            personPhoto={spot.runwayPhoto}
                                            personName={spot.guestName}
                                            photoAlt={spot.guestName}
                                            frameType={spot.runwayPhotoFrame}
                                            isGuestSpot={true}
                                            guestSpotDateRange={dateRange}
                                    />
                                </a>
                        );
                    })}
                </div>
            </section>
    )}

    <section class="mt-8">
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 xl:grid-cols-3">
            {artists.map((artist) => {
                return (
                        <a
                                href={`/artists/${artist.id}`}
                                class="relative overflow-visible"
                        >
                            <ArtistCard
                                    personPhoto={artist.data.runwayPhoto}
                                    personName={artist.data.name}
                                    photoAlt={artist.data.name}
                                    frameType={artist.data.runwayPhotoFrame}
                            />
                        </a>
                );
            })}
        </div>
    </section>

    <script is:inline>
        const cards = document.querySelectorAll("[data-person-card-container]");

        const loadCard = async (card) => {
            const photo = card.querySelector("[data-person-card-photo]");
            const frame = card.querySelector("[data-person-card-frame]");

            const photoReady =
                photo?.complete ||
                new Promise((resolve) => {
                    photo?.addEventListener("load", resolve, {once: true});
                    photo?.addEventListener("error", resolve, {once: true});
                });

            const frameReady = new Promise((resolve) => {

                if (frame) {
                    const frameSrc = frame.dataset.personCardFrameSrc;
                    frame.addEventListener("load", resolve, {once: true});
                    frame.addEventListener("error", resolve, {once: true});
                    frame.src = frameSrc;
                } else {
                    resolve();
                }
            });

            await Promise.all([photoReady, frameReady]);

            card.dataset.ready = "true";
        };

        const observer = new IntersectionObserver(
            (entries) => {
                for (const entry of entries) {
                    if (!entry.isIntersecting) continue;

                    observer.unobserve(entry.target);
                    loadCard(entry.target);
                }
            },
            {
                // rootMargin: "400px 0px",
                threshold: 0.5,
            }
        );

        cards.forEach((card) => observer.observe(card));
    </script>


    <style is:global>
        .person-card-container {
            opacity: 0;
            position: relative;
            transition: opacity 7000ms cubic-bezier(.2, .8, .2, 1);
        }

        .person-card-container[data-ready="true"] {
            opacity: 1;
        }

        [data-person-card-frame] {
            opacity: 0;
            transition: opacity 10s cubic-bezier(.2, .8, .2, 1);
        }

        .person-card-container[data-ready="true"] [data-person-card-frame] {
            opacity: .3;
        }

        .person-card {
            aspect-ratio: 4 / 5;
            //width: 397.6px;
            //height: 500px;
        }

        .applied-mask--frameclip {
            mask-position: center;
            mask-size: contain;
            mask-repeat: no-repeat;
            mask-mode: alpha;

            -webkit-mask-position: center;
            -webkit-mask-size: contain;
            -webkit-mask-repeat: no-repeat;
        }
    </style>

</>



