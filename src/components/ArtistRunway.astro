---
import type {ImageMetadata} from "astro";
import {loadActiveArtists} from "../domain/people/server.ts";
import {loadUpcomingGuestSpotCandidates} from "../domain/events/selectors.ts";
import ArtistCard from "./ArtistCard.astro";
import {fmtDateRange} from "../domain/events/format.ts";


let artists = await loadActiveArtists();
const guestSpotEvents = await loadUpcomingGuestSpotCandidates(new Date());
const primaryRole = "Tattoo Artist";
const seen = new Set<string>();
const guestArtists = guestSpotEvents
    .filter(ev => ev.guestSpot[0].primaryRole === primaryRole)
    .filter((ev) => {
        if (seen.has(ev.guestSpot[0].guestName)) {
            return false;
        }
        seen.add(ev.guestSpot[0].guestName);
        return true;
    });


// Same visual width as:
// grid grid-cols-1 gap-6 sm:grid-cols-2 xl:grid-cols-3
const cardSlotClass =
    "w-full sm:w-[calc((100%-1.5rem)/2)] xl:w-[calc((100%-3rem)/3)]";
---
<>
    {guestArtists.length > 0 && (
            <section class="mt-8">
                <div class="flex flex-wrap justify-around gap-6">
                    {guestArtists.map((guest) => {
                        const spot = guest.guestSpot[0];
                        const dateRange = fmtDateRange(guest);
                        return (
                                <a
                                        href={`/events/${guest.id}`}
                                        class={`relative block ${cardSlotClass}`}
                                >
                                    <ArtistCard
                                            personPhoto={spot.runwayPhoto}
                                            personName={spot.guestName}
                                            photoAlt={spot.guestName}
                                            frameType={spot.runwayPhotoFrame}
                                            isGuestSpot={true}
                                            guestSpotDateRange={dateRange}
                                    />
                                </a>
                        );
                    })}
                </div>
            </section>
    )}

    <section class="mt-8">
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 xl:grid-cols-3">
            {artists.map((artist) => {
                return (
                        <a
                                href={`/artists/${artist.id}`}
                                class="relative overflow-visible"
                        >
                            <ArtistCard
                                    personPhoto={artist.data.runwayPhoto}
                                    personName={artist.data.name}
                                    photoAlt={artist.data.name}
                                    frameType={artist.data.runwayPhotoFrame}
                            />
                        </a>
                );
            })}
        </div>
    </section>


    <style is:global>
        .person-card-container {
            opacity: 1;
            transition: opacity 5s cubic-bezier(.2, .8, .2, 1);
            @starting-style {
                opacity: 0;
            }
        }

        .person-card,
        .framed-person-card {
            aspect-ratio: 4 / 5;
            //width: 397.6px;
            //height: 500px;
        }

        [data-frame] {
            opacity: .3;
            transition: opacity 10s cubic-bezier(.2, .8, .2, 1);
            @starting-style {
                opacity: 0;
            }
        }

        .applied-mask--frameclip {
            mask-position: center;
            mask-size: contain;
            mask-repeat: no-repeat;
            mask-mode: alpha;

            -webkit-mask-position: center;
            -webkit-mask-size: contain;
            -webkit-mask-repeat: no-repeat;
        }
    </style>

</>



