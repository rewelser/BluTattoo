---
interface Props {
  image: string;
  alt?: string;
  className?: string;
}

const { image, alt = "", className = "" } = Astro.props;
---

<section class={`relative overflow-hidden shadow-lg ${className}`}>
  <div data-skeleton-image class="skeleton-promo-hero-image h-[70vh]"></div>
  <!-- had used onload below, but onload fires only after image fully loads, not before paint(?) adds it to layout -->
  <!-- onload="this.classList.remove('opacity-0'); this.previousElementSibling.remove();" -->
  <img
    data-promo-image
    src={image}
    alt={alt}
    class="w-full h-auto hidden opacity-0 transition-opacity duration-300"
    loading="eager"
    fetchpriority="high"
    decoding="sync"
  />

  <!-- gradient overlay -->
  <!-- <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent"></div> -->
</section>

<script is:inline>
  async function initPromoImage(img) {
    console.log("i1");
    const skeleton = img.parentElement?.querySelector("[data-skeleton-image]");
    if (!skeleton) return;

    const reveal = async () => {
      try {
        await img.decode();
      } catch {}

      requestAnimationFrame(() => {
        img.classList.remove("hidden");
        skeleton.remove();

        requestAnimationFrame(() => {
          img.classList.remove("opacity-0");
        });
      });
    };

    if (img.complete) {
      reveal();
      console.log("fishfish");
    } else {
      img.addEventListener("load", reveal, { once: true });
    }
  }

  document.querySelectorAll("[data-promo-image]").forEach(initPromoImage);
</script>
