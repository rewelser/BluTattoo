---
interface Props {
  image: string;
  alt?: string;
  className?: string;
}

const { image, alt = "", className = "" } = Astro.props;
---

<!-- todo: fix this up -->
<section class={`relative overflow-hidden shadow-lg min-h-[70vh] ${className}`}>
  <div class="skeleton-promo-hero-img absolute inset-0 p-inherit"></div>
  <img
    src={image}
    alt={alt}
    class="w-full h-auto absolute inset-0 h-full w-full object-scale-down p-inherit"
    loading="eager"
    fetchpriority="high"
    decoding="sync"
    onloadstart="console.log('fishfishfish');"
    onload="this.classList.remove('opacity-0'); this.previousElementSibling.remove();"
  />

  <!-- gradient overlay -->
  <!-- <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent"></div> -->
</section>
