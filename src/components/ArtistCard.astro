---
import {frameRegistry, type FrameKey} from "./decor/frameportraits/frameclips/registry.ts";
import SparkleCorners from "./decor/SparkleCorners.astro";
import type {ImageMetadata} from "astro";
import {defaults} from "../config/site.ts";

import GuestSpotCardInfoBanner from "./decor/GuestSpotCardInfoBanner.astro";

interface Props {
    personPhoto: ImageMetadata | undefined;
    personName: string;
    primaryRole?: string;
    photoAlt: string;
    frameType?: FrameKey;
    isGuestSpot?: boolean;
    guestSpotDateRange?: string;
    class?: string;
}

const {
    personPhoto,
    personName,
    primaryRole = "Tattoo Artist",
    photoAlt,
    frameType,
    isGuestSpot,
    guestSpotDateRange,
    class: className = "",
} = Astro.props;

const frameConfig = frameType ? frameRegistry[frameType] : undefined;

const defaultPersonRunwayPhoto = defaults.personRunwayPhoto;
---
<div
        class="person-card-container"
        data-person-card-container
>
    {isGuestSpot &&
            <GuestSpotCardInfoBanner
                    primaryRole={primaryRole}
                    dateRange={guestSpotDateRange}
            />
    }
    <div class="relative">
        <div
                class={`person-card group relative overflow-hidden rounded-2xl ${className}`}
        >
            {!frameConfig ?
                (
                        <>
                            <img
                                    src={personPhoto?.src ?? defaultPersonRunwayPhoto}
                                    alt={photoAlt}
                                    data-person-card-photo
                                    loading="lazy"
                                    decoding="async"
                                    class="object-cover transition-transform duration-300 group-hover:scale-105"
                            />
                        </>
                ) : (
                            <>
                                <div
                                        class="applied-mask--frameclip h-full w-full"
                                        style={`mask-image: url("${frameConfig.mask.src}"); -webkit-mask-image: url("${frameConfig.mask.src}");`}
                                >
                                    <img
                                            src={personPhoto?.src ?? defaultPersonRunwayPhoto}
                                            alt={photoAlt}
                                            data-person-card-photo
                                            loading="lazy"
                                            decoding="async"
                                            class="absolute object-cover transition-transform duration-300 group-hover:scale-105"
                                    />
                                </div>

                                <img
                                        alt=""
                                        data-frame
                                        data-person-card-frame
                                        data-person-card-frame-src={frameConfig.frame.src}
                                        loading="lazy"
                                        decoding="async"
                                        class="absolute inset-0 h-full w-full pointer-events-none"
                                        aria-hidden="true"
                                />
                                <frameConfig.FrameClipComponent/>

                                <script is:inline>
                                    (() => {
                                        const root = document.currentScript.parentElement;
                                        const shape = root.querySelector("[data-frame-window]");
                                        const photo = root.querySelector("[data-person-card-photo]");

                                        function syncPhotoToWindow() {
                                            const shapeRect = shape.getBoundingClientRect();
                                            const wrapperRect = root.getBoundingClientRect();

                                            photo.style.top = `${shapeRect.top - wrapperRect.top}px`;
                                            photo.style.left = `${shapeRect.left - wrapperRect.left}px`;
                                            photo.style.width = `${shapeRect.width}px`;
                                            photo.style.height = `${shapeRect.height}px`;
                                        }

                                        const ro = new ResizeObserver(syncPhotoToWindow);
                                        ro.observe(root);

                                        if (photo.complete) {
                                            syncPhotoToWindow();
                                        } else {
                                            photo.addEventListener("load", syncPhotoToWindow, {once: true});
                                        }

                                        window.addEventListener("load", syncPhotoToWindow, {once: true});
                                    })()
                                </script>
                            </>

                )
            }
        </div>
        {isGuestSpot && (
                <SparkleCorners
                        color="black"
                        fillColor="gold"
                        size={24}
                        gap={16}
                        offset={-40}
                />
        )}
    </div>
    <p class="mt-3 text-center text-base font-medium tracking-wide">
        {personName}
    </p>
</div>