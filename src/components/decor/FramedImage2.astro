---
import type {ImageSourceOrMetadata} from "../../domain/decor/types.ts";
import {getImageSrc} from "../../domain/decor/selectors.ts";
import type {ImageMetadata} from "astro";
import type {SvgComponent} from "astro/types";

interface Props {
    kind?: "image" | "video";
    frame: ImageMetadata;
    framedImage: ImageMetadata;
    frameMask: SvgComponent;
    photoAlt: string;
    class?: string;

    autoplay?: boolean;
    muted?: boolean;
    loop?: boolean;
    playsinline?: boolean;
    controls?: boolean;
    preload?: "none" | "metadata" | "auto";
    poster?: ImageMetadata;
}

const {
    kind = "video",
    frame,
    framedImage,
    frameMask: FrameMask,
    photoAlt,
    class: className = "",

    autoplay = false,
    muted = true,
    loop = true,
    playsinline = true,
    controls = false,
    preload = "metadata",
    poster,
} = Astro.props;

const frameUsed = getImageSrc(frame);

const frameAspectRatio = typeof frame === "object" && "width" in frame && "height" in frame ? `${frame.width} / ${frame.height}` : undefined;

const posterUsed = poster?.src ?? framedImage.src;
const videoSrc = "/uploads/misc_videos/fartists3-web.mp4";
const videoSrcMobile = "/uploads/misc_videos/fartists3-mobile-portrait.mp4";
---
<>
    <div data-framed-image-container class={`relative overflow-hidden rounded-2xl ${className}`}>
        <div
                class="frame-mask h-full w-full"
                style={`mask-image: url("${FrameMask.src}"); -webkit-mask-image: url("${FrameMask.src}");`}
        >
            {
                kind === "video" ? (
                        <video
                                data-framed-image
                                class="absolute object-cover transition-transform duration-300"
                                autoplay={autoplay}
                                muted={muted}
                                loop={loop}
                                playsinline={playsinline}
                                controls={controls}
                                preload={preload}
                                poster={posterUsed}
                        >
                            <source
                                    src={videoSrcMobile}
                                    media="(max-width: 640px)"
                                    type="video/mp4"
                            />
                            <source
                                    src={videoSrc}
                                    type="video/mp4"
                            />
                        </video>
                ) : (
                        <img
                                src={framedImage.src}
                                alt={photoAlt}
                                data-framed-image
                                loading="lazy"
                                decoding="async"
                                class="absolute object-cover transition-transform duration-300"
                        />
                )
            }
        </div>

        <img
                alt=""
                data-frame
                data-frame-src={frameUsed}
                loading="lazy"
                decoding="async"
                class="absolute inset-0 h-full w-full object-contain pointer-events-none"
                aria-hidden="true"
        />

        <FrameMask class="absolute inset-0 h-full w-full opacity-0 pointer-events-none" data-frame-window/>

        <script define:vars={{frameAspectRatio, kind}}>
            (() => {
                const root = document.currentScript.closest("[data-framed-image-container]");
                // const shape = root.querySelector("[data-frame-window]");
                const shape = root.querySelector("[data-frame-window] path");
                const media = root.querySelector("[data-framed-image]");
                const frame = root.querySelector("[data-frame]");
                let hasLoaded = false;

                const loadFrameAndMedia = async () => {
                    if (hasLoaded) return;
                    hasLoaded = true;

                    const mediaReady = !media
                        ? Promise.resolve()
                        : kind === "video"
                            ? (
                                media.readyState >= 1
                                    ? Promise.resolve()
                                    : new Promise((resolve) => {
                                        media.addEventListener("loadedmetadata", resolve, {once: true});
                                        media.addEventListener("canplay", resolve, {once: true});
                                        media.addEventListener("error", resolve, {once: true});
                                    })
                            )
                            :
                            media.complete ? Promise.resolve()
                                : new Promise((resolve) => {
                                    media.addEventListener("load", resolve, {once: true});
                                    media.addEventListener("error", resolve, {once: true});
                                });

                    const frameReady = new Promise((resolve) => {
                        const frameSrc = frame?.dataset.frameSrc;

                        if (!frame || !frameSrc) {
                            resolve();
                            return;
                        }

                        frame.addEventListener("load", resolve, {once: true});
                        frame.addEventListener("error", resolve, {once: true});
                        frame.src = frameSrc;
                    });

                    await Promise.all([mediaReady, frameReady]);

                    root.dataset.ready = "true";
                };

                const observer = new IntersectionObserver(
                    async ([entry]) => {
                        if (entry.isIntersecting) {
                            // observer.unobserve(entry.target);
                            await loadFrameAndMedia(entry.target);
                            if (kind === "video") {
                                media.play?.().catch(() => {});
                            }
                        } else {
                            if (kind === "video") {
                                media.pause?.();
                            }
                        }
                    },
                    {
                        threshold: 0.1,
                    }
                );

                observer.observe(root);

                function syncMediaToWindow() {
                    const shapeRect = shape.getBoundingClientRect();
                    const wrapperRect = root.getBoundingClientRect();

                    media.style.top = `${shapeRect.top - wrapperRect.top}px`;
                    media.style.left = `${shapeRect.left - wrapperRect.left}px`;
                    media.style.width = `${shapeRect.width}px`;
                    media.style.height = `${shapeRect.height}px`;
                }

                function syncAspectRatioToFrame() {
                    root.style.aspectRatio = frameAspectRatio ||
                        (frame?.naturalWidth && frame?.naturalHeight
                            ? `${frame.naturalWidth} / ${frame.naturalHeight}`
                            : ".65");
                }

                function visualSync() {
                    syncAspectRatioToFrame();
                    syncMediaToWindow();
                }

                const ro = new ResizeObserver(visualSync);
                ro.observe(root);

                if (kind === "video") {
                    if (media.readyState >= 1) {
                        visualSync();
                    } else {
                        media.addEventListener("loadedmetadata", visualSync, { once: true });
                        media.addEventListener("canplay", visualSync, { once: true });
                    }
                } else if (media.complete) {
                    visualSync();
                } else {
                    media.addEventListener("load", visualSync, {once: true});
                }

                if (frame?.complete) {
                    visualSync();
                } else {
                    frame?.addEventListener("load", visualSync, {once: true});
                }

                window.addEventListener("load", visualSync, {once: true});
            })()
        </script>
    </div>
    <style>
        [data-framed-image-container] {
            opacity: 0;
            position: relative;
            transition: opacity 3000ms cubic-bezier(.2, .8, .2, 1);
        }

        [data-framed-image-container][data-ready="true"] {
            opacity: 1;
        }

        [data-framed-image-container][data-ready="true"] [data-frame] {
            opacity: .8;
        }

        .frame-mask {
            mask-position: center;
            mask-size: contain;
            mask-repeat: no-repeat;
            mask-mode: alpha;

            -webkit-mask-position: center;
            -webkit-mask-size: contain;
            -webkit-mask-repeat: no-repeat;
        }
    </style>
</>