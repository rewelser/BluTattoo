---
type SideImage = { src: string; alt?: string };

type SideImages = {
  left: [SideImage, SideImage];
  right: [SideImage, SideImage];
};

type Props = {
  id?: string;
  images: string[]; // top -> bottom
  sideImages?: SideImages;
  heightVh?: number;
  class?: string;
  imgClass?: string;
  openStartVh?: number; // default 0.8
  peelFrac?: number; // default 0.75
};

const {
  id = "scroll-peel",
  images,
  sideImages,
  heightVh = 400,
  class: className = "",
  imgClass = "",
  openStartVh = 0.8,
  peelFrac = 0.75,
} = Astro.props as Props;

if (!images || images.length < 2) {
  throw new Error("ScrollPeelStack.astro requires at least 2 images.");
}
if (peelFrac <= 0 || peelFrac >= 1) {
  throw new Error("ScrollPeelStack.astro: peelFrac must be between 0 and 1.");
}

const bottomIndex = images.length - 1;
const bottomSrc = images[bottomIndex];
const peelLayers = images.slice(0, bottomIndex);
const phases = peelLayers.length;

const sides: SideImages =
  sideImages ?? {
    left: [
      { src: "/uploads/misc_images/hero-poster.jpg", alt: "Left image 1" },
      { src: "/uploads/misc_images/hero-poster-red.jpg", alt: "Left image 2" },
    ],
    right: [
      { src: "/uploads/misc_images/hero-poster.jpg", alt: "Right image 1" },
      { src: "/uploads/misc_images/hero-poster-red.jpg", alt: "Right image 2" },
    ],
  };
---

<section id={id} class="relative" style={`height:${heightVh}vh;`}>
  <!-- Sticky occupies full viewport; the "frame" is an inner absolute box -->
  <div class="sticky top-0 h-screen w-full">
    <!-- FRAME: this is your deterministic "m-2" -->
    <div
      data-peel-frame
      class="absolute inset-2 overflow-hidden rounded-xl border border-white/15 bg-black/0"
    >
      <!-- Scene root: everything should size to the frame -->
      <div class="relative h-full w-full">
        <!-- Grid exists the whole time (like the reference site) -->
        <div data-peel-reveal
          class="grid h-full w-full grid-cols-3 items-center gap-x-1 sm:gap-x-2 border-2 border-solid border-orange-500 py-50 sm:py-40 md:py-30 lg:py-10 sm:px-10 md:px-20 lg:px-50 overflow-hidden min-width-[500px]"
        >
          <!-- LEFT COLUMN -->
          <div class="flex h-full flex-col justify-start gap-1 sm:gap-2 border-2 border-solid border-green-500">
            <div
              data-side="l1"
              class="opacity-0 pointer-events-none"
              style="transform: translate(-120%, 80%); will-change: transform, opacity;"
            >
              <img
                src={sides.left[0].src}
                alt={sides.left[0].alt ?? ""}
                class="rounded-lg md:rounded-xl object-cover"
                loading="lazy"
                decoding="async"
              />
            </div>

            <div
              data-side="l2"
              class="opacity-0 pointer-events-none pl-10"
              style="transform: translate(-120%, 80%); will-change: transform, opacity;"
            >
              <img
                src={sides.left[1].src}
                alt={sides.left[1].alt ?? ""}
                class="rounded-lg md:rounded-xl object-cover"
                loading="lazy"
                decoding="async"
              />
            </div>
          </div>

          <!-- CENTER COLUMN -->
          <div class="h-full py-10">
            <div
              data-center-shell
              class="relative h-full overflow-visible flex items-center justify-center border-2 border-solid border-green-500"
            >
              <!-- Peel reveal now fills the FRAME (not the viewport) -->
              <div
                
                class="absolute inset-0 overflow-hidden pointer-events-none border-2 border-solid border-purple-500"
              >
                <div
                  data-peel-stage
                  class={`relative h-full w-full ${className}`}
                  style="clip-path: inset(0 50% 0 50% round 8px); will-change: clip-path;"
                >
                  <div
                    data-peel-scale
                    class="absolute inset-0 will-change-transform"
                    style="transform: scale(1); transform-origin: 50% 50%;"
                  >
                    <!-- Bottom (always visible) -->
                    <img
                      src={bottomSrc}
                      alt=""
                      class={`absolute inset-0 w-full h-full object-cover ${imgClass}`}
                      style="z-index:0;"
                      loading="eager"
                      decoding="async"
                    />

                    <!-- Peel layers top -> down with explicit z-index -->
                    {
                      peelLayers.map((src, i) => {
                        const z = phases - i;
                        return (
                          <img
                            src={src}
                            alt=""
                            class={`absolute inset-0 w-full h-full object-cover will-change-[clip-path] ${imgClass}`}
                            style={`clip-path: inset(0 0 0 0); z-index:${z};`}
                            data-peel-layer
                            loading="eager"
                            decoding="async"
                          />
                        );
                      })
                    }
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- RIGHT COLUMN -->
          <div class="flex h-full flex-col justify-end gap-1 sm:gap-2 items-end border-2 border-solid border-green-500">
            <div
              data-side="r1"
              class="opacity-0 pointer-events-none pr-10"
              style="transform: translate(120%, 80%); will-change: transform, opacity;"
            >
              <img
                src={sides.right[0].src}
                alt={sides.right[0].alt ?? ""}
                class="rounded-lg md:rounded-xl object-cover"
                loading="lazy"
                decoding="async"
              />
            </div>

            <div
              data-side="r2"
              class="opacity-0 pointer-events-none"
              style="transform: translate(120%, 80%); will-change: transform, opacity;"
            >
              <img
                src={sides.right[1].src}
                alt={sides.right[1].alt ?? ""}
                class="rounded-lg md:rounded-xl object-cover"
                loading="lazy"
                decoding="async"
              />
            </div>
          </div>
        </div>

        <!-- Script at end of sticky so it sees all columns -->
        <script define:vars={{ id, phases, openStartVh, peelFrac }}>
          (() => {
            const section = document.getElementById(id);
            if (!section) return;

            const stage = section.querySelector("[data-peel-stage]");
            const centerShell = section.querySelector("[data-center-shell]");
            const layers = Array.from(section.querySelectorAll("[data-peel-layer]"));
            const sideEls = Array.from(section.querySelectorAll("[data-side]"));
            const scaleWrap = section.querySelector("[data-peel-scale]");
            if (!stage || !centerShell || !scaleWrap) return;

            const clamp01 = (n) => Math.max(0, Math.min(1, n));
            const lerp = (a, b, t) => a + (b - a) * t;
            const ramp = (t, t0, t1) => clamp01((t - t0) / (t1 - t0));

            // --- Visual knobs ---
            const exitScale = 0.6;
            const scaleLead = 0.0;
            const scaleFinish = 0.6;

            // Radius: 8px under md, 12px at md+
            const radiusSm = 8;
            const radiusMd = 12;
            const isMd = () => window.matchMedia("(min-width: 768px)").matches;

            const sideTimings = {
              l1: [0.12, 0.55],
              r1: [0.18, 0.6],
              l2: [0.3, 0.78],
              r2: [0.36, 0.85],
            };

            let exitFinal = { top: 0, right: 0, bottom: 0, left: 0 };

            const computeExitInsetsPx = () => {
              const shell = centerShell.getBoundingClientRect();
              const s = stage.getBoundingClientRect();

              const top = shell.top - s.top;
              const left = shell.left - s.left;
              const right = s.right - shell.right;
              const bottom = s.bottom - shell.bottom;

              exitFinal = {
                top: Math.max(0, top),
                left: Math.max(0, left),
                right: Math.max(0, right),
                bottom: Math.max(0, bottom),
              };
            };

            requestAnimationFrame(computeExitInsetsPx);

            let rafId = 0;

            const update = () => {
              rafId = 0;

              const r = section.getBoundingClientRect();
              const vh = window.innerHeight || 1;

              // OPENING
              const startPx = vh * openStartVh;
              const openT = clamp01((startPx - r.top) / (startPx || 1));
              const openSidePct = (1 - openT) * 50;

              // SCENE TIMELINE
              const scrollable = r.height - vh;
              const traveled = Math.max(0, -r.top);
              const tScene = clamp01(traveled / (scrollable || 1));

              const peelT = clamp01(tScene / peelFrac);
              const exitT = clamp01((tScene - peelFrac) / (1 - peelFrac));

              // CLIP
              const shrinkT = ramp(exitT, 0.0, 0.6);
              const rPx = isMd() ? radiusMd : radiusSm;

              if (shrinkT <= 0.0001) {
                stage.style.clipPath = `inset(0 ${openSidePct.toFixed(3)}% 0 ${openSidePct.toFixed(3)}% round ${rPx}px)`;
              } else {
                computeExitInsetsPx();

                const top = lerp(0, exitFinal.top, shrinkT);
                const right = lerp(0, exitFinal.right, shrinkT);
                const bottom = lerp(0, exitFinal.bottom, shrinkT);
                const left = lerp(0, exitFinal.left, shrinkT);

                stage.style.clipPath = `inset(${top.toFixed(2)}px ${right.toFixed(2)}px ${bottom.toFixed(2)}px ${left.toFixed(2)}px round ${rPx}px)`;
              }

              // SCALE (optional)
              const scaleT = ramp(exitT, scaleLead, scaleFinish);
              const sVal = lerp(1, exitScale, scaleT);
              // scaleWrap.style.transform = `scale(${sVal.toFixed(4)})`;

              // PEELING
              for (let i = 0; i < phases; i++) {
                const img = layers[i];
                if (!img) continue;

                const start = i / phases;
                const local = clamp01((peelT - start) * phases);
                img.style.clipPath = `inset(0 0 ${(local * 100).toFixed(3)}% 0)`;
              }

              // SIDE ENTRANCE
              for (const el of sideEls) {
                const key = el.getAttribute("data-side") || "";
                const timing = sideTimings[key];
                const tIn = timing ? ramp(exitT, timing[0], timing[1]) : exitT;

                const isLeft = key.startsWith("l");
                const dir = isLeft ? -1 : 1;

                const rectW = el.getBoundingClientRect().width || 0;
                const off = rectW + 80;

                const x = lerp(dir * off, 0, tIn);
                const y = lerp(off, 0, tIn);
                const o = lerp(0, 1, tIn);

                el.style.transform = `translate(${x.toFixed(2)}px, ${y.toFixed(2)}px)`;
                el.style.opacity = String(o);
              }
            };

            const onScroll = () => {
              if (rafId) return;
              rafId = requestAnimationFrame(update);
            };

            const onResize = () => {
              requestAnimationFrame(() => {
                computeExitInsetsPx();
                onScroll();
              });
            };

            window.addEventListener("scroll", onScroll, { passive: true });
            window.addEventListener("resize", onResize);

            update();

            document.addEventListener(
              "astro:before-swap",
              () => {
                window.removeEventListener("scroll", onScroll);
                window.removeEventListener("resize", onResize);
                if (rafId) cancelAnimationFrame(rafId);
              },
              { once: true }
            );
          })();
        </script>
      </div>
    </div>
  </div>
</section>