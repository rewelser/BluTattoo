---
/**
    * ParallaxWindow (image OR video)
    * - src: media url
    * - windowHeight: CSS height for the "window" (default 35vh)
    * - strength: how much slower than scroll (0.2 subtle, 0.35 stronger)
    * - bleed: extra pixels above/below to prevent gaps (auto if not provided)
    *
    * Video notes:
    * - For mobile autoplay: muted + playsinline are important.
    */

import type {ImageMetadata} from "astro";
import SmartMedia from "./SmartMedia.astro";

export interface Props {
    image?: ImageMetadata;
    vidSrcMobile?: string;
    vidSrcDesktop?: string;
    alt?: string; // only used for images
    windowHeight?: string;
    windowHeightMobile?: string;
    mediaHeightMult?: number;
    mediaHeightMultMobile?: number;
    useMinMediaHeight?: boolean;
    strength?: number;
    bleed?: number;
    strengthMobile?: number;
    bleedMobile?: number;
    class?: string;
    layerClass?: string;

    // video extras (optional)
    autoplay?: boolean;
    muted?: boolean;
    loop?: boolean;
    playsinline?: boolean;
    controls?: boolean;
    preload?: "none" | "metadata" | "auto";
    poster?: string;
}

const {
    image,
    alt = "",

    vidSrcMobile,
    vidSrcDesktop,
    poster,

    windowHeight = "35vh",
    windowHeightMobile,
    mediaHeightMult = 2,
    mediaHeightMultMobile = 2,
    useMinMediaHeight = true,
    strength = 0.28,
    bleed,
    strengthMobile,
    bleedMobile,
    class: className = "",
    layerClass,

} = Astro.props;
---

<div
        data-pw
        class={`pw ${className}`}
        data-strength={strength}
        data-strength-mobile={strengthMobile ?? ""}
        data-bleed={bleed ?? ""}
        data-bleed-mobile={bleedMobile ?? ""}
>
    <div class={`pw__layer ${layerClass}`} aria-hidden="true">
        <SmartMedia
                data-pw-media
                mediaClass="pw__media"
                observeTargetSelector="[data-pw]"
                imageAttrs={image
                    ? {
                        src: image,
                        sizes: "auto",
                        loading: "lazy",
                        decoding: "async",
                        alt: alt
                    } : undefined
                }

                videoAttrs={{
                    videoSrcDesktop: vidSrcDesktop,
                    videoSrcMobile: vidSrcMobile,
                    loading: "lazy",
                }}
        />
    </div>

    <div class="pw__content">
        <slot/>
    </div>
    <style define:vars={{windowHeight, mobileWindowHeight: windowHeightMobile ?? windowHeight}}>
        .pw {
            position: relative;
            height: var(--windowHeight);
            overflow: hidden;
        }

        @media (max-width: 640px) {
            .pw {
                height: var(--mobileWindowHeight);
            }
        }

        .pw__layer {
            position: absolute;
            inset: 0;
            will-change: transform;
            transform: translate3d(0, 0, 0);
        }

        /* shared for img/video */
        .pw :global(.pw__media) {
            position: absolute;
            left: 50%;
            top: 50%;
            width: 100%;
            height: 100%;
            transform: translate3d(-50%, -50%, 0);
            object-fit: cover;
            backface-visibility: hidden;
            -webkit-transform-style: preserve-3d;
        }

        .pw__content {
            position: relative;
            z-index: 1;
            height: 100%;
            display: grid;
            place-items: center;
            /*pointer-events: none;*/
        }
    </style>

    <script define:vars={{
        desktopStr: strength,
        mobileStr: strengthMobile ?? null,
        desktopBleed: bleed ?? null,
        mobileBleed: bleedMobile ?? null,
        mediaHeightMult,
        mediaHeightMultMobile,
        useMinMediaHeight
    }}>
        (() => {
            // No-scroll-listener version:
            // - IntersectionObserver toggles active
            // - While active, we run a continuous rAF loop
            const root = document.currentScript?.closest("[data-pw]"); // the .pw div

            if (!(root instanceof HTMLElement)) {
                // no-op
            } else {
                const layer = root.querySelector(".pw__layer");
                const media = root.querySelector("[data-pw-media]");

                if (!(layer instanceof HTMLElement) || !(media instanceof HTMLElement)) {
                    // no-op
                } else {
                    const prefersReduced = window.matchMedia?.(
                        "(prefers-reduced-motion: reduce)",
                    )?.matches;
                    if (prefersReduced) return;

                    const mq = window.matchMedia("(max-width: 767px)");
                    let strengthApplied = desktopStr; // fallback
                    let bleedPx = 0;

                    const getStrength = () => {
                        return clamp(
                            mq.matches && Number.isFinite(mobileStr)
                                ? mobileStr
                                : desktopStr,
                            0,
                            1,
                        );
                    };

                    const computeAutoBleed = () => {
                        const h = root.getBoundingClientRect().height;
                        const travelPx = h * strengthApplied;
                        // console.log("-----");
                        // console.log("h", h);
                        // console.log("travelPx", travelPx);
                        // console.log("bleedpx", travelPx/2);
                        return Math.ceil(travelPx / 2);
                    };

                    const getBleed = () => {
                        if (mq.matches) {
                            if (Number.isFinite(mobileBleed)) return mobileBleed;
                            return computeAutoBleed();
                        }

                        if (Number.isFinite(desktopBleed)) return desktopBleed;

                        return computeAutoBleed();
                    };

                    const updateMotionValues = () => {
                        strengthApplied = getStrength();
                        bleedPx = getBleed();
                    };

                    updateMotionValues();

                    const applySizing = () => {
                        const mult = mq.matches ? mediaHeightMultMobile : mediaHeightMult;
                        // console.log("mult", mult);
                        // console.log("media.offsetHeight + bleedPx * mult:", media.offsetHeight +" + "+bleedPx +" * "+mult + " =");
                        // media.style.height = `calc(100% + ${bleedPx*mult}px)`;
                        // media.style.height = `${window.screen.height}px`;
                        media.style.height = useMinMediaHeight
                            ? `min(calc(100% + ${bleedPx * mult}px), ${window.screen.height}px)`
                            : `calc(100% + ${bleedPx * mult}px)`;
                        // console.log("media.style.height", media.height);
                        media.style.width = "100%";
                    };

                    let rafId = 0;
                    let nowActive = false;

                    const frame = () => {
                        rafId = 0;
                        if (!nowActive) return;

                        const rect = root.getBoundingClientRect();
                        const vh = window.screen.height;

                        const start = vh;
                        const end = -rect.height;
                        const t = (start - rect.top) / (start - end);
                        const progress = clamp(t, 0, 1);

                        const maxShift = bleedPx;
                        const shift = (progress - 0.5) * 2 * maxShift;
                        const clamped = clamp(shift, -maxShift, maxShift);

                        layer.style.transform = `translate3d(0, ${clamped}px, 0)`;
                        // console.log({progress: Math.ceil(progress), shift: Math.ceil(shift), clamped: Math.ceil(clamped), bleedPx: Math.ceil(bleedPx)} );

                        rafId = requestAnimationFrame(frame);
                    };

                    const startLoop = () => {
                        if (rafId) return;
                        rafId = requestAnimationFrame(frame);
                    };

                    const stopLoop = () => {
                        if (!rafId) return;
                        cancelAnimationFrame(rafId);
                        rafId = 0;
                    };

                    const onResize = () => {
                        updateMotionValues();
                        applySizing();
                        // if active, loop updates next frame
                    };

                    const onBreakpointChange = () => {
                        updateMotionValues();
                        applySizing();
                        // if active, loop updates next frame
                    };

                    const io = new IntersectionObserver(
                        (entries) => {
                            const entry = entries[0];
                            nowActive = !!entry?.isIntersecting;

                            if (nowActive) {
                                applySizing();
                                startLoop();
                            } else {
                                stopLoop();
                            }
                        },
                        // had rootMargin: "100px 0px 100px 0px"--changed it to 0 for tighter video playback toggling
                        {root: null, threshold: 0, rootMargin: "100px 0px 100px 0px"},
                    );

                    // attach once; cheap and avoids rebind churn
                    window.addEventListener("resize", onResize, {passive: true});
                    mq.addEventListener("change", onBreakpointChange);

                    const ready = () => {
                        updateMotionValues();
                        applySizing();
                        io.observe(root);
                        // no need to start loop until intersecting
                    };

                    if (root.dataset.smartmediaReady === "true") {
                        ready();
                    } else {
                        root.addEventListener("smartmedia:ready", ready, {once: true});
                    }

                    function clamp(n, min, max) {
                        return Math.max(min, Math.min(max, n));
                    }
                }
            }
        })();
    </script>
</div>