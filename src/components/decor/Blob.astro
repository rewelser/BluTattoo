---
const {
    class: className = "",
    style = "",
    id = "",
    speed = 0.3, // parallax factor
    offset = 0, // extra starting offset in px
} = Astro.props;
---

<!--?xml version="1.0" encoding="UTF-8"?-->
<!-- parallax-svg -->
<div>
    <svg
            style={style}
            class={`parallax-svg ink-droplet ${className} absolute`}
            data-speed={speed}
            data-name="Layer 2"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 517.14 690.44"
            width="60"
            height="40"
    >
        <defs>
            <style>
                .cls-1 {
                    fill: #231f20;
                    stroke: #231f20;
                    stroke-miterlimit: 10;
                }
            </style>
        </defs>
        <g id="Layer_1-2" data-name="Layer 1">
            <path
                    id="rest-droplet"
                    class="cls-1"
                    d="
                M 516.64 256.33
                C 511.42 426.80   385.02 512.11   258.61 512.14
                C 132.20 512.17   5.77  426.93    0.50  256.33
                C 5.71  85.93     132.06 0.58     258.46 0.50
                C 384.85 0.42     511.29 85.62    516.64 256.33
                Z
            "
            >
                <animate
                        id="morph-down"
                        attributeName="d"
                        dur="20ms"
                        fill="freeze"
                        begin="indefinite"
                        to="
                    M 516.64 433.41
                    C 511.42 603.88   385.02 689.19   258.61 689.22
                    C 132.20 689.25   5.77  604.01    0.50  433.41
                    C 5.71  263.02    258.46 0.72     258.46 0.72
                    C 258.46 0.72     511.29 262.70   516.64 433.41
                    Z
                "
                ></animate>

                <animate
                        id="morph-up"
                        attributeName="d"
                        dur="20ms"
                        fill="freeze"
                        begin="indefinite"
                        to="
                    M 516.64 256.33
                    C 511.42 426.80   258.61 689.72   258.61 689.72
                    C 258.61 689.72   5.77  426.93    0.50  256.33
                    C 5.71  85.93     132.06 0.58     258.46 0.50
                    C 384.85 0.42     511.29 85.62    516.64 256.33
                    Z
                "
                ></animate>

                <animate
                        id="morph-rest"
                        attributeName="d"
                        dur="100ms"
                        fill="freeze"
                        begin="indefinite"
                        to="
                    M 516.64 256.33
                    C 511.42 426.80   385.02 512.11   258.61 512.14
                    C 132.20 512.17   5.77  426.93    0.50  256.33
                    C 5.71  85.93     132.06 0.58     258.46 0.50
                    C 384.85 0.42     511.29 85.62    516.64 256.33
                    Z
                "
                ></animate>
            </path>
        </g>
    </svg>
    <script define:vars={{speed, offset}}>
        (() => {
            const script = document.currentScript;
            const root = script?.parentElement;
            const svg = root.querySelector('svg');
            if (!root || root.dataset.disabled === "true") return;

            let ticking = false;
            let lastY = window.scrollY;
            let dir = "rest";

            const begin = (morphID) => {
                const anim = root.querySelector(`#${morphID}`);
                console.log("anim", anim);
                anim.beginElement();
            };

            const morph = (morphDir) => {
                if (morphDir === "up") {
                    begin("morph-up");
                } else if (morphDir === "down") {
                    begin("morph-down");
                } else if (morphDir === "rest") {
                    begin("morph-rest");
                }
            }

            const onScroll = () => {
                if (ticking) return;
                ticking = true;
                const newDir = window.scrollY > lastY ? "up" : "down";
                if (dir !== newDir) {
                    dir = newDir;
                    morph(dir);
                }
                lastY = window.scrollY;

                // requestAnimationFrame(() => {
                //     svg.style.transform = `translate3d(0, ${-(window.scrollY * speed) + offset}px, 0)`;
                //     ticking = false;
                // });
            }

            const onScrollEnd = () => {
                dir = "rest";
                morph(dir);
            }

            window.addEventListener("scroll", onScroll, {passive: true});
            window.addEventListener("scrollend", onScrollEnd);
            return () => {
                window.removeEventListener("scroll", onScroll);
                window.removeEventListener("scrollend", onScrollEnd);
            }
        })();
    </script>
</div>

