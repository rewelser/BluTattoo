---
import maskSrcSvg from "../maskSrcSvgs/squareframe3_mask.svg";
import frameSrcSvg from "../frameSrcSvgs/squareframe3.svg";

export const frameType = "squareframe3"
export const frame = frameSrcSvg;
export const mask = maskSrcSvg;
---
<svg
        data-frameclip-svg
        xmlns="http://www.w3.org/2000/svg"
        class="absolute inset-0 h-full w-full opacity-0 pointer-events-none"
        viewBox="0 0 411.9 500"
        aria-hidden="true"
>
    <polygon data-frame-window id="window" class="st0" points="371 456.5 41 456.5 41 42.6 370.1 39.6 371 456.5"/>

</svg>