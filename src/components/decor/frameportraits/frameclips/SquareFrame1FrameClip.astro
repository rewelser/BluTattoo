---
import maskSrcSvg from "../maskSrcSvgs/squareframe1_mask.svg";
// import frameSrcSvg from "../frameSrcSvgs/squareframe1-3-4.svg";
// import frameSrcSvg from "../frameSrcSvgs/squareframe1.svg";
import frameSrcSvg from "../frameSrcSvgs/squareframe1.png";

export const frameType = "squareframe1"
export const frame = frameSrcSvg;
export const mask = maskSrcSvg;
---
<svg
        data-frameclip-svg
        xmlns="http://www.w3.org/2000/svg"
        class="absolute inset-0 h-full w-full opacity-0 pointer-events-none"
        viewBox="0 0 397.6 500"
        aria-hidden="true"
>
    <rect
            data-frame-window
            fill="black"
            x="78"
            y="82.7"
            width="242.9"
            height="334.9"
    />
</svg>