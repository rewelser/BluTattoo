---
import {frameRegistry, type FrameKey} from "./frameclips/registry.ts";
import {getImage} from "astro:assets";

interface Props {
    photoSrc: string;
    photoAlt: string;
    frameType: FrameKey;
    class?: string;
}

const {
    photoSrc,
    photoAlt,
    frameType,
    class: className = "",
} = Astro.props;

const config = frameRegistry[frameType];

if (!config) {
    throw new Error(`Unknown frame key: ${frameType}`);
}

const {FrameClipComponent, frame, mask} = config;

// todo: remove these, but ask why using img.src exposes whole path???
const frameSvg = await getImage({src: frame});
const maskSvg = await getImage({src: mask});
---

<div
        class={`framed-portrait group relative overflow-hidden rounded-2xl ${className} fade-in`}
        data-framed-portrait
>
    <div
            class="applied-mask--frameclip h-full w-full"
            style={`mask-image: url("${mask.src}"); -webkit-mask-image: url("${mask.src}");`}
    >
        <img
                src={photoSrc}
                alt={photoAlt}
                data-photo
                class="absolute object-cover transition-transform duration-300 group-hover:scale-105"
        />
    </div>

    <img
            src={frame.src}
            alt=""
            data-frame
            class="absolute inset-0 h-full w-full pointer-events-none fade-in-nested-50"
            aria-hidden="true"
    />

    <FrameClipComponent/>

    <script is:inline>
        (() => {
            const root = document.currentScript.parentElement;
            const shape = root.querySelector("[data-frame-window]");
            const photo = root.querySelector("[data-photo]");

            function syncPhotoToWindow() {
                const shapeRect = shape.getBoundingClientRect();
                const wrapperRect = root.getBoundingClientRect();

                photo.style.top = `${shapeRect.top - wrapperRect.top}px`;
                photo.style.left = `${shapeRect.left - wrapperRect.left}px`;
                photo.style.width = `${shapeRect.width}px`;
                photo.style.height = `${shapeRect.height}px`;
            }

            const ro = new ResizeObserver(syncPhotoToWindow);
            ro.observe(root);

            if (photo.complete) {
                syncPhotoToWindow();
            } else {
                photo.addEventListener("load", syncPhotoToWindow, {once: true});
            }

            window.addEventListener("load", syncPhotoToWindow, {once: true});
        })()
    </script>
</div>

<style>

    .fade-in {
        opacity: 1;
        transition: opacity 5s cubic-bezier(.2,.8,.2,1);
        @starting-style {
            opacity: 0;
        }
    }

    .fade-in-nested-50 {
        opacity: .5;
        transition: opacity 10s cubic-bezier(.2,.8,.2,1);
        @starting-style {
            opacity: 0;
        }
    }

    .framed-portrait {
        width: 600px;
        height: 600px;
    }

    .applied-mask--frameclip {
        mask-position: center;
        mask-size: contain;
        mask-repeat: no-repeat;
        mask-mode: alpha;

        -webkit-mask-position: center;
        -webkit-mask-size: contain;
        -webkit-mask-repeat: no-repeat;
    }
</style>

