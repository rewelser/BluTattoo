---
import eventsImage from "../../domain/decor/assets/events-banner.png"

const {
    class: className,
    title,

} = Astro.props as {
    class?: string,
    title: string,
};
const chars = Array.from(title.toUpperCase());
const stagger = 0.06;
const rise = -10;
const drop = 10;
const dur = 0.5;
---
<div class="events-page-heading flex justify-between items-center bg-contain bg-center bg-no-repeat" style={`background-image: url(${eventsImage.src});`}>
    <svg
            viewBox="0 0 1920 738"
            aria-hidden="true"
            focusable="false"
    >

        <text class="arc-text">
            <textPath href="#arc" startOffset="50%" text-anchor="middle">
                {
                    chars.map((letter, i) => (
                            <tspan dy={rise} opacity="0">
                                {letter}
                                <animate
                                        class="letter-anim"
                                        attributeName="dy"
                                        from={String(rise)}
                                        to="0"
                                        dur={`${dur}s`}
                                        begin="indefinite"
                                        fill="freeze"
                                />
                                <animate
                                        class="letter-anim"
                                        attributeName="opacity"
                                        from="0"
                                        to="1"
                                        dur={`${dur}s`}
                                        begin="indefinite"
                                        fill="freeze"
                                />
                            </tspan>
                    ))
                }
            </textPath>
        </text>

        <defs>
            <path id="arc"
                  d="M206.25,452.94c149.43-62.89,414.12-151.77,753.75-148.25,318.86,3.31,568.19,86.66,714.49,148.25"/>
        </defs>
    </svg>
    <style>
        .events-page-heading {
            aspect-ratio: 1920/739;
        }
    </style>
    <script is:inline>
        (() => {
            const setupLogoAnimation = () => {
                const wrap = document.querySelector('.events-page-heading');
                if (!wrap) return;

                const allAnimates = [...wrap.querySelectorAll('.letter-anim')];
                let hasPlayed = false;

                const observer = new IntersectionObserver(
                    (entries) => {
                        const entry = entries[0];
                        if (!entry.isIntersecting || hasPlayed) return;

                        hasPlayed = true;

                        allAnimates.forEach((anim, index) => {
                            const delay = Math.floor((index / 2) * 60);
                            // divide by 2 because each letter has 2 animate tags: dy + opacity

                            setTimeout(() => {
                                if (typeof anim.beginElement === 'function') {
                                    anim.beginElement();
                                }
                            }, delay);
                        });

                        observer.disconnect();
                    },
                    {threshold: 0.2}
                );
                observer.observe(wrap);
            }

            setupLogoAnimation();
        })();

    </script>

    <style>
        .arc-text {
            fill: black;
            font-size: 120px;
            letter-spacing: 0;
        }

        @keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* curveclip-bg clip-path settings */

        .curveclip-bg {
            clip-path: shape(
                    from 0 0,
                    hline to 100%,
                    vline to 80%,
                    curve to 0 80% with 50% 120%,
                    close
            );
        }
    </style>
</div>