---
type SideImage = { src: string; alt?: string };

type SideImages = {
    left: [SideImage, SideImage];
    right: [SideImage, SideImage];
};

type Props = {
    id?: string;
    images: string[]; // top -> bottom
    sideImages?: SideImages;
    heightVh?: number;
    class?: string;
    imgClass?: string;
    openStartVh?: number; // default 0.8
    peelFrac?: number; // default 0.75
};

const {
    id = "scroll-peel",
    images,
    sideImages,
    heightVh = 400,
    class: className = "",
    imgClass = "",
    // openStartVh = 0.8,
    openStartVh = 0.8,
    // peelFrac = 0.75,
    peelFrac = 0.5,
} = Astro.props as Props;

if (!images || images.length < 2) {
    throw new Error("ScrollPeelStack.astro requires at least 2 images.");
}
if (peelFrac <= 0 || peelFrac >= 1) {
    throw new Error("ScrollPeelStack.astro: peelFrac must be between 0 and 1.");
}

const bottomIndex = images.length - 1;
const bottomSrc = images[bottomIndex];
const peelLayers = images.slice(0, bottomIndex);
const phases = peelLayers.length;

const sides: SideImages = sideImages ?? {
    left: [
        { src: "/uploads/misc_images/hero-poster.jpg", alt: "Left image 1" },
        {
            src: "/uploads/misc_images/hero-poster-red.jpg",
            alt: "Left image 2",
        },
    ],
    right: [
        { src: "/uploads/misc_images/hero-poster.jpg", alt: "Right image 1" },
        {
            src: "/uploads/misc_images/hero-poster-red.jpg",
            alt: "Right image 2",
        },
    ],
};
---

<section id={id} class="relative" style={`height:${heightVh}vh;`}>
    <div class="sticky top-0 overflow-hidden h-screen">
        <div
            id="content-frame"
            class="absolute inset-2 overflow-hidden rounded-xl"
        >
            <!-- Full-bleed stage lives INSIDE the center column, centered with transforms -->
            <div
                data-peel-reveal
                class="absolute inset-0 overflow-hidden pointer-events-none"
            >
                <div
                    data-peel-stage
                    class={`relative h-full w-full ${className}`}
                    style="clip-path: inset(0 50% 0 50% round 8px); will-change: clip-path;"
                >
                    <div
                        data-peel-scale
                        class="absolute inset-0 will-change-transform"
                        style="transform: scale(1); transform-origin: 50% 50%;"
                    >
                        <!-- Bottom (always visible) -->
                        <img
                            src={bottomSrc}
                            alt=""
                            class={`absolute inset-0 w-full h-full object-cover ${imgClass}`}
                            style="z-index:0;"
                            loading="eager"
                            decoding="async"
                        />

                        <!-- Peel layers top -> down with explicit z-index -->
                        {
                            peelLayers.map((src, i) => {
                                const z = phases - i;
                                return (
                                    <img
                                        src={src}
                                        alt=""
                                        class={`absolute inset-0 w-full h-full object-cover will-change-[clip-path] ${imgClass}`}
                                        style={`clip-path: inset(0 0 0 0); z-index:${z};`}
                                        data-peel-layer
                                        loading="eager"
                                        decoding="async"
                                    />
                                );
                            })
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Grid exists the whole time (like the reference site) -->
        <div
            class="grid h-full w-full grid-cols-3 items-center gap-x-1 sm:gap-x-2 py-50 sm:py-40 md:py-30 lg:py-10 landscape:py-10 sm:px-10 md:px-20 lg:px-50 min-w-[500px] absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2"
        >
            <!-- LEFT COLUMN (real layout; stacks naturally) -->
            <div class="flex h-full flex-col justify-start gap-1 sm:gap-2">
                <div
                    data-side="l1"
                    class="opacity-0 pointer-events-none"
                    style="transform: translate(-120%, 80%); will-change: transform, opacity;"
                >
                    <img
                        src={sides.left[0].src}
                        alt={sides.left[0].alt ?? ""}
                        class="rounded-lg md:rounded-xl object-cover"
                        loading="lazy"
                        decoding="async"
                    />
                </div>

                <div
                    data-side="l2"
                    class="opacity-0 pointer-events-none pl-10"
                    style="transform: translate(-120%, 80%); will-change: transform, opacity;"
                >
                    <img
                        src={sides.left[1].src}
                        alt={sides.left[1].alt ?? ""}
                        class="rounded-lg md:rounded-xl object-cover"
                        loading="lazy"
                        decoding="async"
                    />
                </div>
            </div>

            <!-- CENTER COLUMN: contains a dummy shell + the "inside" full-bleed stage -->
            <div class="h-full py-10">
                <div
                    data-center-shell
                    class="relative h-full overflow-visible flex items-center justify-center"
                >
                </div>
            </div>

            <!-- RIGHT COLUMN -->
            <div
                class="flex h-full flex-col justify-end gap-1 sm:gap-2 items-end"
            >
                <div
                    data-side="r1"
                    class="opacity-0 pointer-events-none pr-10"
                    style="transform: translate(120%, 80%); will-change: transform, opacity;"
                >
                    <img
                        src={sides.right[0].src}
                        alt={sides.right[0].alt ?? ""}
                        class="rounded-lg md:rounded-xl object-cover"
                        loading="lazy"
                        decoding="async"
                    />
                </div>

                <div
                    data-side="r2"
                    class="opacity-0 pointer-events-none"
                    style="transform: translate(120%, 80%); will-change: transform, opacity;"
                >
                    <img
                        src={sides.right[1].src}
                        alt={sides.right[1].alt ?? ""}
                        class="rounded-lg md:rounded-xl object-cover"
                        loading="lazy"
                        decoding="async"
                    />
                </div>
            </div>
        </div>

        <!-- Script at end of sticky so it sees all columns -->
        <script define:vars={{ id, phases, openStartVh, peelFrac }}>
            (() => {
                const section = document.getElementById(id);
                if (!section) return;

                const stage = section.querySelector("[data-peel-stage]");
                const centerShell = section.querySelector(
                    "[data-center-shell]",
                );
                const layers = Array.from(
                    section.querySelectorAll("[data-peel-layer]"),
                );
                const sideEls = Array.from(
                    section.querySelectorAll("[data-side]"),
                );

                const scaleWrap = section.querySelector("[data-peel-scale]");
                if (!stage || !centerShell || !scaleWrap) return;

                const clamp01 = (n) => Math.max(0, Math.min(1, n));
                const lerp = (a, b, t) => a + (b - a) * t;
                const ramp = (t, t0, t1) => clamp01((t - t0) / (t1 - t0));

                const ease = {
                    // common
                    inOutCubic: (t) =>
                        t < 0.5
                            ? 4 * t * t * t
                            : 1 - Math.pow(-2 * t + 2, 3) / 2,
                    outCubic: (t) => 1 - Math.pow(1 - t, 3),
                    outQuart: (t) => 1 - Math.pow(1 - t, 4),

                    // “bezier-ish” without a full solver:
                    // This is a good approximation for “smoothstep”/S-curve feel.
                    smoothstep: (t) => t * t * (3 - 2 * t),

                    // If you want *actual* cubic-bezier(p1x,p1y,p2x,p2y) like CSS,
                    // see section 3 below.
                };

                const rampEased = (t, t0, t1, fn) =>
                    fn ? fn(ramp(t, t0, t1)) : ramp(t, t0, t1);

                // --- Visual knobs ---
                const desiredExitScale = 0.4;
                const scaleLead = 0.0; // when scaling starts inside exit (0 = immediately w/ clip)
                const scaleFinish = 0.6; // finish scaling by same time shrink finishes (matches your shrinkT window)

                // Radius: 8px under md, 12px at md+
                const radiusSm = 8;
                const radiusMd = 12;
                const isMd = () =>
                    window.matchMedia("(min-width: 768px)").matches;

                // Side stagger
                // const sideTimings = {
                //     l1: [0.18, 0.65],
                //     r1: [0.22, 0.67],
                //     l2: [0.26, 0.69],
                //     r2: [0.3, 0.7],
                // };
                const sideTimings = {
                    l1: [0.18, 0.7],
                    r1: [0.2, 0.72],
                    l2: [0.22, 0.74],
                    r2: [0.24, 0.76],
                };

                // We’ll animate exit to match the CENTER SHELL rect (deterministic)
                // We’ll store “final” insets in px.
                let exitFinal = { top: 0, right: 0, bottom: 0, left: 0 };

                let minCoverScale = 1;

                const computeExitInsetsPx = () => {
                    const shell = centerShell.getBoundingClientRect();
                    const s = stage.getBoundingClientRect();

                    const top = shell.top - s.top;
                    const left = shell.left - s.left;
                    const right = s.right - shell.right;
                    const bottom = s.bottom - shell.bottom;

                    exitFinal = {
                        top: Math.max(0, top),
                        left: Math.max(0, left),
                        right: Math.max(0, right),
                        bottom: Math.max(0, bottom),
                    };

                    // NEW: responsive minimum scale so scaled content still covers final clipped window
                    const shellW = shell.width || 1;
                    const shellH = shell.height || 1;
                    const stageW = s.width || 1;
                    const stageH = s.height || 1;

                    minCoverScale = Math.max(shellW / stageW, shellH / stageH);
                    console.log("shellW / stageW,  shellH / stageH", shellW, stageW, shellH, stageH);
                    console.log("minCoverScale", minCoverScale);

                    // optional tiny safety margin against subpixel rounding
                    minCoverScale = Math.min(1, minCoverScale + 0.01);
                };

                // Initial compute after layout
                requestAnimationFrame(computeExitInsetsPx);

                let rafId = 0;

                const update = () => {
                    rafId = 0;

                    const r = section.getBoundingClientRect();
                    // const vh = window.innerHeight || 1;
                    const vh = document.documentElement.clientHeight || 1;
                    

                    // ---------------------------
                    // OPENING (approach phase)
                    // ---------------------------
                    const startPx = vh * openStartVh;
                    const openT = clamp01((startPx - r.top) / (startPx || 1));
                    const openTEased = ease.smoothstep(openT);

                    // const openSidePct = (1 - openT) * 50;
                    // const openSidePct = (1 - openTEased) * 50;
                    const openSidePct = (1 - openTEased) * 50;

                    // ---------------------------
                    // STICKY SCENE timeline (0..1)
                    // ---------------------------
                    const scrollable = r.height - vh;
                    const traveled = Math.max(0, -r.top);
                    const tScene = clamp01(traveled / (scrollable || 1));

                    const peelT = clamp01(tScene / peelFrac);
                    const exitT = clamp01((tScene - peelFrac) / (1 - peelFrac));

                    // ---------------------------
                    // STAGE CLIP
                    // - Before exit: use percent-based opening aperture.
                    // - During exit: interpolate to px-based insets that match centerShell.
                    // ---------------------------
                    // const shrinkT = ramp(exitT, 0.0, 0.6);
                    const shrinkT = rampEased(exitT, 0.0, 0.6, ease.inOutCubic);
                    // const spaceGate = ramp(shrinkT, 0.25, 0.75); // 0 until shrinkT hits 0.25, then ramps to 1 by 0.75
                    const spaceGate = ramp(shrinkT, 0.25, 1);

                    const rPx = isMd() ? radiusMd : radiusSm;

                    if (shrinkT <= 0.0001) {
                        // opening / full-bleed phase
                        stage.style.clipPath = `inset(0 ${openSidePct.toFixed(3)}% 0 ${openSidePct.toFixed(3)}% round ${rPx}px)`;
                    } else {
                        // exit: lerp from full-bleed (0px insets) to centerShell insets (px)
                        const top = lerp(0, exitFinal.top, shrinkT);
                        const right = lerp(0, exitFinal.right, shrinkT);
                        const bottom = lerp(0, exitFinal.bottom, shrinkT);
                        const left = lerp(0, exitFinal.left, shrinkT);

                        stage.style.clipPath = `inset(${top.toFixed(2)}px ${right.toFixed(2)}px ${bottom.toFixed(2)}px ${left.toFixed(2)}px round ${rPx}px)`;
                    }

                    const exitScale = Math.max(desiredExitScale, minCoverScale);

                    // Scale: starts when exit starts (or slightly later), ends with shrink
                    // const scaleT = ramp(exitT, scaleLead, scaleFinish);
                    const scaleT = rampEased(
                        exitT,
                        scaleLead,
                        scaleFinish,
                        ease.inOutCubic,
                    );
                    const sVal = lerp(1, exitScale, scaleT);
                    scaleWrap.style.transform = `scale(${sVal.toFixed(4)})`;

                    // ---------------------------
                    // PEELING (unchanged)
                    // ---------------------------
                    for (let i = 0; i < phases; i++) {
                        const img = layers[i];
                        if (!img) continue;

                        const start = i / phases;
                        const local = clamp01((peelT - start) * phases);
                        img.style.clipPath = `inset(0 0 ${(local * 100).toFixed(3)}% 0)`;
                    }

                    // ---------------------------
                    // SIDE IMAGES entrance (layout handles abutment)
                    // ---------------------------
                    for (const el of sideEls) {
                        const key = el.getAttribute("data-side") || "";
                        const timing = sideTimings[key];
                        const tInLin = timing
                            ? ramp(exitT, timing[0], timing[1])
                            : exitT;
                        const tInEased = ease.smoothstep(tInLin);
                        // const tIn = tInEased;
                        const tIn = tInEased * spaceGate;

                        const isLeft = key.startsWith("l");
                        const dir = isLeft ? -1 : 1;

                        const rectW = el.getBoundingClientRect().width || 0;
                        const off = rectW + 80;

                        const x = lerp(dir * off, 0, tIn);
                        const y = lerp(off, 0, tIn);
                        const o = lerp(0, 1, tIn);

                        // el.style.transform = `translateX(${x.toFixed(2)}px)`;
                        el.style.transform = `translate(${x.toFixed(2)}px, ${y.toFixed(2)}px)`;
                        el.style.opacity = String(o);
                    }
                };

                const onScroll = () => {
                    if (rafId) return;
                    rafId = requestAnimationFrame(update);
                };

                const onResize = () => {
                    requestAnimationFrame(() => {
                        computeExitInsetsPx();
                        onScroll();
                    });
                };

                window.addEventListener("scroll", onScroll, { passive: true });
                window.addEventListener("resize", onResize);

                update();

                document.addEventListener(
                    "astro:before-swap",
                    () => {
                        window.removeEventListener("scroll", onScroll);
                        window.removeEventListener("resize", onResize);
                        if (rafId) cancelAnimationFrame(rafId);
                    },
                    { once: true },
                );
            })();
        </script>
    </div>
</section>