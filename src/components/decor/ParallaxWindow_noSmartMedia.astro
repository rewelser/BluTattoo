---
/**
    * ParallaxWindow (image OR video)
    * - kind: "image" | "video"
    * - src: media url
    * - windowHeight: CSS height for the "window" (default 35vh)
    * - strength: how much slower than scroll (0.2 subtle, 0.35 stronger)
    * - bleed: extra pixels above/below to prevent gaps (auto if not provided)
    *
    * Video notes:
    * - For mobile autoplay: muted + playsinline are important.
    */

import type {ImageMetadata} from "astro";
import {Image} from "astro:assets";

export interface Props {
    kind?: "image" | "video";
    // this is confusing. I know it is because we are using the src for both the image and the video, but it's annoying, and assumes there's no mobile image variant
    src: ImageMetadata | string;
    srcMobile?: string;
    alt?: string; // only used for images
    windowHeight?: string;
    windowHeightMobile?: string;
    mediaHeightMult?: number;
    mediaHeightMultMobile?: number;
    useMinMediaHeight?: boolean;
    strength?: number;
    bleed?: number;
    strengthMobile?: number;
    bleedMobile?: number;
    class?: string;
    layerClass?: string;

    // video extras (optional)
    autoplay?: boolean;
    muted?: boolean;
    loop?: boolean;
    playsinline?: boolean;
    controls?: boolean;
    preload?: "none" | "metadata" | "auto";
    loading?: "eager" | "lazy" | null | undefined;
    decoding?: "auto" | "async" | "sync" | null | undefined;
    poster?: string;
}

const {
    kind = "image",
    src,
    srcMobile,
    alt = "",
    windowHeight = "35vh",
    windowHeightMobile,
    mediaHeightMult = 2,
    mediaHeightMultMobile = 2,
    useMinMediaHeight = true,
    strength = 0.28,
    bleed,
    strengthMobile,
    bleedMobile,
    class: className = "",
    layerClass,

    autoplay = false,
    muted = true,
    loop = true,
    playsinline = true,
    controls = false,
    preload = "metadata",
    loading = "lazy",
    decoding = "async",
    poster,
} = Astro.props;
---

<div
        class={`pw ${className}`}
        data-strength={strength}
        data-strength-mobile={strengthMobile ?? ""}
        data-bleed={bleed ?? ""}
        data-bleed-mobile={bleedMobile ?? ""}
>
    <div class={`pw__layer ${layerClass}`} aria-hidden="true">
        {
            (kind === "video" && typeof src === "string") ? (
                    <video
                            class="pw__media"
                            autoplay={autoplay}
                            muted={muted}
                            loop={loop}
                            playsinline={playsinline}
                            controls={controls}
                            preload={preload}
                            poster={poster}
                            loading={loading}
                    >
                        <source
                                src={srcMobile}
                                media="(max-width: 640px)"
                                type="video/webm"
                        />
                        <source
                                src={src}
                                type="video/webm"
                        />
                    </video>
            ) : (
                    <Image
                            class="pw__media"
                            src={src as ImageMetadata}
                            width="1200"
                            sizes="auto"
                            alt={alt}
                            loading={loading}
                            decoding={decoding}
                    />
            )
        }
    </div>

    <div class="pw__content">
        <slot/>
    </div>
</div>

<style define:vars={{windowHeight, mobileWindowHeight: windowHeightMobile ?? windowHeight}}>
    .pw {
        position: relative;
        height: var(--windowHeight);
        overflow: hidden;
    }

    @media (max-width: 640px) {
        .pw {
            height: var(--mobileWindowHeight);
        }
    }

    .pw__layer {
        position: absolute;
        inset: 0;
        will-change: transform;
        transform: translate3d(0, 0, 0);
    }

    /* shared for img/video */
    .pw :global(.pw__media) {
        position: absolute;
        left: 50%;
        top: 50%;
        width: 100%;
        height: 100%;
        transform: translate3d(-50%, -50%, 0);
        object-fit: cover;
        backface-visibility: hidden;
        -webkit-transform-style: preserve-3d;
    }

    .pw__content {
        position: relative;
        z-index: 1;
        height: 100%;
        display: grid;
        place-items: center;
        /*pointer-events: none;*/
    }
</style>

<script define:vars={{
    desktopStr: strength,
    mobileStr: strengthMobile ?? null,
    desktopBleed: bleed ?? null,
    mobileBleed: bleedMobile ?? null,
    mediaHeightMult,
    mediaHeightMultMobile,
    useMinMediaHeight
}}>
    (() => {
        // No-scroll-listener version:
        // - IntersectionObserver toggles active
        // - While active, we run a continuous rAF loop
        const root = document.currentScript?.previousElementSibling; // the .pw div

        if (!(root instanceof HTMLElement)) {
            // no-op
        } else {
            const layer = root.querySelector(".pw__layer");
            const media = root.querySelector(".pw__media");

            if (!(layer instanceof HTMLElement) || !(media instanceof HTMLElement)) {
                // no-op
            } else {
                const prefersReduced = window.matchMedia?.(
                    "(prefers-reduced-motion: reduce)",
                )?.matches;
                if (prefersReduced) return;

                const mq = window.matchMedia("(max-width: 640px)");
                let strengthApplied = desktopStr; // fallback
                let bleedPx = 0;

                const getStrength = () => {
                    return clamp(
                        mq.matches && Number.isFinite(mobileStr)
                            ? mobileStr
                            : desktopStr,
                        0,
                        1,
                    );
                };

                const computeAutoBleed = () => {
                    const h = root.getBoundingClientRect().height;
                    const travelPx = h * strengthApplied;
                    // console.log("-----");
                    // console.log("h", h);
                    // console.log("travelPx", travelPx);
                    // console.log("bleedpx", travelPx/2);
                    return Math.ceil(travelPx / 2);
                };

                const getBleed = () => {
                    if (mq.matches) {
                        if (Number.isFinite(mobileBleed)) return mobileBleed;
                        return computeAutoBleed();
                    }

                    if (Number.isFinite(desktopBleed)) return desktopBleed;

                    return computeAutoBleed();
                };

                const updateMotionValues = () => {
                    strengthApplied = getStrength();
                    bleedPx = getBleed();
                };

                updateMotionValues();

                const applySizing = () => {
                    const mult = mq.matches ? mediaHeightMultMobile : mediaHeightMult;
                    // console.log("mult", mult);
                    // console.log("media.offsetHeight + bleedPx * mult:", media.offsetHeight +" + "+bleedPx +" * "+mult + " =");
                    // media.style.height = `calc(100% + ${bleedPx*mult}px)`;
                    // media.style.height = `${window.screen.height}px`;
                    media.style.height = useMinMediaHeight
                        ? `min(calc(100% + ${bleedPx * mult}px), ${window.screen.height}px)`
                        : `calc(100% + ${bleedPx * mult}px)`;
                    // console.log("media.style.height", media.height);
                    media.style.width = "100%";
                };

                let rafId = 0;
                let nowActive = false;

                const frame = () => {
                    rafId = 0;
                    if (!nowActive) return;

                    const rect = root.getBoundingClientRect();
                    const vh = window.screen.height;

                    const start = vh;
                    const end = -rect.height;
                    const t = (start - rect.top) / (start - end);
                    const progress = clamp(t, 0, 1);

                    const maxShift = bleedPx;
                    const shift = (progress - 0.5) * 2 * maxShift;
                    const clamped = clamp(shift, -maxShift, maxShift);

                    layer.style.transform = `translate3d(0, ${clamped}px, 0)`;
                    // console.log({progress: Math.ceil(progress), shift: Math.ceil(shift), clamped: Math.ceil(clamped), bleedPx: Math.ceil(bleedPx)} );

                    rafId = requestAnimationFrame(frame);
                };

                const startLoop = () => {
                    if (rafId) return;
                    rafId = requestAnimationFrame(frame);
                };

                const stopLoop = () => {
                    if (!rafId) return;
                    cancelAnimationFrame(rafId);
                    rafId = 0;
                };

                const onResize = () => {
                    updateMotionValues();
                    applySizing();
                    // if active, loop updates next frame
                };

                const onBreakpointChange = () => {
                    updateMotionValues();
                    applySizing();
                    // if active, loop updates next frame
                };

                const io = new IntersectionObserver(
                    (entries) => {
                        const entry = entries[0];
                        nowActive = !!entry?.isIntersecting;
                        const isVideo = media.tagName === "VIDEO";
                        const video = isVideo ? media : null;

                        if (nowActive) {
                            applySizing();
                            startLoop();

                            if (video) {
                                video.play().catch(() => {});
                            }
                        } else {
                            stopLoop();

                            video && video.pause();
                        }
                    },
                    // had rootMargin: "100px 0px 100px 0px"--changed it to 0 for tighter video playback toggling
                    {root: null, threshold: 0, rootMargin: "0px"},
                );

                // attach once; cheap and avoids rebind churn
                window.addEventListener("resize", onResize, {passive: true});
                mq.addEventListener("change", onBreakpointChange);

                const ready = () => {
                    updateMotionValues();
                    applySizing();
                    io.observe(root);
                    // no need to start loop until intersecting
                };

                if (media.tagName === "IMG") {
                    const img = media;
                    if (img.complete) ready();
                    else img.addEventListener("load", ready, {once: true});
                } else if (media.tagName === "VIDEO") {
                    const vid = media;
                    if (vid.readyState >= 1) ready();
                    else vid.addEventListener("loadedmetadata", ready, {once: true});
                } else {
                    ready();
                }

                function clamp(n, min, max) {
                    return Math.max(min, Math.min(max, n));
                }
            }
        }
    })();
</script>
<!--debug js -->
<script is:inline>
    (() => {
        const SELECTORS = [".pw", ".pw__layer", ".pw__media"];

        const styles = {
            ".pw": ["#00e5ff", "PW"],
            ".pw__layer": ["#ff3bff", "PW LAYER"],
            ".pw__media": ["#ffe600", "PW MEDIA"],
        };

        let enabled = false;
        let rafId = null;

        const overlayRoot = document.createElement("div");
        overlayRoot.id = "pw-debug-overlays";
        Object.assign(overlayRoot.style, {
            position: "fixed",
            inset: "0",
            pointerEvents: "none",
            zIndex: "2147483647",
        });
        document.body.appendChild(overlayRoot);

        function draw() {
            if (!enabled) return;

            overlayRoot.innerHTML = "";

            SELECTORS.forEach((selector) => {
                document.querySelectorAll(selector).forEach((el, index) => {
                    const rect = el.getBoundingClientRect();
                    const [color, label] = styles[selector];

                    const box = document.createElement("div");
                    Object.assign(box.style, {
                        position: "fixed",
                        left: `${rect.left}px`,
                        top: `${rect.top}px`,
                        width: `${rect.width}px`,
                        height: `${rect.height}px`,
                        border: `2px solid ${color}`,
                        boxSizing: "border-box",
                        pointerEvents: "none",
                    });

                    const tag = document.createElement("div");
                    tag.textContent =
                        `${label} ${index + 1} — ${Math.round(rect.width)}×${Math.round(rect.height)}`;
                    Object.assign(tag.style, {
                        position: "absolute",
                        left: "0",
                        top: "0",
                        transform: "translateY(-100%)",
                        background: color,
                        color: "#000",
                        font: "12px/1.3 monospace",
                        padding: "2px 5px",
                        whiteSpace: "nowrap",
                    });

                    box.appendChild(tag);
                    overlayRoot.appendChild(box);
                });
            });

            rafId = requestAnimationFrame(draw);
        }

        draw();

        window.__pwDebugOff = () => {
            enabled = false;

            if (rafId !== null) {
                cancelAnimationFrame(rafId);
            }

            overlayRoot.remove();
        };
    })();
</script>