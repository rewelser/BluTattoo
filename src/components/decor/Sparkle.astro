---
import SparkleSvg from "./SparkleSvg.astro";
const {color = 'black', size = 24, style = ''} = Astro.props;
---

<SparkleSvg color={color} size={size} style={style} className="sparkle-wrapper" svgClassName="sparkle-svg"></SparkleSvg>

<style>
    @keyframes grow-and-shrink {
        0% {
            transform: scale(0);
        }
        50% {
            transform: scale(1);
        }
        100% {
            transform: scale(0);
        }
    }

    @keyframes spin {
        from {
            transform: rotate(0deg);
        }
        to {
            transform: rotate(180deg);
        }
    }

    :global(.sparkle-wrapper) {
        position: absolute;
        pointer-events: none;
        animation: grow-and-shrink 800ms ease-in-out forwards;
    }

    :global(.sparkle-svg) {
        width: 100%;
        height: 100%;
        display: block;
        animation: spin 800ms linear forwards;
    }
</style>