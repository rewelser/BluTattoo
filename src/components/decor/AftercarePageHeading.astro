---
import aftercareSymbol from "../../domain/decor/assets/aftercare-lightred.png";


const {
    class: className,
    title,

} = Astro.props as {
    class?: string,
    title: string,
};
const chars = Array.from(title.toUpperCase());
// 6397CC (light ceil blue)
// 384F66 (dark ceil blue)

// 003366 (navy)

// 80393d (light red)B55156
// 541114 (dark red)
const aftercareImageSrc = aftercareSymbol.src;
---
<div class="aftercare-page-heading h-[80vh] sm:h-[80vh] flex justify-center items-center bg-radial from-black to-[#541114]">
    <div class="aftercare-page-heading-decor-container relative h-[min(60vh,calc(100vw-.5rem))] sm:h-[min(60vh,calc(100vw-2rem))] aspect-square box-border p-2 sm:p-5">
        <div class="aftercare-page-heading-beveled-outer p-5">
            <div class="aftercare-page-heading-beveled-inner h-full w-full">
                <div class="aftercare-page-heading-decor" style={`background-image: url(${aftercareImageSrc})`}>
                    <!-- graphic goes here -->
                </div>
                <div class="aftercare-page-heading-decor-text" aria-hidden="true">
                    {chars.map((char, i) => (
                            <span
                                    class="animated-heading__char"
                                    style={`animation-delay: calc(${i} * 95ms)`}
                                    aria-hidden="true"
                            >
                                          {char === " " ? "\u00A0" : char}
                                        </span>
                    ))}
                </div>
            </div>
        </div>
    </div>
    <style>
        .aftercare-page-heading {
            //background-image: radial-gradient(
            //        ellipse farthest-corner at 50% 70%,
            //        black 0%,
            //        black 70%,
            //        #6397CC 100%
            //);
            mask: linear-gradient(0, #0000 100vw, #000 0),
            radial-gradient(100vw, #000 calc(100% - 1px), #0000) bottom/185vw 200vw;
            /*
              Bottom curve height is the sagitta of the circular mask arc.

              Formula:
              s = r - sqrt(r² - (w / 2)²)

              For this mask:
              r = 100vw
              w = 100vw

              s = 100vw - sqrt(100vw² - 50vw²)
                ≈ 13.4vw
            */
            padding-bottom: 13.4vw;
        }

        @media (min-width: 768px) {
            .aftercare-page-heading {
                /* padding not really necessary on larger screens, due to sizing of graphic */
                padding-bottom: 0;
            }
        }

        .aftercare-page-heading-decor-container {
            container-type: size;
            --bevelSize: 22cqh;
            --bevelSizeBorder: 2.5cqh;

        }

        .aftercare-page-heading-beveled-outer {
            width: 100%;
            height: 100%;
            background: white;
            clip-path: polygon(
                    0 var(--bevelSize),
                    var(--bevelSize) var(--bevelSize),
                    var(--bevelSize) 0,
                    calc(100% - var(--bevelSize)) 0,
                    calc(100% - var(--bevelSize)) var(--bevelSize),
                    100% var(--bevelSize),
                    100% calc(100% - var(--bevelSize)),
                    calc(100% - var(--bevelSize)) calc(100% - var(--bevelSize)),
                    calc(100% - var(--bevelSize)) 100%,
                    var(--bevelSize) 100%,
                    var(--bevelSize) calc(100% - var(--bevelSize)),
                    0 calc(100% - var(--bevelSize))
            );
        }

        .aftercare-page-heading-beveled-inner {
            position: relative;
            filter: drop-shadow(4px 4px 8px rgba(0, 0, 0, 0.5));
        }

        .aftercare-page-heading-beveled-inner:before {
            content: "";
            position: absolute;
            inset: 0;
            background: black;
            clip-path: polygon(
                    0 var(--bevelSize),
                    var(--bevelSize) var(--bevelSize),
                    var(--bevelSize) 0,
                    calc(100% - var(--bevelSize)) 0,
                    calc(100% - var(--bevelSize)) var(--bevelSize),
                    100% var(--bevelSize),
                    100% calc(100% - var(--bevelSize)),
                    calc(100% - var(--bevelSize)) calc(100% - var(--bevelSize)),
                    calc(100% - var(--bevelSize)) 100%,
                    var(--bevelSize) 100%, var(--bevelSize) calc(100% - var(--bevelSize)),
                    0 calc(100% - var(--bevelSize)),
                    0 var(--bevelSize),
                    var(--bevelSizeBorder) calc(var(--bevelSize) + var(--bevelSizeBorder)),
                    var(--bevelSizeBorder) calc(100% - var(--bevelSize) - var(--bevelSizeBorder)),
                    calc(var(--bevelSize) + var(--bevelSizeBorder)) calc(100% - var(--bevelSize) - var(--bevelSizeBorder)),
                    calc(var(--bevelSize) + var(--bevelSizeBorder)) calc(100% - var(--bevelSizeBorder)),
                    calc(100% - var(--bevelSize) - var(--bevelSizeBorder)) calc(100% - var(--bevelSizeBorder)),
                    calc(100% - var(--bevelSize) - var(--bevelSizeBorder)) calc(100% - var(--bevelSize) - var(--bevelSizeBorder)),
                    calc(100% - var(--bevelSizeBorder)) calc(100% - var(--bevelSize) - var(--bevelSizeBorder)),
                    calc(100% - var(--bevelSizeBorder)) calc(var(--bevelSize) + var(--bevelSizeBorder)),
                    calc(100% - var(--bevelSize) - var(--bevelSizeBorder)) calc(var(--bevelSize) + var(--bevelSizeBorder)),
                    calc(100% - var(--bevelSize) - var(--bevelSizeBorder)) var(--bevelSizeBorder),
                    calc(var(--bevelSize) + var(--bevelSizeBorder)) var(--bevelSizeBorder),
                    calc(var(--bevelSize) + var(--bevelSizeBorder)) calc(var(--bevelSize) + var(--bevelSizeBorder)),
                    var(--bevelSizeBorder) calc(var(--bevelSize) + var(--bevelSizeBorder))
            );
        }

        .aftercare-page-heading-decor {
            position: absolute;
            top: calc(var(--bevelSize) + var(--bevelSizeBorder));
            left: calc(var(--bevelSize) + var(--bevelSizeBorder));
            height: calc(100% - 2 * (var(--bevelSize) + var(--bevelSizeBorder)));
            width: calc(100% - 2 * (var(--bevelSize) + var(--bevelSizeBorder)));
            background-size: contain;
            background-position: center;
            background-repeat: no-repeat;
        }

        .aftercare-page-heading-decor-text {
            position: absolute;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden;
            top: calc(var(--bevelSize) + var(--bevelSizeBorder));
            left: var(--bevelSizeBorder);
            height: calc(100% - 2 * (var(--bevelSize) + var(--bevelSizeBorder)));
            width: calc(100% - 2 * var(--bevelSizeBorder));

            /*
              clamp(min, preferred, max)

              min: 2rem  — readable floor on small containers
              preferred: 12cqw — scales with the component; 12% of container width
              max: 8rem — visual ceiling on large containers

              The 12cqw value was tuned for the word "Aftercare": it makes the
              font-size roughly containerWidth / 8.33, which gives this title a
              good visual width inside the decorative frame.
            */
            font-size: clamp(2rem, 12cqw, 8rem);
            /* bounds by container height. Unstable, but keeping comment for posterity */
            //font-size: min(18cqw, 28cqh);
            line-height: 1;
            white-space: nowrap;
        }

        .animated-heading__char {
            display: inline-block;
            opacity: 0;
            transform: translateY(0.6em);
            animation: heading-char-in 600ms cubic-bezier(.2, .8, .2, 1) forwards;
        }

        @keyframes heading-char-in {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @media (prefers-reduced-motion: reduce) {
            .animated-heading__char {
                opacity: 1;
                transform: none;
                animation: none;
            }
        }
    </style>
</div>