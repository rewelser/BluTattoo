---
import SparkleSvg from "./SparkleSvg.astro";

interface Props {
    color?: string;
    size?: number;
    gap?: number;
    offset?: number;
    sparkleDurationMs?: number;
    stepMs?: number;
    betweenClustersPauseMs?: number;
    cyclePauseMs?: number;
}

const {
    color = "black",
    size = 24,
    gap = 18,
    offset = 10,
    sparkleDurationMs = 800,
    stepMs = 180,
    betweenClustersPauseMs = 450,
    cyclePauseMs = 700,
} = Astro.props;

// Derived numbers for the whole animation timeline
const clusterStartMs = sparkleDurationMs + stepMs * 2;
const secondClusterStartMs = clusterStartMs + betweenClustersPauseMs;
const totalCycleMs = secondClusterStartMs + sparkleDurationMs + stepMs * 2 + cyclePauseMs;

// Triangle geometry
const clusterWidth = gap * 2 + size;
const clusterHeight = gap + size;

// Convert times to percentages of the whole cycle
const pct = (ms: number) => (ms / totalCycleMs) * 100;

// One sparkle's visible animation window
const window0Start = 0;
const window0Mid = pct(sparkleDurationMs / 2);
const window0End = pct(sparkleDurationMs);

const sparkleKeyframes = `
  0%, 100% { transform: scale(0); }
  ${window0Start}% { transform: scale(0); }
  ${window0Mid}% { transform: scale(1); }
  ${window0End}% { transform: scale(0); }
`;

const spinKeyframes = `
  0%, ${window0Start}% { transform: rotate(0deg); }
  ${window0End}% { transform: rotate(180deg); }
  100% { transform: rotate(180deg); }
`;
---

<div class="sparkle-corners" aria-hidden="true">
    <div class="cluster cluster--top-left">
        <div class="sparkle sparkle--tl-1" style="--bg-color: #ff5733;">
            <SparkleSvg
                    color={color}
                    size={size}
                    className="sparkle-wrapper"
                    svgClassName="sparkle-svg"
            />
        </div>
        <div class="sparkle sparkle--tl-2">
            <SparkleSvg
                    color={color}
                    size={size}
                    className="sparkle-wrapper"
                    svgClassName="sparkle-svg"
            />
        </div>
        <div class="sparkle sparkle--tl-3">
            <SparkleSvg
                    color={color}
                    size={size}
                    className="sparkle-wrapper"
                    svgClassName="sparkle-svg"
            />
        </div>
    </div>

    <div class="cluster cluster--bottom-right">
        <div class="sparkle sparkle--br-1">
            <SparkleSvg
                    color={color}
                    size={size}
                    className="sparkle-wrapper"
                    svgClassName="sparkle-svg"
            />
        </div>
        <div class="sparkle sparkle--br-2">
            <SparkleSvg
                    color={color}
                    size={size}
                    className="sparkle-wrapper"
                    svgClassName="sparkle-svg"
            />
        </div>
        <div class="sparkle sparkle--br-3">
            <SparkleSvg
                    color={color}
                    size={size}
                    className="sparkle-wrapper"
                    svgClassName="sparkle-svg"
            />
        </div>
    </div>
</div>

<style define:vars={{
    size,
    gap,
    offset,
    sparkleDurationMs,
    stepMs,
    betweenClustersPauseMs,
    cyclePauseMs,
    totalCycleMs,
    clusterWidth,
    clusterHeight,
    sparkleKeyframes,
    spinKeyframes,
}}>
    @keyframes sparkle-grow-and-shrink {
        /* Astro injects these values as CSS vars, so this is valid */
        0%, 100% { transform: scale(0); }
        50% { transform: scale(1); }
    }

    @keyframes sparkle-spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(180deg); }
    }

    .sparkle-corners {
        position: absolute;
        inset: 0;
        //pointer-events: none;
        overflow: visible;
    }

    .cluster {
        position: absolute;
        width: calc(var(--clusterWidth) * 1px);
        height: calc(var(--clusterHeight) * 1px);
    }

    .cluster--top-left {
        left: calc((var(--clusterWidth) + var(--offset)) * -1px);
        top: calc((var(--clusterHeight) + var(--offset)) * -1px);
    }

    .cluster--bottom-right {
        right: calc((var(--clusterWidth) + var(--offset)) * -1px);
        bottom: calc((var(--clusterHeight) + var(--offset)) * -1px);
    }

    .sparkle {
        position: absolute;
        background-color: var(--bg-color);
        width: calc(var(--size) * 1px);
        height: calc(var(--size) * 1px);
        transform: scale(0);
        animation-name: sparkle-grow-and-shrink;
        animation-duration: calc(var(--sparkleDurationMs) * 1ms);
        animation-timing-function: ease-in-out;
        animation-iteration-count: infinite;
        animation-fill-mode: both;
    }

    .sparkle--tl-1 { left: calc(var(--gap) * 1px); top: 0; }
    .sparkle--tl-2 { left: 0; top: calc(var(--gap) * 1px); }
    .sparkle--tl-3 { left: calc(var(--gap) * 2px); top: calc(var(--gap) * 1px); }

    .sparkle--br-1 { left: calc(var(--gap) * 1px); top: 0; }
    .sparkle--br-2 { left: 0; top: calc(var(--gap) * 1px); }
    .sparkle--br-3 { left: calc(var(--gap) * 2px); top: calc(var(--gap) * 1px); }

    /* Sequential delays within one shared cycle */
    .sparkle--tl-1 { animation-delay: 0ms; }
    .sparkle--tl-2 { animation-delay: calc(var(--stepMs) * 1ms); }
    .sparkle--tl-3 { animation-delay: calc(var(--stepMs) * 2ms); }

    .sparkle--br-1 {
        animation-delay: calc(
                (var(--sparkleDurationMs) + var(--stepMs) * 2 + var(--betweenClustersPauseMs)) * 1ms
        );
    }
    .sparkle--br-2 {
        animation-delay: calc(
                (var(--sparkleDurationMs) + var(--stepMs) * 3 + var(--betweenClustersPauseMs)) * 1ms
        );
    }
    .sparkle--br-3 {
        animation-delay: calc(
                (var(--sparkleDurationMs) + var(--stepMs) * 4 + var(--betweenClustersPauseMs)) * 1ms
        );
    }

    :global(.sparkle-wrapper) {
        width: 100%;
        height: 100%;
        display: block;
        pointer-events: none;
    }

    :global(.sparkle-svg) {
        width: 100%;
        height: 100%;
        display: block;
        animation-name: sparkle-spin;
        animation-duration: calc(var(--sparkleDurationMs) * 1ms);
        animation-timing-function: linear;
        animation-iteration-count: infinite;
        animation-fill-mode: both;
    }

    .sparkle--tl-1 :global(.sparkle-svg) { animation-delay: 0ms; }
    .sparkle--tl-2 :global(.sparkle-svg) { animation-delay: calc(var(--stepMs) * 1ms); }
    .sparkle--tl-3 :global(.sparkle-svg) { animation-delay: calc(var(--stepMs) * 2ms); }

    .sparkle--br-1 :global(.sparkle-svg) {
        animation-delay: calc(
                (var(--sparkleDurationMs) + var(--stepMs) * 2 + var(--betweenClustersPauseMs)) * 1ms
        );
    }
    .sparkle--br-2 :global(.sparkle-svg) {
        animation-delay: calc(
                (var(--sparkleDurationMs) + var(--stepMs) * 3 + var(--betweenClustersPauseMs)) * 1ms
        );
    }
    .sparkle--br-3 :global(.sparkle-svg) {
        animation-delay: calc(
                (var(--sparkleDurationMs) + var(--stepMs) * 4 + var(--betweenClustersPauseMs)) * 1ms
        );
    }

    /* Critical: all animations need the full cycle duration, not just one sparkle duration */
    .sparkle,
    .sparkle :global(.sparkle-svg) {
        animation-duration: calc(var(--totalCycleMs) * 1ms);
    }
</style>