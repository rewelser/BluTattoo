---
interface Layer {
    src?: string;
    alt?: string;
    speed?: number;
    direction?: "up" | "down" | "left" | "right";
    max?: number;
    class?: string;
}

interface Props {
    layers?: Layer[];
    class?: string;
    heightClass?: string;
}

import ParallaxLayer from "./ParallaxLayer.astro";

const {
    layers = [],
    class: className = "",
    heightClass = "min-h-[80vh]",
} = Astro.props;
---

<section class={`parallax-layers ${heightClass} ${className}`}>
    {layers.map((layer) => (
            <ParallaxLayer
                    speed={layer.speed}
                    direction={layer.direction}
                    max={layer.max}
                    class={layer.class}
            >
                {layer.src && (
                        <img
                                src={layer.src}
                                alt={layer.alt ?? ""}
                                loading="lazy"
                                decoding="async"
                        />
                )}
            </ParallaxLayer>
    ))}

    <div class="parallax-layers__content">
        <slot />
    </div>
</section>

<style>
    .parallax-layers {
        position: relative;
        overflow: hidden;
        isolation: isolate;
    }

    .parallax-layers__content {
        position: relative;
        z-index: 10;
    }
</style>