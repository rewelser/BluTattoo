---
import type {ImageSourceOrMetadata} from "../../domain/decor/types.ts";
import {getImageSrc} from "../../domain/decor/selectors.ts";
import type {ImageMetadata} from "astro";
import type {SvgComponent} from "astro/types";

interface Props {
    frame: ImageMetadata;
    framedImage: ImageMetadata;
    frameMask: SvgComponent;
    photoAlt: string;
    class?: string;
}

const {
    frame,
    framedImage,
    frameMask: FrameMask,
    photoAlt,
    class: className = ""
} = Astro.props;

const frameUsed = getImageSrc(frame);
const framedImageUsed = getImageSrc(framedImage);

const frameAspectRatio = typeof frame === "object" && "width" in frame && "height" in frame ? `${frame.width} / ${frame.height}` : undefined;
---
<>
    <div data-framed-image-container class={`relative overflow-hidden rounded-2xl ${className}`}>
        <div
                class="frame-mask h-full w-full"
                style={`mask-image: url("${FrameMask.src}"); -webkit-mask-image: url("${FrameMask.src}");`}
        >
            <img
                    src={framedImageUsed}
                    alt={photoAlt}
                    data-framed-image
                    loading="lazy"
                    decoding="async"
                    class="absolute object-cover transition-transform duration-300"
            />
        </div>

        <img
                src={frameUsed}
                alt=""
                data-frame
                data-frame-src={frameUsed}
                loading="lazy"
                decoding="async"
                class="absolute inset-0 h-full w-full object-contain pointer-events-none"
                aria-hidden="true"
        />

        <!--<svg-->
        <!--        class="absolute inset-0 h-full w-full opacity-0 pointer-events-none"-->
        <!--        xmlns="http://www.w3.org/2000/svg"-->
        <!--        viewBox="0 0 1000 1510.93"-->
        <!--&gt;-->
        <!--    <path data-frame-window-->
        <!--          d="M966.25,814.67v566.63H201.91v-566.63c0-3.14.03-6.24.12-9.35,4.94-206.75,174.12-372.83,382.05-372.83s377.11,166.08,382.05,372.83c.09,3.1.12,6.21.12,9.35Z"-->
        <!--          style="fill: none;"/>-->
        <!--</svg>-->

        <!--<svg-->
        <!--        class="absolute inset-0 h-full w-full opacity-0 pointer-events-none"-->
        <!--        xmlns="http://www.w3.org/2000/svg"-->
        <!--        viewBox="0 0 1000 1544.23"-->
        <!--&gt;-->
        <!--    <path data-frame-window-->
        <!--          d="M966.53,687.78v839.45H193.55v-728.03c0-209.57,176.92-379.47,395.15-379.47,177.86,0,328.27,112.85,377.83,268.05Z"/>-->
        <!--</svg>-->

        <FrameMask class="absolute inset-0 h-full w-full opacity-0 pointer-events-none" data-frame-window />

        <script define:vars={{frameAspectRatio}}>
            (() => {
                const root = document.currentScript.closest("[data-framed-image-container]");
                // const shape = root.querySelector("[data-frame-window]");
                const shape = root.querySelector("[data-frame-window] path");
                const photo = root.querySelector("[data-framed-image]");
                const frame = root.querySelector("[data-frame]");

                const loadFrameAndImage = async () => {

                    // const photoReady =
                    //     photo?.complete ||
                    //     new Promise((resolve) => {
                    //         photo?.addEventListener("load", resolve, {once: true});
                    //         photo?.addEventListener("error", resolve, {once: true});
                    //     });

                    const photoReady = !photo || photo.complete
                        ? Promise.resolve()
                        : new Promise((resolve) => {
                            photo.addEventListener("load", resolve, {once: true});
                            photo.addEventListener("error", resolve, {once: true});
                        });

                    // const frameReady = new Promise((resolve) => {
                    //
                    //     if (frame) {
                    //         const frameSrc = frame.dataset.frameSrc;
                    //         frame.addEventListener("load", resolve, {once: true});
                    //         frame.addEventListener("error", resolve, {once: true});
                    //         frame.src = frameSrc;
                    //     } else {
                    //         resolve();
                    //     }
                    // });

                    const frameReady = frame?.complete
                        ? Promise.resolve()
                        : new Promise((resolve) => {
                            frame?.addEventListener("load", resolve, {once: true});
                            frame?.addEventListener("error", resolve, {once: true});
                        });

                    await Promise.all([photoReady, frameReady]);

                    root.dataset.ready = "true";
                };

                const observer = new IntersectionObserver(
                    ([entry]) => {
                        if (entry.isIntersecting) {
                            observer.unobserve(entry.target);
                            loadFrameAndImage(entry.target);
                        }
                    },
                    {
                        threshold: 0.1,
                    }
                );

                observer.observe(root);

                function syncPhotoToWindow() {
                    const shapeRect = shape.getBoundingClientRect();
                    const wrapperRect = root.getBoundingClientRect();

                    photo.style.top = `${shapeRect.top - wrapperRect.top}px`;
                    photo.style.left = `${shapeRect.left - wrapperRect.left}px`;
                    photo.style.width = `${shapeRect.width}px`;
                    photo.style.height = `${shapeRect.height}px`;
                }

                function syncAspectRatioToFrame() {
                    root.style.aspectRatio = frameAspectRatio ||
                        (frame?.naturalWidth && frame?.naturalHeight
                            ? `${frame.naturalWidth} / ${frame.naturalHeight}`
                            : ".65");
                }

                function visualSync() {
                    syncAspectRatioToFrame();
                    syncPhotoToWindow();
                }

                const ro = new ResizeObserver(visualSync);
                ro.observe(root);

                if (photo.complete) {
                    visualSync();
                } else {
                    photo.addEventListener("load", visualSync, {once: true});
                }

                if (frame?.complete) {
                    visualSync();
                } else {
                    frame?.addEventListener("load", visualSync, {once: true});
                }

                window.addEventListener("load", visualSync, {once: true});
            })()
        </script>
    </div>
    <style>
        [data-framed-image-container] {
            opacity: 0;
            position: relative;
            transition: opacity 3000ms cubic-bezier(.2, .8, .2, 1);
        }

        [data-framed-image-container][data-ready="true"] {
            opacity: 1;
        }

        [data-framed-image-container][data-ready="true"] [data-frame] {
            opacity: .8;
        }

        .frame-mask {
            mask-position: center;
            mask-size: contain;
            mask-repeat: no-repeat;
            mask-mode: alpha;

            -webkit-mask-position: center;
            -webkit-mask-size: contain;
            -webkit-mask-repeat: no-repeat;
        }
    </style>
</>