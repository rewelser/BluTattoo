---
import {getImageSrc} from "../../domain/decor/selectors.ts";
import type {ImageMetadata} from "astro";
import type {SvgComponent} from "astro/types";
import SmartMedia from "./SmartMedia.astro";
import {Image} from "astro:assets";

interface Props {
    kind?: "image" | "video";
    frame: ImageMetadata;
    framedImage: ImageMetadata;

    frameMask: SvgComponent;
    frameMaskImgMetadata: ImageMetadata;
    imageAlt: string;
    class?: string;

    videoSrcDesktop?: string;
    videoSrcMobile?: string;
    posterMobile?: ImageMetadata;
    posterDesktop?: ImageMetadata;
    autoplay?: boolean;
    muted?: boolean;
    loop?: boolean;
    playsinline?: boolean;
    controls?: boolean;
    preload?: "none" | "metadata" | "auto";
}

const {
    kind = "image",
    frame,
    framedImage,
    frameMask: FrameMask,
    frameMaskImgMetadata,
    imageAlt,
    class: className = "",

    videoSrcDesktop,
    videoSrcMobile,
    posterMobile,
    posterDesktop,
    autoplay = false,
    muted = true,
    loop = true,
    playsinline = true,
    controls = false,
    preload = "metadata",
} = Astro.props;

const frameUsed = getImageSrc(frame);

const frameAspectRatio = typeof frame === "object" && "width" in frame && "height" in frame ? `${frame.width} / ${frame.height}` : undefined;
---
<>
    <div  data-framed-media-container class={`relative overflow-hidden rounded-2xl ${className}`}>
        <div
                class="frame-mask h-full w-full"
                style={`mask-image: url("${frameMaskImgMetadata.src}"); -webkit-mask-image: url("${frameMaskImgMetadata.src}");`}
        >
            <SmartMedia
                    data-framed-media
                    imageAttrs={framedImage
                        ? {
                            src: framedImage,
                            alt: imageAlt
                        } : undefined
                    }

                    videoAttrs={{
                        videoSrcDesktop: videoSrcDesktop,
                        videoSrcMobile: videoSrcMobile,
                        posterMobile: posterMobile,
                        posterDesktop: posterDesktop,
                    }}
            />
        </div>

        <Image
                src={frame}
                alt=""
                widths={[640, 768, 960, 1200, 1440, 1920]}
                sizes="auto"
                data-frame
                data-frame-src={frameUsed}
                loading="lazy"
                decoding="async"
                class="absolute inset-0 h-full w-full object-contain pointer-events-none"
                aria-hidden="true"
        />

        <FrameMask class="absolute inset-0 h-full w-full opacity-0 pointer-events-none" data-frame-window/>

        <script define:vars={{frameAspectRatio, kind}}>
            (() => {
                const root = document.currentScript.closest("[ data-framed-media-container]");
                const shape = root.querySelector("[data-frame-window] path");
                const media = root.querySelector("[data-framed-media]");
                const frame = root.querySelector("[data-frame]");

                const observer = new IntersectionObserver(
                    async ([entry]) => {
                        if (entry.isIntersecting) {
                            observer.unobserve(entry.target);
                            root.dataset.ready = "true";
                        }
                    },
                    {
                        rootMargin: "400px 0px",
                        threshold: 0.1,
                    }
                );

                observer.observe(root);

                function syncMediaToWindow() {
                    const shapeRect = shape.getBoundingClientRect();
                    const wrapperRect = root.getBoundingClientRect();

                    media.style.top = `${shapeRect.top - wrapperRect.top}px`;
                    media.style.left = `${shapeRect.left - wrapperRect.left}px`;
                    media.style.width = `${shapeRect.width}px`;
                    media.style.height = `${shapeRect.height}px`;
                }

                function syncAspectRatioToFrame() {
                    root.style.aspectRatio = frameAspectRatio ||
                        (frame?.naturalWidth && frame?.naturalHeight
                            ? `${frame.naturalWidth} / ${frame.naturalHeight}`
                            : ".65");
                }

                function visualSync() {
                    syncAspectRatioToFrame();
                    syncMediaToWindow();
                }

                const ro = new ResizeObserver(visualSync);
                ro.observe(root);

                if (kind === "video") {
                    if (media.readyState >= 1) {
                        visualSync();
                    } else {
                        media.addEventListener("loadedmetadata", visualSync, { once: true });
                        media.addEventListener("canplay", visualSync, { once: true });
                    }
                } else if (media.complete) {
                    visualSync();
                } else {
                    media.addEventListener("load", visualSync, {once: true});
                }

                if (frame?.complete) {
                    visualSync();
                } else {
                    frame?.addEventListener("load", visualSync, {once: true});
                }

                window.addEventListener("load", visualSync, {once: true});
            })()
        </script>
    </div>
    <style>
        [ data-framed-media-container] {
            opacity: 0;
            position: relative;
            transition: opacity 2000ms cubic-bezier(.2, .8, .2, 1);
        }

        [ data-framed-media-container][data-ready="true"] {
            opacity: 1;
        }

        [ data-framed-media-container][data-ready="true"] [data-frame] {
            opacity: .8;
        }

        .frame-mask {
            mask-position: center;
            mask-size: contain;
            mask-repeat: no-repeat;
            mask-mode: alpha;

            -webkit-mask-position: center;
            -webkit-mask-size: contain;
            -webkit-mask-repeat: no-repeat;
        }
    </style>
</>