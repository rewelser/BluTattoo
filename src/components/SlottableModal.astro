---
const {
    cardButtonClass = "",
    modalContentClass = "",
    modalContentHeroClass = "",
    modalContentLowerClass = "",

    cardRadius = "50px",
    expandedRadius = "24px",
    cardShadow = "none",
    expandedShadow = "none",
    cardBorder = "0 solid transparent",
    expandedBorder = "0 solid transparent",
    ...rest
} = Astro.props as {
    cardButtonClass?: string;
    modalContentClass?: string;
    modalContentHeroClass?: string;
    modalContentLowerClass?: string;

    cardRadius: string,
    expandedRadius: string,
    cardShadow: string,
    expandedShadow: string,
    cardBorder: string,
    expandedBorder: string,
};

const id = `modal-${crypto.randomUUID()}`;
const transitionName = `shared-card-${id}`;
// const transitionName = `shared-card`;
const groupAnimationName = `-ua-view-transition-group-anim-${transitionName}`;
// const groupAnimationName = `-ua-view-transition-group-anim-${transitionName}`;
---
<>
    <div class="shell" style={`--transitionName: ${transitionName};`}>
        <button class={`card ${cardButtonClass}`} data-card aria-haspopup="dialog" {...rest}>
            <div class="card-content">
                <slot name="card"/>
            </div>
        </button>

        <dialog class="dialog" data-dialog>

            <article class="expanded-card" data-expanded-card>
                <button class="close" data-close aria-label="Close modal">×</button>
                <div class="modal-content">
                    <div class="modal-content-hero">
                        <slot name="modal-content-hero"/>
                    </div>
                    <div class="modal-content-main">
                        <slot name="modal-content-main"/>
                    </div>
                </div>
            </article>
        </dialog>
        <script define:vars={{
            transitionName,
            groupAnimationName,
            cardRadius,
            expandedRadius,
            cardShadow,
            expandedShadow,
            cardBorder,
            expandedBorder
        }}>
            (() => {
                const script = document.currentScript;
                const shell = script?.closest(".shell");

                const card = shell?.querySelector("[data-card]");
                const dialog = shell?.querySelector("[data-dialog]");
                const close = shell?.querySelector("[data-close]");

                const clearActiveVt = () => {
                    document
                        .querySelectorAll(".shell[data-vt-active]")
                        .forEach((el) => el.removeAttribute("data-vt-active"));
                };

                const vtSetup = (direction) => {
                    clearActiveVt();
                    shell?.setAttribute("data-vt-active", "");
                    document.documentElement.dataset.vtDirection = direction;
                    document.documentElement.style.setProperty("--groupAnimationName", groupAnimationName);
                    document.documentElement.style.setProperty('--cardRadius', cardRadius);
                    document.documentElement.style.setProperty('--expandedRadius', expandedRadius);
                    document.documentElement.style.setProperty('--cardShadow', cardShadow);
                    document.documentElement.style.setProperty('--expandedShadow', expandedShadow);
                    document.documentElement.style.setProperty('--cardBorder', cardBorder);
                    document.documentElement.style.setProperty('--expandedBorder', expandedBorder);
                }

                const vtBreakdown = () => {
                    shell?.removeAttribute("data-vt-active");
                    delete document.documentElement.dataset.vtDirection;
                    for (const name of [
                        "--groupAnimationName",
                        "--cardRadius",
                        "--expandedRadius",
                        "--cardShadow",
                        "--expandedShadow",
                        "--cardBorder",
                        "--expandedBorder",
                    ]) {
                        document.documentElement.style.removeProperty(name);
                    }
                }

                const transition = (fn, direction) => {
                    vtSetup(direction);
                    if (document.startViewTransition) {
                        const t = document.startViewTransition(fn);
                        t.finished.finally(vtBreakdown);
                    } else {
                        fn();
                        vtBreakdown();
                    }
                }

                const openModal = () => {
                    transition(() => {
                        shell.classList.add("is-open");
                        dialog.showModal();
                        dialog.dispatchEvent(new CustomEvent("modal:open"));
                    }, "open")
                }

                const closeModal = () => {
                    transition(() => {
                        shell.classList.remove("is-open");
                        dialog.close();
                        dialog.dispatchEvent(new CustomEvent("modal:close"));
                    }, "close")
                }

                card?.addEventListener("click", openModal);
                close?.addEventListener("click", closeModal);
                dialog?.addEventListener("click", (event) => {
                    if (event.target === dialog) {
                        closeModal();
                    }
                });
            })();
        </script>

        <style define:vars={{
            transitionName,
            groupAnimationName,
            cardRadius,
            expandedRadius,
            cardShadow,
            expandedShadow,
            cardBorder,
            expandedBorder
        }}>
            body:has([data-vt-active]),
            body:has(.shell.is-open) {
                overflow: hidden;
            }

            :global(:root) {
                --vt-duration: 800ms;
                //--vt-duration: 2s;
                --vt-ease: cubic-bezier(0.2, 0.8, 0.2, 1);
            }

            @keyframes slottable-modal-anim {
                from {
                    border-radius: var(--cardRadius);
                    box-shadow: var(--cardShadow);
                    outline: var(--cardBorder);
                }
                to {
                    border-radius: var(--expandedRadius);
                    box-shadow: var(--expandedShadow);
                    outline: var(--expandedBorder);
                }
            }

            .shell[data-vt-active]:not(.is-open) .card {
                view-transition-name: var(--transitionName);
                view-transition-class: slottable-modal;
            }

            .shell[data-vt-active].is-open .expanded-card {
                view-transition-name: var(--transitionName);
                view-transition-class: slottable-modal;
            }

            .shell[data-vt-active] .card {
                visibility: hidden;
            }

            :global(::view-transition-group(.slottable-modal)) {
                animation-name: var(--groupAnimationName), slottable-modal-anim;
                animation-duration: var(--vt-duration), var(--vt-duration);
                animation-timing-function: var(--vt-ease), var(--vt-ease);
                overflow: clip;
            }

            :global(html[data-vt-direction="close"]::view-transition-group(.slottable-modal)) {
                animation-direction: normal, reverse;
            }

            :global(html::view-transition-old(.slottable-modal)),
            :global(html::view-transition-new(.slottable-modal)) {
                animation: none;
                height: 100%;
                overflow: clip;
                object-fit: none;
            }

            .card {
                cursor: pointer;
                border-radius: var(--cardRadius);
                //overflow: hidden;
            }

            .dialog {
                width: min(860px, calc(100dvw - 2rem));
                max-height: calc(100dvh - 2rem);
                height: calc(100dvh - 2rem);
                padding: 0;
                margin: auto;
                border-radius: var(--expandedRadius);
                background: transparent;
                overflow: hidden;
                scrollbar-width: none;
                overscroll-behavior: none;
            }

            .dialog::backdrop {
                background: rgb(10 15 25 / 0.55);
            }

            .expanded-card {
                position: relative;
                overflow: auto;
                height: calc(100dvh - 2rem);
                max-height: calc(100dvh - 2rem);
                border-radius: var(--expandedRadius);
                scrollbar-width: none;
                overscroll-behavior: contain;
                overscroll-behavior-x: none;
            }

            .modal-content {
                border-radius: var(--expandedRadius);
                min-height: 100%;
                height: fit-content;
                overflow: hidden;
                background: white;
            }

            :global(.modal-content-hero img) {
                width: 100%;
                height: min(420px, 45dvh);
                object-fit: cover;
                display: block;
            }

            .close {
                position: sticky;
                top: 0;
                margin-left: auto;
                display: block;
                z-index: 2;

                /* pull it out of the normal layout space */
                margin-bottom: -2.5rem;
                transform: translate(-1rem, 1rem);

                width: 2.5rem;
                height: 2.5rem;
                border: 0;
                border-radius: 999px;
                background: white;
                box-shadow: 0 10px 30px rgb(0 0 0 / 0.25);
                font-size: 1.5rem;
                cursor: pointer;
            }

            @media (prefers-reduced-motion: reduce) {
                :global(::view-transition-group(*)) {
                    animation-duration: 1ms;
                }
            }
        </style>
    </div>
</>