---
import PromoBar from "./PromoBar.astro";
import { loadEventsPublished, pickPromoEvent } from "../../scripts/events";

const {
  fallbackHref = "/events",
  enabled = true,
} = Astro.props as {
  fallbackHref?: string;
  enabled?: boolean;
};
if (!enabled) return;

const events = await loadEventsPublished();
const promoEvent = pickPromoEvent(events, new Date());

if (!promoEvent?.promoBar?.message) return;

const storageKey = `bt_promo_dismissed_${promoEvent.id}`;
const href = promoEvent.promoBar.href ?? fallbackHref;
const { message, color1, color2 } = promoEvent.promoBar;
---

<PromoBar
  storageKey={storageKey}
  message={message}
  href={href}
  color1={color1}
  color2={color2}
/>