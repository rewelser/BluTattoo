---
import PromoBar from "./PromoBar.astro";
import { loadUpcomingCandidates } from "../../scripts/events";
import { getPromoCandidates } from "../../scripts/eventsClient";

const {
  fallbackHref = "/events",
  enabled = true,
} = Astro.props as {
  fallbackHref?: string;
  enabled?: boolean;
};
if (!enabled) return;

const events = await loadUpcomingCandidates(new Date());
const promoCandidates = getPromoCandidates(events);
const promoEvent = promoCandidates.find((ev) => ev.featured) ?? promoCandidates[0] ?? null;

if (!promoEvent?.promoBar?.message) return;

const storageKey = `bt_promo_dismissed_${promoEvent.id}`;
const href = promoEvent.promoBar.href ?? fallbackHref;
const { message, color1, color2 } = promoEvent.promoBar;
---

<PromoBar
  storageKey={storageKey}
  message={message}
  href={href}
  color1={color1}
  color2={color2}
/>