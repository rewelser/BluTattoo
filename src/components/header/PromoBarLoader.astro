---
import PromoBar from "./PromoBar.astro";

import {getPromoCandidates, loadUpcomingCandidates} from "../../domain/events/selectors.ts";

const {
    fallbackHref = "/events",
    enabled = true,
    currentPath = "/"
} = Astro.props as {
    fallbackHref?: string;
    enabled?: boolean;
    currentPath?: string;
};
if (!enabled) return;

// If confused why not simply using getUpcomingCandidates like in UpcomingEvents, or vice versa, it's because index.astro already has events list, and we don't here
const events = await loadUpcomingCandidates(new Date());
const promoCandidates = getPromoCandidates(events);
const promoEvent = promoCandidates.find((ev) => ev.featured) ?? promoCandidates[0] ?? null;

if (!promoEvent?.promoBar?.message) return;
if (currentPath.includes(promoEvent.id)) return;

const storageKey = `bt_promo_dismissed_${promoEvent.id}`;
const href = promoEvent.promoBar.href ?? `${fallbackHref}/${promoEvent.id}`;
const {message, color1, color2} = promoEvent.promoBar;
---

<PromoBar
        storageKey={storageKey}
        message={message}
        href={href}
        color1={color1}
        color2={color2}
/>