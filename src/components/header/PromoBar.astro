---
const {
    id = "promo-bar",
    storageKey = "bt_promo_dismissed",
    message = "Now booking!",
    href = "/booking",
    color1,
    color2,
} = Astro.props;

const duration = 260;

// const defaultBg = "linear-gradient(90deg, #020024 0%, #005eff 100%)";
const defaultBg = "linear-gradient(90deg, #020024 0%, #5613ff 100%)";

const c1 = typeof color1 === "string" && color1.trim() ? color1.trim() : "";
const c2 = typeof color2 === "string" && color2.trim() ? color2.trim() : "";

// Rules:
// - 0 colors -> default gradient
// - 1 color  -> solid
// - 2 colors -> simple 2-stop gradient
const background =
    c1 && c2
        ? `linear-gradient(90deg, ${c1} 0%, ${c2} 100%)`
        : c1
            ? c1
            : defaultBg;
---

<aside
        id={id}
        class="promo-bar fixed top-0 left-0 w-full z-[80]"
        role="region"
        aria-label="Announcement"
        data-state="hidden"
        hidden
>
    <div
            class="h-full flex items-center justify-center gap-3 py-2 px-4 text-white text-sm sm:text-base md:text-2xl"
            style={`background: ${background};`}
    >
        <a
                class="promo-outline flex items-center justify-center w-full h-full text-center"
                href={href}
        >
            {message}
        </a>
        <button
                type="button"
                class="ml-auto px-2 py-1 leading-none cursor-pointer"
                aria-label="Dismiss announcement"
                data-dismiss
        >
            ✕
        </button>
    </div>
</aside>

<style>
    .promo-bar {
        transform: translateY(-100%);
        transition: transform var(--promo-bar-duration) ease;
        will-change: transform;
    }

    .promo-bar[data-state="visible"] {
        transform: translateY(0);
    }

    .promo-bar[data-state="closing"] {
        transform: translateY(-100%);
    }
</style>

<script is:inline define:vars={{storageKey, id, duration}}>
    (() => {
        const root = document.documentElement;
        const banner = document.getElementById(id);
        const seenKey = `${storageKey}_seen_session`;
        if (!banner) return;

        const setAnnouncementHeight = (value) => {
            root.style.setProperty("--promo-bar-h", value);
        };

        const show = () => {
            banner.hidden = false;

            // ensure starting state is applied before transition
            banner.setAttribute("data-state", "hidden");
            setAnnouncementHeight("0px");

            requestAnimationFrame(() => {
                const measured = `${banner.offsetHeight}px`;
                banner.style.setProperty("height", measured);

                requestAnimationFrame(() => {
                    banner.setAttribute("data-state", "visible");
                    setAnnouncementHeight(measured);
                });
            });
        };

        const showInstant = () => {
            banner.hidden = false;
            banner.style.transition = "none";

            const measured = `${banner.offsetHeight}px`;
            banner.style.setProperty("height", measured);
            banner.setAttribute("data-state", "visible");
            setAnnouncementHeight(measured);

            requestAnimationFrame(() => {
                banner.style.transition = "";
            });
        };

        const hide = () => {
            banner.setAttribute("data-state", "closing");
            setAnnouncementHeight("0px");

            window.setTimeout(() => {
                banner.hidden = true;
            }, duration);
        };

        let dismissed = false;
        let seenThisSession = false;

        try {
            dismissed = localStorage.getItem(storageKey) === "1" && false; // remove `&& false` for prod
            seenThisSession = sessionStorage.getItem(seenKey) === "1";
            root.dataset.promoTransition = seenThisSession ? "off" : "on";
            console.log("document.documentElement.dataset.promoTransition", document.documentElement.dataset.promoTransition);
        } catch {
        }

        if (!dismissed) {
            if (seenThisSession) {
                root.dataset.promoTransition = "off";
                showInstant();
            } else {
                root.dataset.promoTransition = "on";
                show();
                try {
                    sessionStorage.setItem(seenKey, "1");
                } catch {
                }
            }
        } else {
            root.dataset.promoTransition = "off";
            banner.hidden = true;
            setAnnouncementHeight("0px");
        }

        banner.querySelector("[data-dismiss]")?.addEventListener("click", () => {
            try {
                localStorage.setItem(storageKey, "1");
            } catch {
            }
            hide();
        });
    })();
</script>