---
const {
    id = "promo-bar",
    storageKey = "bt_promo_dismissed",
    message = "Now booking!",
    href = "/booking",
    color1,
    color2,
} = Astro.props;

const duration = 260;

// const defaultBg = "linear-gradient(90deg, #020024 0%, #005eff 100%)";
const defaultBg = "linear-gradient(90deg, #020024 0%, #5613ff 100%)";

const c1 = typeof color1 === "string" && color1.trim() ? color1.trim() : "";
const c2 = typeof color2 === "string" && color2.trim() ? color2.trim() : "";

// Rules:
// - 0 colors -> default gradient
// - 1 color  -> solid
// - 2 colors -> simple 2-stop gradient
const background =
    c1 && c2
        ? `linear-gradient(90deg, ${c1} 0%, ${c2} 100%)`
        : c1
            ? c1
            : defaultBg;
---
<!-- text-nowrap -->
<aside
        id={id}
        class="promo-bar fixed top-0 left-0 w-full z-[80]"
        role="region"
        aria-label="Announcement"
>
    <div
            class="h-full flex items-center justify-center gap-3 py-2 px-4 text-white text-sm sm:text-base md:text-2xl"
            style={`background: ${background};`}
    >
        <a
                class="promo-outline flex items-center justify-center w-full h-full text-center"
                href={href}
        >
            {message}
        </a>
        <button
                type="button"
                class="ml-auto px-2 py-1 leading-none cursor-pointer"
                aria-label="Dismiss announcement"
                data-dismiss
        >
            ✕
        </button>
    </div>
</aside>

<style>
    .promo-bar {
        transform: translateY(0);
        view-transition-name: promo-bar;
    }

    html[data-load="direct"] .promo-bar:not([data-promo-state="dismiss"]) {
        transition: transform var(--promo-bar-duration) ease;
    }

    @starting-style {
        html[data-load="direct"] .promo-bar:not([data-promo-state="dismiss"]) {
            transform: translateY(-100%);
        }
    }

    html[data-load="internal"] .promo-bar:not([data-promo-state="dismiss"]) {
        transform: translateY(0);
        transition: none;
    }

    .promo-bar[data-promo-state="dismiss"] {
        transform: translateY(-100%);
        transition: transform var(--promo-bar-duration) ease;
    }
</style>

<script is:inline define:vars={{storageKey, id, duration}}>
    (() => {
        const root = document.documentElement;
        const promoBar = document.getElementById(id);

        const internalNav =
            !!navigation.activation?.from &&
            navigation.activation.from.url &&
            new URL(navigation.activation.from.url).origin === location.origin;

        const setAnnouncementHeight = (value) => {
            root.style.setProperty("--promo-bar-h", value);
        }

        const show = () => {
            root.dataset.load = "direct";
            // root.dataset.load = internalNav ? "internal" : "direct";

            const measured = `${promoBar.offsetHeight}px`;
            setAnnouncementHeight(measured);
        }

        const hide = () => {
            promoBar.setAttribute("data-promo-state", "dismiss");
            setAnnouncementHeight("0px");

            // window.setTimeout(() => {
            //     promoBar.hidden = true;
            // }, duration);
        }

        console.log("internalNav", internalNav);

        const dismissed = localStorage.getItem(storageKey) === "1" && false;

        if (!dismissed) {
            show();
        }

        promoBar.querySelector("[data-dismiss]")?.addEventListener("click", () => {
            try {
                // localStorage.setItem(storageKey, "1");
            } catch {
            }
            hide();
        })
    })();
</script>