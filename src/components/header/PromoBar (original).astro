<style>
    .promo-bar {
        transform: translateY(-100%);
        transition: transform var(--promo-bar-duration) ease;
        view-transition-name: promo-bar;
    }

    /* Only animate on real/direct page loads */
    html[data-load="direct"] .promo-bar {
        transform: translateY(-100%);

    }

    /* Internal nav: no "fresh load" animation */
    html[data-load="internal"] .promo-bar:not([data-promo-state="dismiss"]) {
        transform: translateY(0);
    }

    html[data-load="internal"] .promo-bar[data-promo-state="dismiss"] {
        //animation: promo-bar-slide-down var(--promo-bar-duration) ease both reverse;
        transform: translateY(-100%);
    }
</style>

<script is:inline define:vars={{storageKey, id, duration}}>
    (() => {
        const root = document.documentElement;
        const promoBar = document.getElementById(id);

        const setAnnouncementHeight = (value) => {
            root.style.setProperty("--promo-bar-h", value);
        }

        const show = () => {
            const measured = `${promoBar.offsetHeight}px`;
            console.log("measured", measured);
            setAnnouncementHeight(measured);
        }

        const hide = () => {
            promoBar.setAttribute("data-promo-state", "dismiss");
            setAnnouncementHeight("0px");

            // window.setTimeout(() => {
            //     promoBar.hidden = true;
            // }, duration);
        }

        const internalNav =
            !!navigation.activation?.from &&
            navigation.activation.from.url &&
            new URL(navigation.activation.from.url).origin === location.origin;
        console.log("internalNav", internalNav);

        const dismissed = localStorage.getItem(storageKey) === "1" && false;

        root.dataset.load = internalNav ? "internal" : "direct";

        if (!dismissed) {
            console.log(root.style.getPropertyValue("--promo-bar-h"));
            show();
            console.log(root.style.getPropertyValue("--promo-bar-h"));

        }

        // if (internalNav) {
        //     console.log("external nav");
        //
        //
        // } else {
        //     console.log("external nav");
        //     show();
        // }

        promoBar.querySelector("[data-dismiss]")?.addEventListener("click", () => {
            try {
                // localStorage.setItem(storageKey, "1");
            } catch {
            }
            hide();
        })
    })();
</script>

<script is:inline define:vars={{storageKey, id, duration}}>
    (() => {
        return;
        const root = document.documentElement;
        const banner = document.getElementById(id);
        const seenKey = `${storageKey}_seen_session`;
        if (!banner) return;

        const setAnnouncementHeight = (value) => {
            root.style.setProperty("--promo-bar-h", value);
        };

        const show = () => {
            console.log("fffff");
            banner.hidden = false;

            // ensure starting state is applied before transition
            banner.setAttribute("data-state", "hidden");
            setAnnouncementHeight("0px");

            // const measured = `${banner.offsetHeight}px`;
            // banner.setAttribute("data-state", "visible");
            // setAnnouncementHeight(measured);


            requestAnimationFrame(() => {
                // banner.style.setProperty("height", measured);

                requestAnimationFrame(() => {
                    // const measured = `${banner.offsetHeight}px`;
                    // banner.setAttribute("data-state", "visible");
                    // setAnnouncementHeight(measured);
                    requestAnimationFrame(() => {
                        // const measured = `${banner.offsetHeight}px`;
                        // banner.setAttribute("data-state", "visible");
                        // setAnnouncementHeight(measured);
                        requestAnimationFrame(() => {
                            const measured = `${banner.offsetHeight}px`;
                            banner.setAttribute("data-state", "visible");
                            setAnnouncementHeight(measured);
                        });
                    });
                });
            });
        };

        const hide = () => {
            banner.setAttribute("data-state", "closing");
            setAnnouncementHeight("0px");

            window.setTimeout(() => {
                banner.hidden = true;
            }, duration);
        };

        let dismissed = false;
        let seenThisSession = false;

        try {
            dismissed = localStorage.getItem(storageKey) === "1" && false; // remove `&& false` for prod
            seenThisSession = sessionStorage.getItem(seenKey) === "1";
            console.log("seenThisSession try", seenThisSession);

            // root.dataset.promoTransition = seenThisSession ? "off" : "on";
            // root.dataset.promoTransition = "on";
            root.dataset.promoTransition = "off";
            console.log("document.documentElement.dataset.promoTransition", document.documentElement.dataset.promoTransition);
        } catch {
        }

        if (!dismissed) {
            console.log("seenThisSession", seenThisSession);
            show();
        } else {
            banner.hidden = true;
            setAnnouncementHeight("0px");
        }

        if (!seenThisSession) {
            try {
                sessionStorage.setItem(seenKey, "1");
            } catch {
            }
        }

        banner.querySelector("[data-dismiss]")?.addEventListener("click", () => {
            try {
                localStorage.setItem(storageKey, "1");
            } catch {
            }
            hide();
        });
    })();
</script>