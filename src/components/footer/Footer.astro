---
import SocialRow from "../../components/SocialRow.astro";
import {siteInfoSocialsToItems} from "../../domain/contact/adapters.ts";
import HrDivider from "../decor/HrDivider.astro";

const {defaults, site} = Astro.props;
const year = new Date().getFullYear();
const siteName = site?.data?.siteName ?? defaults.siteName;
const addressObj = site?.data.address ?? defaults.address;
const addressString = `${addressObj.streetAddress}, ${addressObj.addressLocality}, ${addressObj.addressRegion} ${addressObj.postalCode}`;
const mapQuery = encodeURIComponent(`${siteName}, ${addressString}`);
const placeId = site?.data.address.placeId ?? defaults.placeId;
const mapHref = placeId
    ? `https://www.google.com/maps/search/?api=1&query=${mapQuery}&query_place_id=${encodeURIComponent(placeId)}`
    : `https://www.google.com/maps/search/?api=1&query=${mapQuery}`;

const phone = site?.data.phone ?? defaults.sitePhone;
const email = site?.data.email ?? defaults.siteEmail;
const hours = site?.data.hours ?? [];
const phoneDigits = phone.replace(/[^\d+]/g, ""); // keep + and digits
const phoneHref = `tel:${phoneDigits}`;
const emailHref = `mailto:${email}`;
const hoursShortline = site?.data.hoursShortline ?? defaults.hoursShortline;
const links = siteInfoSocialsToItems(site?.data?.socials ?? []);
const footerLinkGroups = [
    {
        title: "Contact",
        items: [
            {label: phone, href: phoneHref},
            {label: email, href: emailHref},
            {label: "Make an appointment", href: "/booking/"},
        ],
    },
    {
        title: "Location",
        items: [
            {label: addressString, href: mapHref},
        ],
    },
    {
        title: "Hours",
        items: [
            {text: hoursShortline},
        ],
    },
    {
        title: "Explore",
        items: [
            {label: "Home", href: "/"},
            {label: "Artists", href: "/artists/"},
            {label: "Piercing", href: "/piercing/"},
            {label: "Events", href: "/events/"},
        ],
    },
    {
        title: "Info",
        items: [
            {label: "Aftercare", href: "/aftercare/"},
            {label: "FAQ", href: "/faq/"},
            {label: "Contact", href: "/contact/"},

        ],
    }
];
---

<footer class="bg-black px-6">
    <div
            class="mx-auto max-w-7xl pt-10 pb-4 flex flex-col gap-6 md:flex-row md:items-center md:justify-between"
    >
        {
            site?.data?.socials && (
                        <SocialRow
                                links={links}
                                justificationClass="justify-center md:justify-start"
                                anchorClass="text-orange-100/60 hover:text-orange-100 transition duration-200"
                        />
            )
        }

        <div class="text-sm text-orange-100/70 text-center text-nowrap">
            <span class="font-semibold text-orange-100">{siteName}</span>
            <span class="block sm:inline sm:ml-2">© {year}. All rights reserved.</span
            >
        </div>
    </div>
    <div class="flex justify-center">
        <HrDivider
                text="proudly woman-owned"
                color="oklch(0.954 0.038 75.164 / 30%)"
                className="my-4 py-4 text-xs w-full max-w-7xl"
        />
    </div>

    <nav
            aria-label="Footer links and studio information"
            class="mx-auto grid max-w-7xl grid-cols-1 gap-8 py-8 text-center sm:grid-cols-3 lg:grid-cols-5 sm:text-left"
    >
        {footerLinkGroups.map((group) => (
                <div>
                    <h2 class="text-sm font-semibold uppercase tracking-wide text-orange-100">
                        {group.title}
                    </h2>

                    <ul class="mt-3 space-y-2 text-sm text-orange-100/70">
                        {group.items.map((item) => (
                                <li>
                                    {"href" in item ? (
                                            <a href={item.href} class="transition hover:text-orange-100">
                                                {item.label}
                                            </a>
                                    ) : (
                                            <p class="whitespace-pre-line">{item.text}</p>
                                    )}
                                </li>
                        ))}
                    </ul>
                </div>
        ))}
    </nav>
</footer>
