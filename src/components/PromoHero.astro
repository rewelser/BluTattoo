---
interface Props {
  image: string;
  alt?: string;
  className?: string;
}

const { image, alt = "", className = "" } = Astro.props;
---

<section class={`relative overflow-hidden shadow-lg ${className}`} data-promo-hero-root>
  <div data-skeleton-image class="skeleton-promo-hero-image"></div>
  <img
    data-promo-image
    src={image}
    alt={alt}
    class="w-full h-auto hidden opacity-0 transition-opacity duration-300"
    loading="eager"
    fetchpriority="high"
    decoding="sync"
  />
</section>

<script is:inline>
  async function initPromoImage(root) {
    const img = root.querySelector("[data-promo-image]");
    const skeleton = root.querySelector("[data-skeleton-image]");
    if (!img || !skeleton) return;

    const reveal = async () => {
      try {
        await img.decode();
      } catch {}

      requestAnimationFrame(() => {
        img.classList.remove("hidden");
        skeleton.remove();

        requestAnimationFrame(() => {
          img.classList.remove("opacity-0");
        });
      });
    };

    if (img.complete) {
      reveal();
    } else {
      img.addEventListener("load", reveal, { once: true });
    }
  }

  const root = document.currentScript?.previousElementSibling;
  if (root?.matches("[data-promo-hero-root]")) {
    initPromoImage(root);
  }
</script>