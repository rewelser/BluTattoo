---
import type {ImageMetadata} from "astro";

interface Props {
    isEventPage?: boolean,
    href?: string,
    image: ImageMetadata,
    alt?: string,
    className?: string,
}

const {isEventPage = false, href = "/events/", image, alt = "", className = ""} = Astro.props;
console.log("image (promohero)", image);
---

<div
        class={`relative overflow-hidden shadow-lg ${className}`}
        data-promo-hero-root
>
    <div data-skeleton-image class="skeleton-promo-hero-image"></div>
    {!isEventPage ? (
            <a href={href}>
                <img
                        data-promo-image
                        src={image.src}
                        alt={`${alt} – view event details`}
                        class="w-full h-auto hidden opacity-0 transition-opacity duration-300"
                        loading="eager"
                        fetchpriority="high"
                        decoding="sync"
                />
            </a>
    ) : (
            <button
                    type="button"
                    data-scroll-to-event-btn data-destination="event-info"
                    class="cursor-pointer"
            >
                <img
                        data-promo-image
                        src={image.src}
                        alt={`${alt} – jump to event information`}
                        class="w-full h-auto hidden opacity-0 transition-opacity duration-300"
                        loading="eager"
                        fetchpriority="high"
                        decoding="sync"
                />
            </button>
    )}

</div>

<script is:inline>
    (() => {
        async function initPromoImage(root) {
            const img = root.querySelector("[data-promo-image]");
            const skeleton = root.querySelector("[data-skeleton-image]");
            if (!img || !skeleton) return;

            const reveal = async () => {
                try {
                    await img.decode();
                } catch {
                }

                requestAnimationFrame(() => {
                    img.classList.remove("hidden");
                    skeleton.remove();

                    requestAnimationFrame(() => {
                        img.classList.remove("opacity-0");
                    });
                });
            };

            if (img.complete) {
                reveal();
            } else {
                img.addEventListener("load", reveal, {once: true});
            }
        }

        const root = document.currentScript?.previousElementSibling;
        if (root?.matches("[data-promo-hero-root]")) {
            initPromoImage(root);
        }

        const scrollBtn = document.querySelector("[data-scroll-to-event-btn]");
        if (scrollBtn) {
            scrollBtn.addEventListener("click", e => {
                const destinationValue = scrollBtn.dataset.destination;
                const target = document.querySelector(`[data-section="${destinationValue}"]`);

                if (target) {
                    target.scrollIntoView({behavior: 'smooth'});
                }
            })
        }
    })();
</script>
