---
import SlottableModal from "./SlottableModal.astro";
import ShareRow1 from "./ShareRow.astro";
import ShareRow from "./ShareRow.astro";
import {defaults} from "../config/site.ts";
import type {ImageSourceOrMetadata} from "../domain/decor/types.ts";
import {getImageSrc} from "../domain/decor/selectors.ts";
import ShareIcon from "./graphics/shareIcon.astro";

const {
    shareTitle = defaults.siteName,
    shareHero = defaults.siteLogo,
    variant = 1,
    variant2ShareText = "share this",
    heroFullBleed = false,
    shellClass,
    cardButtonClass = "m-5",
    cardButtonColorClass = "bg-white/80",
    expandedCardClass,
    modalContentClass,
    modalContentHeroClass,
    modalContentMainClass,
    cardRadius,
} = Astro.props as {
    shareTitle: string;
    shareHero: ImageSourceOrMetadata;
    variant: number;
    variant2ShareText: string;
    heroFullBleed: boolean;
    shellClass: string;
    cardButtonClass: string;
    cardButtonColorClass: string;
    expandedCardClass: string;
    modalContentClass: string;
    modalContentHeroClass: string;
    modalContentMainClass: string;
    cardRadius: string;
}

const shareHeroUsed = getImageSrc(shareHero);
---


<SlottableModal
        square=true
        shellClass={shellClass}
        cardButtonClass={`${variant === 2 ? "p-1 rounded-md shadow-md" : "aspect-square h-12 w-12 p-3 rounded-full" } ${cardButtonColorClass} ${cardButtonClass} `}
        modalContentHeroClass={`${heroFullBleed ? "" : "p-5"}`}
        modalContentMainClass="h-full flex flex-col justify-center"
        cardRadius={cardRadius}
        duration="420ms"
>
    <Fragment slot="card">
        {
            variant === 2 ? (
                    <div class="flex items-center justify-center">
                        <span class="text-nowrap p-1">{variant2ShareText}</span>
                        <span class="p-1">
                        <ShareIcon class="w-4 h-4"/>
                        </span>
                    </div>
            ) : (
                    <div class="flex items-center justify-center">
                        <ShareIcon/>
                    </div>
            )
        }
    </Fragment>
    <Fragment slot="modal-content-hero">
        <div class="h-full flex flex-col min-h-0">
            {
                heroFullBleed ? (
                        <div class="flex-1 min-h-0">
                            <img class="object-cover object-top" src={shareHeroUsed} alt={`Image for: ${shareTitle}`}/>
                        </div>
                ) : (
                        <div class="p-6 flex-1 min-h-0 rounded-3xl" style="box-shadow: inset 0 0 10px rgba(0, 0, 0, 0.1);">
                            <img class="object-contain" src={shareHeroUsed} alt={`Image for: ${shareTitle}`}/>
                        </div>
                )
            }
        </div>
    </Fragment>
    <Fragment slot="modal-content-main">
        <span class="text-center font-medium pt-4">
            Share {shareTitle}:
        </span>
        <ShareRow class="h-full"/>
    </Fragment>
</SlottableModal>