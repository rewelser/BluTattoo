---
import SlottableModal from "./SlottableModal.astro";
import ShareRow1 from "./ShareRow.astro";
import ShareRow from "./ShareRow.astro";
import {defaults} from "../config/site.ts";

const {
    siteName = defaults.siteName,
    logo = defaults.siteLogo,
} = Astro.props as {
    siteName: string;
    logo: string;
}
---


<SlottableModal
        square=true
        cardButtonClass="m-5"
        modalContentHeroClass="p-5"
        modalContentMainClass="h-full flex flex-col justify-center"
        cardRadius="50px"
        duration="420ms"
>
    <Fragment slot="card">
        <div class="aspect-square h-12 w-12 bg-white/80 p-3 rounded-full flex items-center justify-center">
            <!--<img src="/uploads/misc_images/graphics/share.svg" alt=""/>-->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 390.07 440.74">
                <path d="M81.39,219.2h-42.4c-13.19,0-23.99,7.82-23.99,17.37v171.8c0,9.56,10.79,17.37,23.99,17.37h312.09c13.19,0,23.99-7.82,23.99-17.37v-171.8c0-9.56-10.79-17.37-23.99-17.37h-48.82,48.81c13.19,0,23.99,7.82,23.99,17.37v171.8c0,9.56-10.79,17.37-23.99,17.37H38.99c-13.19,0-23.99-7.82-23.99-17.37v-171.8c0-9.56,10.79-17.37,23.99-17.37h48.82"
                      style="fill: none; stroke: #000; stroke-linecap: round; stroke-linejoin: round; stroke-width: 30px;"/>
                <line x1="195.03" y1="322.47" x2="195.03" y2="15"
                      style="fill: none; stroke: #000; stroke-linecap: round; stroke-linejoin: round; stroke-width: 30px;"/>
                <line x1="73.62" y1="152.26" x2="195.03" y2="15"
                      style="fill: none; stroke: #000; stroke-linecap: round; stroke-linejoin: round; stroke-width: 30px;"/>
                <line x1="316.45" y1="152.26" x2="195.03" y2="15"
                      style="fill: none; stroke: #000; stroke-linecap: round; stroke-linejoin: round; stroke-width: 30px;"/>
            </svg>
        </div>
    </Fragment>
    <Fragment slot="modal-content-hero">
        <div class="h-full flex flex-col min-h-0">
            <div class="p-6 flex-1 min-h-0 rounded-3xl" style="box-shadow: inset 0 0 10px rgba(0, 0, 0, 0.1);">
                <img class="object-contain" src={logo} alt={`${siteName} Logo`}/>
            </div>
        </div>
    </Fragment>
    <Fragment slot="modal-content-main">
        <span class="text-center font-medium">
            Share {siteName}!
        </span>
        <ShareRow class="h-full"/>
    </Fragment>
</SlottableModal>