---
// import type {EventItem} from "../../domain/events/types";
import type { EventItem } from "../domain/events/types";
import {fmtDate} from "../domain/events/format.ts";

interface Props {
    ev: Pick<EventItem, "startDate" | "endDate">;
}

const {ev} = Astro.props;
---
<>
    {!ev.endDate || ev.startDate === ev.endDate ? (
            <time datetime={ev.startDate}>{fmtDate(ev.startDate)}</time>
    ) : (
            <>
                <time datetime={ev.startDate}>{fmtDate(ev.startDate)}</time>
                {" – "}
                <time datetime={ev.endDate}>{fmtDate(ev.endDate)}</time>
            </>
    )}
</>
