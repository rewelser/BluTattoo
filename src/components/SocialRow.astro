---
import {iconRegistry} from "./graphics/icons/registry";
import {socialTypes} from "../domain/contact/defs.ts";

import type {IconVariant, SocialItems} from "../domain/contact/types.ts";

const {
    links = [],
    variant = "thin",
    class: className = "",
    anchorClass = "",
    iconClass = "w-6 h-6",
    extraFilter,
} = Astro.props as {
    links: SocialItems;
    variant?: IconVariant;
    class?: string;
    anchorClass?: string;
    iconClass?: string;
    extraFilter?: (item: SocialItems[number]) => boolean;
};

const aAttrs = {target: "_blank", rel: "noopener noreferrer"};
---

<div class={`flex items-center gap-3 ${className}`}>
    {
        socialTypes.map((key) => {
            const item = links.find(
                (item) =>
                    item.type === key &&
                    item.enabled &&
                    (extraFilter ? extraFilter(item) : true),
            );
            const href = item?.href;

            const entry = iconRegistry[key]?.[variant] ?? iconRegistry[key]?.default;
            if (!entry) return null;

            const {label, Icon} = entry;
            return (
                item && (
                        <a
                                href={href}
                                aria-label={label}
                                {...aAttrs}
                                class={`flex items-center ${anchorClass}`}
                        >
                            <Icon class={`fill-current ${iconClass}`}/>
                        </a>
                )
            );
        })
    }
</div>
