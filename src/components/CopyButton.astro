<script>
    const buttons = document.querySelectorAll<HTMLButtonElement>(".copy-link-btn");

    buttons.forEach((button) => {
        if (button.dataset.copyButtonReady === "true") return;
        button.dataset.copyButtonReady = "true";

        const label = button.querySelector<HTMLElement>(".label");
        const copyIcon = button.querySelector<SVGElement>(".copy-icon");
        const checkIcon = button.querySelector<SVGElement>(".check-icon");

        const copyText = button.dataset.copyText ?? "";
        const defaultLabel = button.dataset.label ?? "Copy";
        const copiedLabel = button.dataset.copiedLabel ?? "Copied!";

        let timeout: ReturnType<typeof setTimeout>;

        button.addEventListener("click", async () => {
            try {
                await navigator.clipboard.writeText(copyText);

                if (label) label.textContent = copiedLabel;

                copyIcon?.classList.add("hidden");
                checkIcon?.classList.remove("hidden");

                button.classList.add("text-green-600");

                clearTimeout(timeout);

                timeout = setTimeout(() => {
                    if (label) label.textContent = defaultLabel;

                    copyIcon?.classList.remove("hidden");
                    checkIcon?.classList.add("hidden");

                    button.classList.remove("text-green-600");
                }, 2000);
            } catch (err) {
                console.error("Failed to copy", err);
            }
        });
    });
</script>