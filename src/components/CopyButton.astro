---
const {
    copyText,
    thing = "Text",
    label,
    copiedLabel,
    hideLabel = false,
    class: className = "",
} = Astro.props as {
    copyText: string;
    thing?: string;
    label?: string;
    copiedLabel?: string;
    hideLabel?: boolean;
    class?: string;
};

const defaultLabel = label ?? `Copy ${thing}`;
const defaultCopiedLabel = copiedLabel ?? `${thing} Copied!`;
---

<button
        type="button"
        class:list={[
            "copy-link-btn inline-flex items-center gap-1.5 p-2 m-2 rounded-md shadow-md transition-colors cursor-pointer",
            className,
        ]}
        aria-live="polite"
        data-copy-text={copyText}
        data-label={defaultLabel}
        data-copied-label={defaultCopiedLabel}
>
    <span class="relative inline-flex h-[1.25em] w-[1.25em] shrink-0 items-center justify-center">
        <svg
                class="copy-icon h-[1.25em] w-[1.25em]"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 500 500"
                aria-hidden="true"
        >
            <path
                    d="M430.75,59.34c0-30.84-23.5-56.34-54.65-59.32l-.14-.02h-180.42c-29.1,2.32-52.19,25.2-54.89,54.4l-.02.14v271.5l.02.15c2.87,29.57,26.4,52.45,55.96,54.43h.11s178.06-.23,178.06-.23c15.7-.02,28.26-8.19,36.03-15.05,12.7-11.21,19.98-27.24,19.97-44l-.03-262ZM401.2,323.48c0,6.35-3.27,13.02-9.72,19.81-5.79,5.01-11.99,7.51-20.08,8.08h-171.84c-8.22-.64-14.33-3.15-19.78-8.15-4.49-4.54-9.8-11.66-9.81-19.84l-.11-265.65c1.23-15.5,13.4-27.48,29-28.53l173.51.22c14.6.02,27.02,11.77,28.92,27.37l-.09,266.69Z"
                    fill="currentColor"
            />
            <path
                    d="M359.05,447.06l-.02.19c-1.77,14.06-8.01,26.56-18.07,36.15-9.98,9.52-22.75,15.25-36.94,16.59l-.14.02-178.4-.24c-14.31-.02-29.11-7.06-40.61-19.3-10.09-10.75-15.65-24.93-15.65-39.94l.02-262.54c0-16.62,7.58-32.82,20.78-44.43,2.83-2.49,6.23-3.8,9.83-3.8,1.8,0,3.64.33,5.44.98,4.8,1.73,8.55,6.44,9.11,11.47.8,7.09-2.36,11.11-5.89,14.38-6.18,5.73-9.86,13.05-9.86,19.58l-.11,266.51c1.73,15.38,13.89,27.08,29.02,27.88l3.76-.12,165.29.13c11.35,0,19.72-3.32,25.63-10.15,4.91-5.68,7.44-11.46,7.53-17.19l.33-23.42c.09-6.2,5.29-12.88,13.84-13.34.25,0,.48-.02.73-.02,6.91,0,14.3,5.16,14.32,12.83l.05,27.79Z"
                    fill="currentColor"
            />
        </svg>

        <svg
                class="check-icon hidden h-[1.25em] w-[1.25em]"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 512 512"
                aria-hidden="true"
        >
            <line
                    x1="453.38"
                    y1="133.06"
                    x2="207.49"
                    y2="378.94"
                    fill="none"
                    stroke="currentColor"
                    stroke-linecap="round"
                    stroke-miterlimit="10"
                    stroke-width="30"
            />
            <line
                    x1="205.19"
                    y1="377.28"
                    x2="58.62"
                    y2="230.71"
                    fill="none"
                    stroke="currentColor"
                    stroke-linecap="round"
                    stroke-miterlimit="10"
                    stroke-width="30"
            />
        </svg>
    </span>

    <span class={`label ${hideLabel ? "hidden" : ""}`}>{defaultLabel}</span>
</button>

