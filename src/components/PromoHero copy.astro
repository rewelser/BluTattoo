---
interface Props {
  image: string;
  alt?: string;
  className?: string;
}

const { image, alt = "", className = "" } = Astro.props;
---

<section class={`relative overflow-hidden shadow-lg ${className}`}>
  <div class="skeleton-promo-hero-img h-[70vh]"></div>
  <!-- had used onload="this.previousElementSibling.remove();", but this fires only after image loads, not before paint(?) -->
  <img
    src={image}
    alt={alt}
    class="w-full h-auto"
    loading="eager"
    fetchpriority="high"
    decoding="sync"
    onload="this.previousElementSibling.remove();"
  />

  <!-- gradient overlay -->
  <!-- <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent"></div> -->
</section>
