---
interface Props {
  image: string;
  alt?: string;
  className?: string;
}

const { image, alt = "", className = "" } = Astro.props;
---
<!-- this was an experiment to see if absolutely positioning the skeleton and putting it below the image would better size the skeleton based on the image. This does work, but it actually looks worse in practice because as the image loads, there's a moment after the fallback is replaced but before the image is rendered in layout where the skeleton has no height. Once the reflow happens for the image the skeleton is the same dimensions as the image, which is nice, but at that point the visual jank has already occurred. The only way to avoid this is either to put a minimum height on the whole section, or an aspect-ratio or something, and then removing it as well once the image is loaded. If this approach is taken, then that also requires putting the same fixed height on the dummy section in the fallback. That isn't a huge ask, given that the alternative requires a fixed height on the skeleton, and then a matching height on the skeleton in the fallback, but since this rounds out to be around the same amount of logic, and something still has to have a fixed height, then we may as well keep the original approach and ditch this one. Will be logged for posterity though. -->
<section class={`relative overflow-hidden shadow-lg min-h-[80vh] ${className}`}>
  <!-- had used onload attribute before switching to initPromoImage below, but onload fires only after image fully loads, not before paint(?) adds it to layout -->
  <img
    data-promo-image
    src={image}
    alt={alt}
    class="w-full h-auto opacity-0 transition-opacity duration-300"
    loading="eager"
    fetchpriority="high"
    decoding="sync"
  />
  <div data-skeleton-image class="skeleton-promo-hero-image absolute inset-8"></div>
</section>

<script is:inline>
  async function initPromoImage(img) {
    console.log("i1");
    const skeleton = img.parentElement?.querySelector("[data-skeleton-image]");
    if (!skeleton) return;

    const reveal = async () => {
      try {
        await img.decode();
      } catch {}

      requestAnimationFrame(() => {
        img.classList.remove("hidden");
        skeleton.remove();

        requestAnimationFrame(() => {
          img.classList.remove("opacity-0");
        });
      });
    };

    if (img.complete) {
      reveal();
      console.log("fishfish");
    } else {
      img.addEventListener("load", reveal, { once: true });
    }
  }

  document.querySelectorAll("[data-promo-image]").forEach(initPromoImage);
</script>
