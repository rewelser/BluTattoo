---
import {socialTypes} from "../domain/contact/defs.ts";
import type {IconType, IconVariant} from "../domain/contact/types.ts";
import {getIconEntry, iconRegistry} from "./graphics/icons/registry.ts";
import ScrollXContainer from "./scaffolding/ScrollXContainer.astro";
import {getEntry} from "astro:content";
import {defaults} from "../config/site.ts";
import ShareIcon from "./graphics/shareIcon.astro";

const site = await getEntry("siteInfo", "main");
const siteName = site?.data?.siteName ?? defaults.siteName;

const {
    shareTitle = `Check out ${siteName}`,
    shareUrl = new URL(Astro.url.pathname, Astro.site).toString(),
    // shareTypes = [
    //     'x',
    //     'facebook',
    //     'facebookMessenger',
    //     'instagram',
    //     'whatsapp',
    //     'snapchat',
    // ],
    shareTypes = [
        'x',
        'facebook',
        'whatsapp',
        'snapchat',
    ],
    variant = "roundColor",
    class: className,
    justificationClass,
    scrollBtnClass,
    anchorClass = "p-1 w-[60px]",
    iconClass = "w-12 h-12",
} = Astro.props as {
    shareTitle?: string;
    shareUrl?: string;
    shareTypes: IconType[],
    variant?: IconVariant;
    class?: string;
    justificationClass?: string;
    scrollBtnClass?: string;
    anchorClass?: string;
    iconClass?: string;
};

const buttonAnchorContainerClass = "h-full flex flex-col justify-center";
const buttonClass = "flex flex-col items-center justify-center font-light text-xs cursor-pointer";
const buttonIconSpanClass = "flex justify-center items-center rounded-full overflow-hidden bg-gray-200 p-3";
const labelClass = "pt-2 text-center text-nowrap whitespace-nowrap overflow-visible";

/**
 * For debugging:
 * --------------
 *  console.log({
 *      "Astro.url.href": Astro.url.href,
 *      "Astro.url.pathname": Astro.url.pathname,
 *      "Astro.url.origin": Astro.url.origin,
 *      "Astro.originPathname": Astro.originPathname,
 *      "window.location.href": window.location.href,
 *      "Astro.site": Astro.site
 *  })
 **/
// case "reddit": return `https://www.reddit.com/submit?url=${encodeURIComponent(shareUrl)}&title=${encodeURIComponent(shareTitle)}`;
const encodeShareUrl = (key: IconType) => {
    switch (key) {
        case "x":
            return `https://twitter.com/intent/tweet?url=${encodeURIComponent(shareUrl)}&text=${encodeURIComponent(shareTitle)}`;

        case "facebook":
            return `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(shareUrl)}`;

        case "whatsapp":
            return `https://wa.me/?text=${encodeURIComponent(`${shareTitle} ${shareUrl}`)}`;

        case "snapchat":
            return `https://www.snapchat.com/share?link=${encodeURIComponent(shareUrl)}`;

        case "email":
            return `mailto:?subject=${encodeURIComponent(shareTitle)}&body=${encodeURIComponent(shareUrl)}`;

        default:
            return null;
    }
};
---

<ScrollXContainer class={className} scrollContainerClass="px-3" justificationClass={justificationClass}
                  scrollBtnClass={scrollBtnClass}>
    <Fragment slot="scrollContent">
        <div class={buttonAnchorContainerClass}>
            <button
                    type="button"
                    class={`copy-link-btn ${buttonClass} ${anchorClass}`}
                    aria-live="polite"
            >
            <span
                    class={`icon-shell ${buttonIconSpanClass} ${iconClass}`}
            >
                <svg class="copy-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
                  <path d="M325.79,373.05l-89.29,89.29c-37.45,37.45-98.76,37.45-136.23-.03l-50.6-50.6c-37.45-37.45-37.45-98.76,0-136.21l89.29-89.29"
                        style="fill: none; stroke: currentColor; stroke-linecap: round; stroke-miterlimit: 10; stroke-width: 30px;"/>
                  <path d="M186.22,138.96l89.29-89.29c37.45-37.45,98.76-37.45,136.21,0l50.6,50.6c37.47,37.47,37.47,98.79.03,136.23l-89.29,89.29"
                        style="fill: none; stroke: currentColor; stroke-linecap: round; stroke-miterlimit: 10; stroke-width: 30px;"/>
                  <line x1="377.29" y1="134.72" x2="131.4" y2="380.6"
                        style="fill: none; stroke: currentColor; stroke-linecap: round; stroke-miterlimit: 10; stroke-width: 30px;"/>
                </svg>

                <svg class="check-icon hidden" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
                  <line x1="453.38" y1="133.06" x2="207.49" y2="378.94"
                        style="fill: none; stroke: currentColor; stroke-linecap: round; stroke-miterlimit: 10; stroke-width: 30px;"/>
                  <line x1="205.19" y1="377.28" x2="58.62" y2="230.71"
                        style="fill: none; stroke: currentColor; stroke-linecap: round; stroke-miterlimit: 10; stroke-width: 30px;"/>
                </svg>
            </span>

                <span class={`label ${labelClass}`}>Copy Link</span>
            </button>

            <script define:vars={{shareUrl}}>
                (() => {
                    const button = document.currentScript?.previousElementSibling;

                    if (!(button instanceof HTMLButtonElement)) return;

                    const label = button.querySelector(".label");
                    const copyIcon = button.querySelector(".copy-icon");
                    const checkIcon = button.querySelector(".check-icon");

                    let timeout;

                    button.addEventListener("click", async () => {
                        try {
                            await navigator.clipboard.writeText(shareUrl);

                            label.textContent = "Link Copied!";

                            copyIcon?.classList.add("hidden");
                            checkIcon?.classList.remove("hidden");

                            button.classList.add("text-green-600");

                            clearTimeout(timeout);

                            timeout = setTimeout(() => {
                                label.textContent = "Copy Link";

                                copyIcon?.classList.remove("hidden");
                                checkIcon?.classList.add("hidden");

                                button.classList.remove("text-green-600");
                            }, 2000);
                        } catch (err) {
                            console.error("Failed to copy link", err);
                        }
                    });
                })();
            </script>
        </div>

        {
            shareTypes.map((key) => {
                const entry = getIconEntry(key, [variant, "round", "thick"]);

                if (!entry) return null;
                const {label, Icon} = entry;
                return (
                    entry && (
                            <div class={buttonAnchorContainerClass}>
                                <a href={encodeShareUrl(key)} aria-label={label} target="_blank" rel="noopener noreferrer"
                                   class={`flex flex-col items-center justify-center font-light text-xs ${anchorClass}`}>
                                    <!--    <a href="fishy.com" aria-label={label} class={`flex flex-col items-center justify-center font-light text-xs ${anchorClass}`}>-->
                                    <Icon class={iconClass}/>
                                    <span class={`${labelClass}`}>{label}</span>
                                </a>
                            </div>
                    )
                );
            })
        }

        <a href={encodeShareUrl(`email`)} aria-label="Email" target="_blank" rel="noopener noreferrer"
           class={`flex flex-col items-center justify-center font-light text-xs ${anchorClass}`}>
            <span class={`${buttonIconSpanClass} ${iconClass}`}>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
                    <rect x="17.87" y="86.25" width="476.26" height="339.5" rx="68.47" ry="68.47"
                          style="fill: none; stroke: currentColor; stroke-linecap: round; stroke-linejoin: round; stroke-width: 30px;"/>
                    <line x1="446.99" y1="140.91" x2="256.16" y2="287.17"
                          style="fill: none; stroke: currentColor; stroke-linecap: round; stroke-linejoin: round; stroke-width: 30px;"/>
                    <line x1="333.35" y1="247.13" x2="446.99" y2="371.09"
                          style="fill: none; stroke: currentColor; stroke-linecap: round; stroke-linejoin: round; stroke-width: 30px;"/>
                    <line x1="65.01" y1="140.91" x2="255.84" y2="287.17"
                          style="fill: none; stroke: currentColor; stroke-linecap: round; stroke-linejoin: round; stroke-width: 30px;"/>
                    <line x1="178.65" y1="247.13" x2="65.01" y2="371.09"
                          style="fill: none; stroke: currentColor; stroke-linecap: round; stroke-linejoin: round; stroke-width: 30px;"/>
                </svg>
            </span>
            <span class={`${labelClass}`}>Email</span>
        </a>

        <div class={buttonAnchorContainerClass}>
            <button class={`${buttonClass} ${anchorClass}`}>
            <span class={`${buttonIconSpanClass} ${iconClass}`}>
                <ShareIcon/>
            </span>
                <span class={`${labelClass}`}>More</span>

            </button>
            <script define:vars={{shareUrl, shareTitle}}>
                (() => {
                    const button = document.currentScript?.previousElementSibling;

                    if (!(button instanceof HTMLButtonElement)) return;

                    button.addEventListener('click', async () => {
                        if (navigator.share) {
                            try {
                                await navigator.share({
                                    title: document.title,
                                    text: shareTitle,
                                    url: shareUrl
                                });
                            } catch (err) {
                                console.error('Share failed:', err);
                            }
                        } else {
                            alert('Sharing not supported on this browser');
                        }
                    });
                })();
            </script>
        </div>
    </Fragment>
</ScrollXContainer>