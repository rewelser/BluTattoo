---
import {socialTypes} from "../domain/contact/defs.ts";
import type {IconType, IconVariant} from "../domain/contact/types.ts";
import {getIconEntry, iconRegistry} from "./graphics/icons/registry.ts";
import ScrollXContainer from "./scaffolding/ScrollXContainer.astro";
const {
    shareTypes = [
        'x',
        'facebook',
        'facebookMessenger',
        'instagram',
        'whatsapp',
        'snapchat',
    ],
    variant = "roundColor",
    class: className = "",
    anchorClass = "",
    iconClass = "w-12 h-12",

} = Astro.props as {
    shareTypes: IconType[],
    variant?: IconVariant;
    class?: string;
    anchorClass?: string;
    iconClass?: string;
};
---

<div class={`flex gap-4 ${className}`}>
    <button
            type="button"
            class={`relative copy-link-btn flex flex-col items-center justify-between font-light text-xs cursor-pointer ${anchorClass}`}
            aria-live="polite"
    >
    <span
            class={`icon-shell flex justify-center items-center rounded-full overflow-hidden bg-gray-200 p-3 ${iconClass}`}
    >
        <svg
                class="copy-icon"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 498.83 498.83"
        >
            <path
                    d="M319.2,366.46l-89.29,89.29c-37.45,37.45-98.76,37.45-136.23-.03l-50.6-50.6c-37.45-37.45-37.45-98.76,0-136.21l89.29-89.29"
                    style="fill: none; stroke: currentColor; stroke-linecap: round; stroke-miterlimit: 10; stroke-width: 30px;"
            />
            <path
                    d="M179.63,132.37l89.29-89.29c37.45-37.45,98.76-37.45,136.21,0l50.6,50.6c37.47,37.47,37.47,98.79.03,136.23l-89.29,89.29"
                    style="fill: none; stroke: currentColor; stroke-linecap: round; stroke-miterlimit: 10; stroke-width: 30px;"
            />
            <line
                    x1="370.7"
                    y1="128.13"
                    x2="124.82"
                    y2="374.01"
                    style="fill: none; stroke: currentColor; stroke-linecap: round; stroke-miterlimit: 10; stroke-width: 30px;"
            />
        </svg>

        <svg
                class="check-icon hidden"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 424.75 275.88"
        >
            <line
                    x1="409.75"
                    y1="15"
                    x2="163.87"
                    y2="260.88"
                    style="fill: none; stroke: currentColor; stroke-linecap: round; stroke-miterlimit: 10; stroke-width: 30px;"
            />
            <line
                    x1="161.57"
                    y1="259.23"
                    x2="15"
                    y2="112.66"
                    style="fill: none; stroke: currentColor; stroke-linecap: round; stroke-miterlimit: 10; stroke-width: 30px;"
            />
        </svg>
    </span>

        <span class="label pt-2 text-nowrap text-start absolute bottom-0 left-1/2 -translate-x-1/2 overflow-visible">Copy Link</span>
    </button>

    <script is:inline>
        (() => {
            const button = document.currentScript?.previousElementSibling;

            if (!(button instanceof HTMLButtonElement)) return;

            const label = button.querySelector(".label");
            const copyIcon = button.querySelector(".copy-icon");
            const checkIcon = button.querySelector(".check-icon");

            let timeout;

            button.addEventListener("click", async () => {
                try {
                    await navigator.clipboard.writeText(window.location.href);

                    label.textContent = "Link Copied!";

                    copyIcon?.classList.add("hidden");
                    checkIcon?.classList.remove("hidden");

                    button.classList.add("text-green-600");

                    clearTimeout(timeout);

                    timeout = setTimeout(() => {
                        label.textContent = "Copy Link";

                        copyIcon?.classList.remove("hidden");
                        checkIcon?.classList.add("hidden");

                        button.classList.remove("text-green-600");
                    }, 2000);
                } catch (err) {
                    console.error("Failed to copy link", err);
                }
            });
        })();
    </script>


    {
        shareTypes.map((key) => {
            const entry = getIconEntry(key, [variant, "round", "thick"]);

            if (!entry) return null;
            const {label, Icon} = entry;
            return (
                entry && (
                        <a
                                href="fishy.com"
                                aria-label={label}
                                class={`flex flex-col items-center justify-center font-light text-xs ${anchorClass}`}
                        >
                            <Icon class={iconClass}/>
                            <span class="pt-2">{label}</span>
                        </a>
                )
            );
        })
    }

</div>