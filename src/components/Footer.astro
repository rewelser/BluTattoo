---
import SocialRow from "../components/SocialRow.astro";
import { siteInfoSocialsToItems } from "../scripts/socials";

const { defaults, site } = Astro.props;
const year = new Date().getFullYear();
const siteName = site?.data?.siteName ?? defaults.siteName;
const links = siteInfoSocialsToItems(site.data.socials);
---

<footer class="bg-black bg-transparent">
  <div
    class="mx-auto max-w-7xl px-6 py-10 flex flex-col gap-6 md:flex-row md:items-center md:justify-between"
  >
    {
      site?.data?.socials && (
        <SocialRow
          links={links}
          class="justify-center"
          anchorClass="text-orange-100/60 hover:text-orange-100 transition duration-200"
        />
      )
    }

    <div class="text-sm text-orange-100/70 text-center">
      <span class="font-semibold text-orange-100">{siteName}</span>
      <span class="block sm:inline sm:ml-2">© {year}. All rights reserved.</span
      >
    </div>

    <!-- <nav class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-white/70">
      <a href="/about" class="hover:text-white transition">About</a>
      <a href="/contact" class="hover:text-white transition">Contact</a>
      <a href="/blog" class="hover:text-white transition">Blog</a>
      <a href="/projects" class="hover:text-white transition">Projects</a>
      <a href="/privacy" class="hover:text-white transition">Privacy</a>
      <a href="/terms" class="hover:text-white transition">Terms</a>
    </nav> -->
  </div>
</footer>
